---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Weifang Tianyuan Waterproof Material Co., Ltd. - Professional Waterproofing Solutions" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans">
		<header class="bg-white border-b border-slate-200 sticky top-0 z-50">
			<nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
				<div class="flex items-center gap-2">
					<span class="text-2xl font-bold tracking-tight text-blue-700">TIANYUAN</span>
					<span class="text-xs uppercase tracking-widest text-slate-500 font-semibold border-l pl-2 border-slate-300">Waterproof</span>
				</div>
				<div class="hidden md:flex gap-8 text-sm font-medium">
					<a href="/" class="text-blue-600">Home</a>
					<a href="#" class="hover:text-blue-600 transition-colors">Products</a>
					<a href="#" class="hover:text-blue-600 transition-colors">Solutions</a>
					<a href="#" class="hover:text-blue-600 transition-colors">About Us</a>
					<a href="#" class="hover:text-blue-600 transition-colors">Contact</a>
				</div>
				<button class="bg-blue-700 text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-blue-800 transition-all shadow-sm">
					Get a Quote
				</button>
			</nav>
		</header>
		<slot />
		<footer class="bg-slate-900 text-slate-400 py-12 mt-20">
			<div class="max-w-7xl mx-auto px-4 text-center">
				<p class="text-sm">© 2026 Weifang Tianyuan Waterproof Material Co., Ltd. All rights reserved.</p>
			</div>
		</footer>
	</body>
</html>
