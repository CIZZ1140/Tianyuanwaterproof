---
const { product } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<a class="card group block" href={`${base}products/${product.slug}/`}>
  <div class="mb-5 grid h-44 place-items-center rounded-2xl bg-gradient-to-br from-slate-100 to-slate-200">
    <div class="h-24 w-40 rounded-[50%] border-[18px] border-industrial bg-white shadow-inner"></div>
  </div>
  <p class="mb-2 text-xs font-bold uppercase tracking-wider text-accent">{product.category}</p>
  <h3 class="text-xl font-bold text-slate-950 group-hover:text-industrial">{product.name}</h3>
  <p class="mt-3 line-clamp-3 text-sm leading-6 text-slate-600">{product.intro}</p>
  <span class="mt-5 inline-flex text-sm font-bold text-industrial">View Details →</span>
</a>
