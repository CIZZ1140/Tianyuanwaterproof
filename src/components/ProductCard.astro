---
interface Props { title: string; href: string; image: string; excerpt?: string; }
const { title, href, image, excerpt } = Astro.props;

const imageFitClass = "object-contain p-4";
---
<a href={href} class="group card block overflow-hidden hover:-translate-y-1 hover:shadow-xl transition-all h-full flex flex-col">
  <div class="aspect-[4/3] bg-white border-b border-slate-100 flex items-center justify-center overflow-hidden">
    <img 
      src={image} 
      alt={title} 
      loading="lazy" 
      class={`h-full w-full ${imageFitClass} transition-transform duration-500 group-hover:scale-105`} 
      onerror="this.src='/placeholder.webp'; this.onerror=null;"
    />
  </div>
  <div class="p-5">
    <h3 class="text-base font-extrabold text-navy group-hover:text-brand">{title}</h3>
    {excerpt && <p class="mt-2 line-clamp-2 text-sm leading-6 text-slate-600">{excerpt}</p>}
    <span class="mt-4 inline-flex text-sm font-bold text-brand">View Details →</span>
  </div>
</a>

