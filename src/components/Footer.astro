---
import { site, productCategories, applications, nav } from '../data/site';

type FooterLink = {
  label: string;
  href: string;
};

type FooterGroup = {
  title: string;
  links: FooterLink[];
};

type ContactItem = {
  label: string;
  value: string;
  href?: string;
};

type FooterProps = {
  logoSrc?: string;
  logoAlt?: string;
  brandName?: string;
  description?: string;
  footerGroups?: FooterGroup[];
  contactItems?: ContactItem[];
  legalLinks?: FooterLink[];
  copyright?: string;
};

const defaultFooterGroups: FooterGroup[] = [
  {
    title: "PRODUCTS",
    links: productCategories.map(cat => ({ label: cat.title, href: cat.href })),
  },
  {
    title: "APPLICATIONS",
    links: applications.map(app => ({ label: app.title, href: `/applications/${app.slug}/` })),
  },
  {
    title: "QUICK LINKS",
    links: nav.slice(nav.length - 3).map(link => ({ label: link.label, href: link.href })),
  },
];

const defaultContactItems: ContactItem[] = [
  { label: "Location", value: site.address },
  { label: "Email", value: site.email, href: `mailto:${site.email}` },
  { label: "WhatsApp", value: site.phone, href: `https://wa.me/${site.whatsapp}` },
  { label: "Website", value: site.domain.replace('https://', ''), href: "/" },
];

const defaultLegalLinks: FooterLink[] = [
  { label: "Privacy Policy", href: "/#why-us" },
  { label: "Terms of Use", href: "/#why-us" },
  { label: "Sitemap", href: "/#why-us" },
];

const {
  logoSrc = "https://img.tyuanwaterproof.com/logo.png",
  logoAlt = `${site.shortName} Logo`,
  brandName = site.brand,
  description = `${site.brand} is a professional manufacturer of waterproofing materials, integrating R&D, production, sales and global service.`,
  footerGroups = defaultFooterGroups,
  contactItems = defaultContactItems,
  legalLinks = defaultLegalLinks,
  copyright = `© ${new Date().getFullYear()} ${site.brand}. All Rights Reserved.`,
} = Astro.props as FooterProps;
---

<footer class="relative w-full bg-[#081E36] text-[#B8C7DA]">
  <div class="mx-auto grid max-w-7xl gap-y-12 gap-x-8 px-4 py-20 md:grid-cols-2 lg:grid-cols-12 lg:px-8">
    <div class="lg:col-span-3">
      <a href="/" class="flex items-center gap-5 group">
        <img
          src={logoSrc}
          alt={logoAlt}
          class="h-[52px] w-[52px] object-contain transition-transform group-hover:scale-105"
        />
        <div>
          <span class="block text-[22px] font-extrabold leading-tight text-white uppercase tracking-wider">
            {brandName}
          </span>
          <span class="text-xs text-white/50 font-bold tracking-tight">Bitumen Membrane & Roofing Felt Manufacturer</span>
        </div>
      </a>

      <p class="mt-8 max-w-sm text-[15px] leading-[1.6] text-[#B8C7DA]">
        {description}
      </p>
    </div>

    {footerGroups.map((group) => (
      <nav aria-label={group.title} class="lg:col-span-2">
        <h3 class="text-[17px] font-bold uppercase tracking-widest text-white">
          {group.title}
        </h3>

        <ul class="mt-6 space-y-4">
          {group.links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-[15px] text-[#DDE7F2] transition hover:text-[#F58A1F] hover:translate-x-1 inline-block transform"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    ))}

    <div class="lg:col-span-3">
      <h3 class="text-[17px] font-bold uppercase tracking-widest text-white">
        CONTACT INFO
      </h3>

      <ul class="mt-6 space-y-6">
        {contactItems.map((item) => (
          <li class="text-[15px] leading-relaxed">
            <span class="block text-white/50 uppercase tracking-wider font-bold text-xs mb-1">{item.label}</span>
            {item.href ? (
              <a
                href={item.href}
                class="text-[#DDE7F2] transition hover:text-[#F58A1F] break-words whitespace-normal"
              >
                {item.value}
              </a>
            ) : (
              <span class="text-[#DDE7F2]">{item.value}</span>
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t border-white/5 bg-[#051124]">
    <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-8 text-[11px] text-white/30 font-bold uppercase tracking-widest md:flex-row md:items-center md:justify-between md:px-6 lg:px-8">
      <p>{copyright}</p>

      <nav class="flex flex-wrap gap-8" aria-label="Legal navigation">
        {legalLinks.map((link) => (
          <a
            href={link.href}
            class="transition hover:text-[#F58A1F]"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</footer>
