---
import { site, productCategories, applications, nav } from '../data/site';

type FooterLink = {
  label: string;
  href: string;
};

type FooterGroup = {
  title: string;
  links: FooterLink[];
};

type ContactItem = {
  label: string;
  value: string;
  href?: string;
};

type FooterProps = {
  logoSrc?: string;
  logoAlt?: string;
  brandName?: string;
  description?: string;
  footerGroups?: FooterGroup[];
  contactItems?: ContactItem[];
  legalLinks?: FooterLink[];
  copyright?: string;
};

const defaultFooterGroups: FooterGroup[] = [
  {
    title: "PRODUCTS",
    links: productCategories.map(cat => ({ label: cat.title, href: cat.href })),
  },
  {
    title: "APPLICATIONS",
    links: applications.map(app => ({ label: app.title, href: `/applications/${app.slug}/` })),
  },
  {
    title: "QUICK LINKS",
    links: nav.slice(nav.length - 3).map(link => ({ label: link.label, href: link.href })),
  },
];

const defaultContactItems: ContactItem[] = [
  { label: "Location", value: site.address },
  { label: "Email", value: site.email, href: `mailto:${site.email}` },
  { label: "WhatsApp", value: site.phone, href: `https://wa.me/${site.whatsapp}` },
  { label: "Website", value: site.domain.replace('https://', ''), href: "/" },
];

const defaultLegalLinks: FooterLink[] = [
  { label: "Privacy Policy", href: "/#why-us" },
  { label: "Terms of Use", href: "/#why-us" },
  { label: "Sitemap", href: "/#why-us" },
];

const {
  logoSrc = "https://img.tyuanwaterproof.com/logo.png",
  logoAlt = `${site.shortName} Logo`,
  brandName = site.brand,
  description = `${site.brand} is a professional manufacturer of waterproofing materials, integrating R&D, production, sales and global service.`,
  footerGroups = defaultFooterGroups,
  contactItems = defaultContactItems,
  legalLinks = defaultLegalLinks,
  copyright = `© ${new Date().getFullYear()} ${site.brand}. All Rights Reserved.`,
} = Astro.props as FooterProps;
---

<footer class="relative w-full bg-[#081E36] text-[#B8C7DA]">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-16 md:grid-cols-2 md:px-6 lg:grid-cols-6 lg:px-8">
    <div class="lg:col-span-2">
      <a href="/" class="inline-flex items-center gap-3">
        <img
          src={logoSrc}
          alt={logoAlt}
          class="h-12 w-12 rounded-full bg-white object-contain p-1"
        />
        <div>
          <span class="block text-base font-extrabold leading-tight text-white uppercase tracking-wider">
            {brandName}
          </span>
          <span class="text-[10px] text-white/50 font-bold tracking-tight">Bitumen Membrane & Roofing Felt Manufacturer</span>
        </div>
      </a>

      <p class="mt-6 max-w-sm text-xs leading-7 text-[#B8C7DA]">
        {description}
      </p>
    </div>

    {footerGroups.map((group) => (
      <nav aria-label={group.title}>
        <h3 class="text-xs font-extrabold uppercase tracking-widest text-white/90">
          {group.title}
        </h3>

        <ul class="mt-5 space-y-3">
          {group.links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-xs text-[#DDE7F2] transition hover:text-[#F58A1F] hover:translate-x-1 inline-block transform"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    ))}

    <div>
      <h3 class="text-xs font-extrabold uppercase tracking-widest text-white/90">
        CONTACT INFO
      </h3>

      <ul class="mt-5 space-y-4">
        {contactItems.map((item) => (
          <li class="text-xs leading-5">
            <span class="block text-white/40 uppercase tracking-tighter font-bold text-[9px] mb-0.5">{item.label}</span>
            {item.href ? (
              <a
                href={item.href}
                class="text-[#DDE7F2] transition hover:text-[#F58A1F] break-all"
              >
                {item.value}
              </a>
            ) : (
              <span class="text-[#DDE7F2]">{item.value}</span>
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t border-white/5 bg-[#051124]">
    <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-6 text-[10px] text-white/40 font-bold uppercase tracking-wider md:flex-row md:items-center md:justify-between md:px-6 lg:px-8">
      <p>{copyright}</p>

      <nav class="flex flex-wrap gap-6" aria-label="Legal navigation">
        {legalLinks.map((link) => (
          <a
            href={link.href}
            class="transition hover:text-[#F58A1F]"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</footer>
