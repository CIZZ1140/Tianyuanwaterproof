---
import { productCategories, applications, site } from '@data/site';
---
<footer class="bg-deep text-white">
  <div class="container grid gap-10 py-12 md:grid-cols-2 lg:grid-cols-5">
    <div class="lg:col-span-1">
      <div class="flex items-center gap-3">
        <img src={site.logo} alt="Tianyuan Waterproof logo" class="h-12 w-12 object-contain bg-white rounded-full p-1" />
        <div>
          <p class="font-extrabold tracking-wide">{site.brand}</p>
          <p class="text-xs text-white/60">{site.tagline}</p>
        </div>
      </div>
      <p class="mt-4 text-sm leading-6 text-white/70">TIANYUAN WATERPROOF is a professional manufacturer of waterproofing materials, integrating R&D, production, sales and global service.</p>
    </div>
    <div>
      <h3 class="mb-4 text-sm font-extrabold uppercase">Products</h3>
      <ul class="space-y-2 text-sm text-white/70">{productCategories.slice(0,4).map((c)=><li><a href={c.href} class="hover:text-white">{c.title}</a></li>)}</ul>
    </div>
    <div>
      <h3 class="mb-4 text-sm font-extrabold uppercase">Applications</h3>
      <ul class="space-y-2 text-sm text-white/70">{applications.map((a)=><li><a href={`/applications/${a.slug}/`} class="hover:text-white">{a.title}</a></li>)}</ul>
    </div>
    <div>
      <h3 class="mb-4 text-sm font-extrabold uppercase">Quick Links</h3>
      <ul class="space-y-2 text-sm text-white/70">
        <li><a href="/about/" class="hover:text-white">About Us</a></li>
        <li><a href="/projects/" class="hover:text-white">Projects</a></li>
        <li><a href="/contact/" class="hover:text-white">Contact Us</a></li>
      </ul>
    </div>
    <div>
      <h3 class="mb-4 text-sm font-extrabold uppercase">Contact Info</h3>
      <ul class="space-y-2 text-sm text-white/70">
        <li>{site.address}</li>
        <li><a href={`mailto:${site.email}`} class="hover:text-white">{site.email}</a></li>
        <li>WhatsApp: {site.whatsapp}</li>
        <li><a href={site.siteUrl} class="hover:text-white">{site.siteUrl.replace('https://','')}</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10 py-5">
    <div class="container flex flex-col gap-3 text-xs text-white/60 md:flex-row md:items-center md:justify-between">
      <p>© {site.year} TIANYUAN WATERPROOF. All Rights Reserved.</p>
      <div class="flex gap-4"><a href="/" class="hover:text-white">Privacy Policy</a><a href="/" class="hover:text-white">Terms of Use</a><a href="/" class="hover:text-white">Sitemap</a></div>
    </div>
  </div>
</footer>
