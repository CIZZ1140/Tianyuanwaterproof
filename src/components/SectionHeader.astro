---
interface Props { title: string; href?: string; linkLabel?: string; }
const { title, href, linkLabel = 'View All' } = Astro.props;
---
<div class="mb-6 flex items-end justify-between gap-4">
  <div>
    <h2 class="section-title">{title}</h2>
    <div class="mt-2 h-1 w-16 bg-brand"></div>
  </div>
  {href && <a href={href} class="hidden text-sm font-bold text-navy hover:text-brand sm:inline-flex">{linkLabel} →</a>}
</div>
