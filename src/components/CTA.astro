---
const base = import.meta.env.BASE_URL;
---
<section class="bg-navy py-16 text-white">
  <div class="container-wrap grid gap-8 md:grid-cols-[1.4fr_.6fr] md:items-center">
    <div>
      <p class="eyebrow">Request a quote</p>
      <h2 class="mt-3 text-3xl font-bold text-white md:text-4xl">Need waterproofing materials for bulk supply or project use?</h2>
      <p class="mt-4 max-w-3xl text-white/70">Send product type, thickness, width, roll length, quantity and destination port. We can prepare quotation, TDS, packaging details and OEM options.</p>
    </div>
    <div class="flex flex-wrap gap-3 md:justify-end">
      <a class="btn-primary" href={`${base}contact/`}>Contact Sales</a>
      <a class="btn-secondary" href={`${base}technical/download-center/`}>Download Catalog</a>
    </div>
  </div>
</section>
