---
import { site } from '../data/site';
const whatsappLink = "https://wa.me/" + site.whatsapp.replace(/\D/g, '') + "?text=Hi%2C%20I'm%20interested%20in%20your%20waterproofing%20materials.";
---

<section class="bg-white py-16" id="inquiry" aria-labelledby="inq-title">
  <div class="container mx-auto px-4">
    <div class="rounded-[2rem] bg-gradient-to-br from-[#0E2A47] to-[#1F4E8C] p-8 md:p-12 shadow-2xl relative overflow-hidden">
      <!-- Background Decorative Elements -->
      <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-64 h-64 bg-white/5 rounded-full blur-3xl" aria-hidden="true"></div>
      <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-96 h-96 bg-brand/10 rounded-full blur-3xl" aria-hidden="true"></div>

      <div class="relative z-10 grid gap-12 lg:grid-cols-[1fr_0.8fr] lg:items-center">
        <div class="text-white">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 text-white text-[10px] font-bold uppercase tracking-[0.2em] mb-8 border border-white/10">
            <span class="relative flex h-2 w-2" aria-hidden="true">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-brand"></span>
            </span>
            Ready to Help
          </div>
          <h2 class="text-3xl md:text-5xl font-black leading-[1.1] text-white" id="inq-title">Quick Inquiry</h2>
          <p class="mt-6 text-lg text-white/70 leading-relaxed max-w-xl font-medium">Leave a quick message regarding your project needs, and our team will get back to you shortly.</p>
          
          <div class="mt-10 flex flex-col sm:flex-row gap-6">
            <!-- WhatsApp Card -->
            <a 
              href={whatsappLink} 
              target="_blank" 
              rel="noopener noreferrer"
              class="group flex items-center gap-4 p-5 rounded-2xl bg-white/5 border border-white/10 transition-all duration-300 hover:bg-white/15 hover:-translate-y-1 hover:border-white/25 shadow-sm"
            >
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-white/10 text-white transition-all duration-300 group-hover:bg-brand group-hover:text-white group-hover:scale-110">
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2A9.86 9.86 0 0 0 2.2 11.84a9.72 9.72 0 0 0 1.34 4.94L2 22l5.36-1.48a9.86 9.86 0 0 0 4.68 1.19h.01A9.86 9.86 0 0 0 21.9 11.86 9.86 9.86 0 0 0 12.04 2Zm5.78 14.04c-.24.67-1.4 1.28-1.96 1.36-.5.07-1.13.1-1.82-.11-.42-.13-.95-.31-1.64-.61-2.89-1.25-4.77-4.16-4.91-4.35-.14-.19-1.17-1.56-1.17-2.97 0-1.41.74-2.1 1-2.39.26-.29.58-.36.77-.36h.56c.18.01.42-.07.66.5.24.58.82 2 .89 2.14.07.14.12.31.02.5-.1.19-.14.31-.29.48-.14.17-.3.38-.43.51-.14.14-.29.29-.12.58.17.29.75 1.23 1.6 2 .1.09 1.11.99 2.57 1.37.32.08.5.07.69-.12.22-.22.79-.92 1-1.24.22-.31.43-.26.72-.16.29.1 1.86.88 2.18 1.04.31.16.53.24.6.38.07.14.07.81-.17 1.48Z"/></svg>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase tracking-wider text-white/40 transition-colors group-hover:text-white/60">WhatsApp</p>
                <p class="text-sm font-bold text-white transition-colors group-hover:text-brand">{site.whatsapp}</p>
              </div>
            </a>

            <!-- Email Card -->
            <a 
              href={`mailto:${site.email}`}
              class="group flex items-center gap-4 p-5 rounded-2xl bg-white/5 border border-white/10 transition-all duration-300 hover:bg-white/15 hover:-translate-y-1 hover:border-white/25 shadow-sm"
            >
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-white/10 text-white transition-all duration-300 group-hover:bg-brand group-hover:text-white group-hover:scale-110">
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase tracking-wider text-white/40 transition-colors group-hover:text-white/60">Email Inquiry</p>
                <p class="text-sm font-bold text-white transition-colors group-hover:text-brand">{site.email}</p>
              </div>
            </a>
          </div>
        </div>

        <div class="bg-white rounded-[2rem] p-8 shadow-2xl">
          <form action="https://formspree.io/f/mzdqdpwd" method="POST" class="space-y-4">
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="full-name" class="block text-[11px] font-bold text-slate-600 uppercase tracking-widest mb-2 ml-1">Full Name</label>
                <input id="full-name" type="text" name="Name" placeholder="Your Name" required class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3.5 text-sm text-navy focus:border-brand focus:ring-4 focus:ring-brand/10 focus:outline-none transition-all" />
              </div>
              <div>
                <label for="email-address" class="block text-[11px] font-bold text-slate-600 uppercase tracking-widest mb-2 ml-1">Email Address</label>
                <input id="email-address" type="email" name="Email" placeholder="name@company.com" required class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3.5 text-sm text-navy focus:border-brand focus:ring-4 focus:ring-brand/10 focus:outline-none transition-all" />
              </div>
            </div>
            <div>
              <label for="company-name" class="block text-[11px] font-bold text-slate-600 uppercase tracking-widest mb-2 ml-1">Company</label>
              <input id="company-name" type="text" name="Company" placeholder="Company Name" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3.5 text-sm text-navy focus:border-brand focus:ring-4 focus:ring-brand/10 focus:outline-none transition-all" />
            </div>
            <div>
              <label for="interested-product" class="block text-[11px] font-bold text-slate-600 uppercase tracking-widest mb-2 ml-1">Interested Product</label>
              <select id="interested-product" name="Product" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3.5 text-sm text-navy focus:border-brand focus:ring-4 focus:ring-brand/10 focus:outline-none transition-all appearance-none bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2364748b%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C/polyline%3E%3C/svg%3E')] bg-[length:18px_18px] bg-[right_1rem_center] bg-no-repeat cursor-pointer">
                <option value="">Select product category...</option>
                <option value="Bitumen Membranes">Bitumen Membranes</option>
                <option value="Polymer Membranes">Polymer Membranes</option>
                <option value="Asphalt Shingles">Asphalt Shingles</option>
                <option value="Waterproof Tapes">Waterproof Tapes</option>
                <option value="Waterproof Coatings">Waterproof Coatings</option>
                <option value="Geosynthetics">Geosynthetics</option>
                <option value="Other Waterproof Products">Other Waterproof Products</option>
              </select>
            </div>
            <div>
              <label for="message-text" class="block text-[11px] font-bold text-slate-600 uppercase tracking-widest mb-2 ml-1">Message</label>
              <textarea id="message-text" name="Message" rows="4" placeholder="How can we help you? (Quantity, Specifications...)" required class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3.5 text-sm text-navy focus:border-brand focus:ring-4 focus:ring-brand/10 focus:outline-none transition-all resize-none"></textarea>
            </div>
            <button type="submit" class="w-full rounded-xl bg-[#F58A1F] py-4 text-[15px] font-bold text-white shadow-xl shadow-[#F58A1F]/20 transition-all hover:bg-[#E37812] hover:-translate-y-1 active:translate-y-0">Submit Inquiry →</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
