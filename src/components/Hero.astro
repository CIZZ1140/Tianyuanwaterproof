---
import { stats as siteStats } from '../data/site';
import { Award, Factory, Globe2, Cog, Clock } from 'lucide-astro';

type HeroAction = {
  label: string;
  href: string;
};

type HeroStat = {
  value: string;
  label: string;
  icon: any;
};

type HeroProps = {
  imageSrc?: string;
  mobileImageSrc?: string;
  imageAlt?: string;
  title?: string;
  description?: string;
  primaryAction?: HeroAction;
  secondaryAction?: HeroAction;
};

const {
  imageSrc = "https://img.tyuanwaterproof.com/banner.webp",
  mobileImageSrc = "https://img.tyuanwaterproof.com/banner-mobile.webp",
  imageAlt = "Professional waterproofing membrane installation on a modern roof",
  title = "Waterproofing Materials Supplier from China",
  description = "Factory supply of waterproofing membranes, tapes and coatings with OEM packaging, technical data support and fast quotation service.",
  primaryAction = {
    label: "Request a Quote →",
    href: "/contact/",
  },
  secondaryAction = {
    label: "View Products",
    href: "/products/",
  },
} = Astro.props as HeroProps;

const stats: HeroStat[] = [
  { value: "30+", label: "Years Experience", icon: Award },
  { value: "5", label: "Production Lines", icon: Factory },
  { value: "50+", label: "Export Countries", icon: Globe2 },
  { value: "OEM/ODM", label: "Custom Service", icon: Cog },
  { value: "24/7", label: "Quick Response", icon: Clock },
];
---

<section class="relative w-full overflow-hidden bg-[#0E2A47] text-white">
  <div class="relative min-h-[600px] md:min-h-[720px] flex items-center">
    <!-- Background Image -->
    <div class="absolute inset-0 z-0">
      <picture>
        <source srcset={mobileImageSrc} media="(max-width: 768px)" width="768" height="1024" />
        <img
          src={imageSrc}
          alt={imageAlt}
          class="absolute inset-0 h-full w-full object-cover object-center lg:object-[center_right]"
          loading="eager"
          fetchpriority="high"
          decoding="sync"
          width="1920"
          height="1080"
          sizes="100vw"
        />
      </picture>
    </div>

    <!-- Overlay Gradient -->
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(8,24,49,0.95)_0%,rgba(14,42,71,0.85)_40%,rgba(14,42,71,0.3)_100%)] z-10"></div>

    <!-- Content -->
    <div class="relative mx-auto w-full max-w-[1680px] px-6 lg:px-16 z-20">
      <div class="max-w-[720px] text-left lg:-translate-y-6">
        <div class="inline-flex items-center gap-2 bg-blue-600/20 border border-blue-400/30 px-4 py-1.5 rounded-full mb-8 backdrop-blur-md">
          <span class="w-2 h-2 bg-blue-400 rounded-full animate-pulse"></span>
          <span class="text-xs font-black uppercase tracking-widest text-blue-200">Factory Direct Sourcing</span>
        </div>
        
        <h1 style="line-height: 1.25;" class="text-5xl lg:text-7xl font-black tracking-tight text-white mb-8">
          {title}
        </h1>

        <p class="text-lg md:text-xl leading-relaxed text-slate-200 max-w-[620px] mb-12 font-medium opacity-90">
          {description}
        </p>

        <div class="flex flex-wrap gap-6">
          <a
            href={primaryAction.href}
            class="inline-flex items-center justify-center rounded-2xl bg-[#C05800] px-12 py-5 text-base font-black text-white shadow-2xl shadow-[#C05800]/40 transition-all hover:bg-[#D96A0A] hover:-translate-y-1"
          >
            {primaryAction.label}
          </a>

          <a
            href={secondaryAction.href}
            class="inline-flex items-center justify-center rounded-2xl border-2 border-white/20 px-12 py-5 text-base font-bold text-white transition-all hover:bg-white hover:text-[#0E2A47] hover:border-white backdrop-blur-sm"
          >
            {secondaryAction.label}
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Redesigned Stats Bar - Major Improvement -->
  <div class="relative z-30 bg-[#0E2A47] border-y border-white/10">
    <div class="absolute inset-0 bg-gradient-to-r from-blue-900/40 via-transparent to-blue-900/40 opacity-50"></div>
    <dl class="relative mx-auto grid w-full max-w-[1680px] grid-cols-2 md:grid-cols-5 divide-x divide-white/10">
      {stats.map((item) => (
        <div class="group px-6 py-10 flex flex-col items-center justify-center text-center transition-all hover:bg-blue-600/10">
          <div class="mb-4 text-blue-400 group-hover:scale-110 group-hover:text-blue-300 transition-all duration-300" aria-hidden="true">
            <item.icon size={28} strokeWidth={2.5} />
          </div>
          <dd class="text-[32px] lg:text-[42px] font-black text-white leading-none mb-3 tracking-tighter">
            {item.value}
          </dd>
          <dt class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.2em] text-blue-200/60 group-hover:text-blue-200 transition-colors">
            {item.label}
          </dt>
        </div>
      ))}
    </dl>
  </div>
</section>
