---
import { stats as siteStats } from '../data/site';

type HeroAction = {
  label: string;
  href: string;
};

type HeroStat = {
  value: string;
  label: string;
};

type HeroProps = {
  imageSrc?: string;
  mobileImageSrc?: string;
  imageAlt?: string;
  title?: string;
  description?: string;
  primaryAction?: HeroAction;
  secondaryAction?: HeroAction;
  stats?: HeroStat[];
};

const {
  imageSrc = "https://img.tyuanwaterproof.com/banner.webp",
  mobileImageSrc = "https://img.tyuanwaterproof.com/banner-mobile.webp",
  imageAlt = "Professional waterproofing membrane installation on a modern roof",
  title = "Waterproofing Materials Supplier from China",
  description = "Factory supply of waterproofing membranes, tapes and coatings with OEM packaging, technical data support and fast quotation service.",
  primaryAction = {
    label: "Request a Quote →",
    href: "/contact/",
  },
  secondaryAction = {
    label: "View Products",
    href: "/products/",
  },
  stats = [
    { value: "30+", label: "Years Experience" },
    { value: "5", label: "Product Lines" },
    { value: "50+", label: "Countries Exported" },
    { value: "OEM/ODM", label: "Service" },
    { value: "24/7", label: "Quick Response" },
  ],
} = Astro.props as HeroProps;
---

<section class="relative w-full overflow-hidden bg-[#0E2A47] text-white border-b border-white/5">
  <div class="relative min-h-[600px] md:min-h-[660px] flex items-center">
    <div class="absolute inset-0 z-0">
      <picture>
        <source srcset={mobileImageSrc} media="(max-width: 768px)" />
        <img
          src={imageSrc}
          alt={imageAlt}
          class="absolute inset-0 h-full w-full object-cover object-center lg:object-[center_right]"
          loading="eager"
          fetchpriority="high"
          decoding="sync"
          width="1920"
          height="1080"
          sizes="100vw"
        />
      </picture>
    </div>

    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(8,24,49,0.92)_0%,rgba(14,42,71,0.72)_42%,rgba(14,42,71,0.28)_100%)] z-10"></div>

    <div class="relative mx-auto w-full max-w-[1680px] px-6 lg:px-10 xl:px-16 z-20">
      <div class="max-w-[640px] text-left lg:-translate-y-4 lg:-ml-[90px]">
        <h1 style="line-height: 1.5;" class="text-4xl lg:text-5xl 2xl:text-6xl font-extrabold tracking-tight text-white">
          {title}
        </h1>

        <p class="mt-8 text-base md:text-lg leading-7 text-white/90 max-w-[620px]">
          {description}
        </p>

        <div class="mt-10 flex flex-col gap-5 sm:flex-row">
          <a
            href={primaryAction.href}
            class="inline-flex items-center justify-center rounded-xl bg-[#C05800] px-10 py-4 text-[15px] font-bold text-white shadow-lg shadow-[#C05800]/20 transition hover:bg-[#9E4700]"
          >
            {primaryAction.label}
          </a>

          <a
            href={secondaryAction.href}
            class="inline-flex items-center justify-center rounded-xl border border-white/40 px-10 py-4 text-[15px] font-bold text-white transition hover:bg-white hover:text-[#0E2A47] backdrop-blur-sm"
          >
            {secondaryAction.label}
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="relative bg-[linear-gradient(90deg,#0E2A47_0%,#1F4E8C_100%)] border-t border-white/5 min-h-[100px] flex items-center">
    <dl class="mx-auto grid w-full max-w-[1680px] grid-cols-2 gap-px px-6 py-5 md:grid-cols-5 md:px-10 lg:px-16">
      {stats.map((item) => (
        <div class="border-white/10 px-3 py-2 text-center md:border-l first:md:border-l-0 flex flex-col-reverse justify-center">
          <dt class="mt-2 text-[10px] font-bold uppercase tracking-wider text-[#BFD0E4] md:text-xs">
            {item.label}
          </dt>
          <dd class="text-[28px] md:text-[32px] font-extrabold text-white leading-none">
            {item.value}
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>
