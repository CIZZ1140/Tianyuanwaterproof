---
import { stats as siteStats } from '../data/site';

type HeroAction = {
  label: string;
  href: string;
};

type HeroStat = {
  value: string;
  label: string;
};

type HeroProps = {
  imageSrc?: string;
  imageAlt?: string;
  title?: string;
  description?: string;
  primaryAction?: HeroAction;
  secondaryAction?: HeroAction;
  stats?: HeroStat[];
};

const {
  imageSrc = "https://img.tyuanwaterproof.com/banner.webp",
  imageAlt = "Professional waterproofing membrane installation on a modern roof",
  title = "Waterproofing Materials Supplier from China",
  description = "Factory supply of waterproofing membranes, tapes and coatings with OEM packaging, technical data support and fast quotation service.",
  primaryAction = {
    label: "REQUEST A QUOTE →",
    href: "/#categories",
  },
  secondaryAction = {
    label: "View Products",
    href: "/#categories",
  },
  stats = [
    { value: "30+", label: "Years Experience" },
    { value: "3", label: "Product Lines" },
    { value: "50+", label: "Countries Exported" },
    { value: "OEM/ODM", label: "Service" },
    { value: "24/7", label: "Quick Response" },
  ],
} = Astro.props as HeroProps;
---

<section class="relative w-full overflow-hidden bg-[#0E2A47] text-white">
  <div class="relative min-h-[520px] md:min-h-[560px] lg:min-h-[620px] flex items-center">
    <img
      src={imageSrc}
      alt={imageAlt}
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />

    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(5,17,36,0.92)_0%,rgba(14,42,71,0.60)_50%,rgba(14,42,71,0.20)_100%)]"></div>

    <div class="relative mx-auto w-full max-w-7xl px-4 md:px-6 lg:px-8">
      <div class="max-w-[600px] text-left">
        <h1 class="text-[38px] md:text-[56px] font-extrabold leading-[1.1] tracking-tight text-white uppercase">
          {title}
        </h1>

        <p class="mt-6 text-[17px] md:text-[18px] leading-[1.6] text-white/90">
          {description}
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a
            href={primaryAction.href}
            class="inline-flex items-center justify-center rounded-xl bg-[#F58A1F] px-10 py-4 text-[15px] font-bold text-white shadow-lg shadow-[#F58A1F]/20 transition hover:bg-[#E37812]"
          >
            {primaryAction.label}
          </a>

          <a
            href={secondaryAction.href}
            class="inline-flex items-center justify-center rounded-xl border border-white/60 px-10 py-4 text-[15px] font-bold text-white transition hover:bg-white hover:text-[#0E2A47] backdrop-blur-sm"
          >
            {secondaryAction.label}
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="relative bg-[linear-gradient(90deg,#0E2A47_0%,#1F4E8C_100%)] border-t border-white/10 min-h-[90px] flex items-center">
    <div class="mx-auto grid w-full max-w-7xl grid-cols-2 gap-px px-4 py-4 md:grid-cols-5 md:px-6 lg:px-8">
      {stats.map((item) => (
        <div class="border-white/10 px-3 py-2 text-center md:border-l first:md:border-l-0">
          <div class="text-[28px] md:text-[32px] font-extrabold text-white leading-none">
            {item.value}
          </div>
          <div class="mt-2 text-[10px] font-bold uppercase tracking-wider text-[#BFD0E4] md:text-xs">
            {item.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
