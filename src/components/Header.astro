---
import { nav, site } from '../data/site';

type NavLink = {
  label: string;
  href: string;
};

type HeaderProps = {
  logoSrc?: string;
  logoAlt?: string;
  brandName?: string;
  navLinks?: NavLink[];
  quoteHref?: string;
  quoteLabel?: string;
  languageLabel?: string;
};

const {
  logoSrc = "https://img.tyuanwaterproof.com/logo.png",
  logoAlt = `${site.shortName} Logo`,
  brandName = site.shortName,
  navLinks = nav,
  quoteHref = "/#categories",
  quoteLabel = "REQUEST A QUOTE",
  languageLabel = "EN",
} = Astro.props as HeaderProps;
---

<header class="relative w-full bg-[#0E2A47] text-white shadow-sm sticky top-0 z-50">
  <div class="mx-auto max-w-7xl px-4 md:px-6 lg:px-8">
    <div class="flex min-h-16 items-center justify-between gap-4 py-3">
      <a href="/" class="flex items-center gap-3">
        <img
          src={logoSrc}
          alt={logoAlt}
          class="h-10 w-10 object-contain"
        />
        <span class="text-base font-bold tracking-tight text-white md:text-lg">
          {brandName}
        </span>
      </a>

      <nav class="hidden items-center gap-7 lg:flex" aria-label="Main navigation">
        {navLinks.map((item) => (
          <a
            href={item.href}
            class="text-sm font-semibold text-white/85 transition hover:text-[#F58A1F]"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="hidden items-center gap-4 lg:flex">
        <span class="rounded-full border border-white/20 px-3 py-1 text-xs font-semibold text-white/80">
          {languageLabel}
        </span>

        <a
          href={quoteHref}
          class="rounded-xl bg-[#F58A1F] px-5 py-2.5 text-sm font-bold text-white shadow-sm transition hover:bg-[#E37812]"
        >
          {quoteLabel}
        </a>
      </div>

      <details class="group lg:hidden">
        <summary class="flex cursor-pointer list-none items-center gap-2 rounded-lg border border-white/20 px-3 py-2 text-sm font-semibold text-white [&::-webkit-details-marker]:hidden">
          Menu
          <span class="text-white/70 transition group-open:rotate-180 text-xs">▼</span>
        </summary>

        <nav class="absolute top-full right-4 mt-2 w-56 rounded-2xl border border-white/10 bg-[#0E2A47] p-3 shadow-xl z-50" aria-label="Mobile navigation">
          <div class="flex flex-col gap-1">
            {navLinks.map((item) => (
              <a
                href={item.href}
                class="rounded-lg px-3 py-2 text-sm font-semibold text-white/85 transition hover:bg-white/10 hover:text-[#F58A1F]"
              >
                {item.label}
              </a>
            ))}
          </div>

          <a
            href={quoteHref}
            class="mt-3 block rounded-xl bg-[#F58A1F] px-4 py-3 text-center text-sm font-bold text-white transition hover:bg-[#E37812]"
          >
            {quoteLabel}
          </a>
        </nav>
      </details>
    </div>
  </div>
</header>
