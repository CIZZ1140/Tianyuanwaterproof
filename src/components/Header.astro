---
type NavLink = {
  label: string;
  href: string;
};

type HeaderProps = {
  logoSrc?: string;
  logoAlt?: string;
  brandName?: string;
  navLinks?: NavLink[];
  quoteHref?: string;
  quoteLabel?: string;
  languageLabel?: string;
};

const defaultNavLinks: NavLink[] = [
  { label: "Home", href: "/" },
  { label: "Products", href: "/products" },
  { label: "Applications", href: "/applications" },
  { label: "Technical", href: "/technical" },
  { label: "Projects", href: "/projects" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];

const {
  logoSrc = "/images/logo.png",
  logoAlt = "Tianyuan Waterproof Logo",
  brandName = "Tianyuan Waterproof",
  navLinks = defaultNavLinks,
  quoteHref = "/contact",
  quoteLabel = "REQUEST A QUOTE →",
  languageLabel = "EN",
} = Astro.props as HeaderProps;
---

<header class="relative w-full bg-[#0E2A47] text-white shadow-sm">
  <div class="mx-auto grid min-h-[74px] max-w-[1600px] grid-cols-[auto_auto] items-center gap-4 px-5 md:px-8 lg:grid-cols-[320px_minmax(0,1fr)_320px] lg:px-10 xl:px-14">
    <a href="/" class="flex shrink-0 items-center gap-3">
      <img
        src={logoSrc}
        alt={logoAlt}
        class="h-10 w-10 rounded-full bg-white object-contain p-1"
      />

      <span class="text-[18px] font-extrabold tracking-tight text-white">
        {brandName}
      </span>
    </a>

    <nav
      class="hidden items-center justify-center gap-8 lg:flex xl:gap-10"
      aria-label="Main navigation"
    >
      {navLinks.map((item) => (
        <a
          href={item.href}
          class="text-[15px] font-bold text-white/85 transition hover:text-[#F58A1F]"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center justify-end gap-4 lg:flex">
      <span class="rounded-full border border-white/20 px-3.5 py-1.5 text-xs font-bold text-white/85">
        {languageLabel}
      </span>

      <a
        href={quoteHref}
        class="rounded-xl bg-[#F58A1F] px-6 py-3 text-sm font-extrabold text-white shadow-sm transition hover:bg-[#E37812]"
      >
        {quoteLabel}
      </a>
    </div>

    <details class="group relative justify-self-end lg:hidden">
      <summary class="flex cursor-pointer list-none items-center gap-2 rounded-lg border border-white/20 px-3 py-2 text-sm font-bold text-white [&::-webkit-details-marker]:hidden">
        Menu
        <span class="text-white/70 transition group-open:rotate-180">⌄</span>
      </summary>

      <nav
        class="absolute right-0 mt-3 w-64 rounded-2xl border border-white/10 bg-[#0E2A47] p-4 shadow-xl"
        aria-label="Mobile navigation"
      >
        <div class="flex flex-col gap-1">
          {navLinks.map((item) => (
            <a
              href={item.href}
              class="rounded-lg px-3 py-2 text-sm font-bold text-white/85 transition hover:bg-white/10 hover:text-[#F58A1F]"
            >
              {item.label}
            </a>
          ))}
        </div>

        <a
          href={quoteHref}
          class="mt-4 block rounded-xl bg-[#F58A1F] px-4 py-3 text-center text-sm font-extrabold text-white transition hover:bg-[#E37812]"
        >
          {quoteLabel}
        </a>
      </nav>
    </details>
  </div>
</header>
