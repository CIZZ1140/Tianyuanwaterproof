---
import Layout from '@/layouts/Layout.astro';
import CTA from '@/components/CTA.astro';
---
<Layout title="About Us | Waterproofing Materials Manufacturer">
  <section class="bg-navy py-16 text-white"><div class="container-wrap"><p class="eyebrow">About us</p><h1 class="mt-3 text-4xl font-black text-white md:text-5xl">B2B waterproofing materials supplier</h1><p class="mt-5 max-w-3xl text-white/70">Weifang Tianyuan is a leading manufacturer of premium bitumen membranes and high-polymer waterproofing materials, dedicated to providing durable solutions for global construction infrastructure.</p></div></section>
  <section class="py-16"><div class="container-wrap grid gap-6 md:grid-cols-3">{[
    { title: 'Factory Supply', desc: 'Direct-from-factory wholesale pricing with a production capacity of over 10 million square meters annually.' },
    { title: 'Quality Control', desc: 'Rigorous testing protocols and ISO-certified manufacturing ensure consistent material performance and durability.' },
    { title: 'OEM / ODM', desc: 'Customized private label options, specialized roll sizes, and technical packaging tailored to international markets.' }
  ].map((item) => <div class="card"><h2 class="text-2xl font-bold">{item.title}</h2><p class="mt-3 text-sm leading-6 text-slate-600">{item.desc}</p></div>)}</div></section>

  <section class="py-16 bg-slate-100/50">
    <div class="container-wrap">
      <div class="mb-12 text-center">
        <h2 class="section-title">Our Certifications</h2>
        <p class="section-copy mx-auto">We maintain the highest standards of quality and safety in our manufacturing process, ensuring our waterproofing materials meet international requirements.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { name: 'ISO 9001 Quality Management', placeholder: 'ISO 9001' },
          { name: 'CE Certification', placeholder: 'CE Mark' },
          { name: 'ISO 14001 Environmental', placeholder: 'ISO 14001' },
          { name: 'ASTM Standards Compliance', placeholder: 'ASTM' }
        ].map((cert) => (
          <div class="card flex flex-col items-center text-center">
            <div class="aspect-[3/4] w-full bg-slate-200 rounded-2xl mb-4 flex items-center justify-center text-slate-400 font-bold border-2 border-dashed border-slate-300">
              <span class="text-xs uppercase tracking-widest">{cert.placeholder}</span>
            </div>
            <h3 class="font-bold text-slate-900 leading-tight">{cert.name}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</Layout>
