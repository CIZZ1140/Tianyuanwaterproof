---
import Layout from '../layouts/Layout.astro';
import {
  ArrowRight,
  BookOpenCheck,
  Boxes,
  Building2,
  CheckCircle2,
  ClipboardCheck,
  Factory,
  FileCheck2,
  FileText,
  FlaskConical,
  Activity,
  Globe2,
  Layers,
  Mail,
  MapPin,
  PackageCheck,
  PackageOpen,
  Phone,
  Ruler,
  Send,
  Settings2,
  ShieldCheck,
  Truck,
  Users,
  Warehouse
} from 'lucide-astro';

const pageTitle = 'About Tianyuan Waterproof | Waterproofing Materials Manufacturer';
const pageDescription = 'Learn about Tianyuan Waterproof’s manufacturing capability, waterproofing product systems, quality control, technical documentation, export packing and OEM support for global B2B buyers.';

const hero = {
  eyebrow: 'ABOUT TIANYUAN WATERPROOF',
  title: 'Waterproofing Materials Manufacturer for Global B2B Supply',
  description: 'Tianyuan Waterproof manufactures waterproofing membranes, coatings, tapes, asphalt shingles and related construction materials for distributors, contractors and project procurement teams.',
  supportText: 'Based in Weifang, Shandong Province, China, we support product selection, technical documentation, export packing, OEM orders and factory quotation for global projects.',
  image: 'https://img.tyuanwaterproof.com/factory-main.webp',
  imageAlt: 'Tianyuan Waterproof manufacturing factory in Weifang, Shandong, China',
  primaryCta: { label: 'View Our Products', href: '/products/' },
  secondaryCta: { label: 'Contact Technical Sales', href: '/contact/' }
};

const stats = [
  { value: '30+', label: 'Years Experience', description: 'Deep roots in waterproofing manufacturing since the 1990s.' },
  { value: '5', label: 'Production Lines', description: 'Advanced automation for stable membrane and coating supply.' },
  { value: '50+', label: 'Countries Exported', description: 'Trusted by B2B buyers across Southeast Asia, Middle East and Africa.' },
  { value: 'OEM/ODM', label: 'Service Available', description: 'Professional private-label and customized export packing support.' }
] as const;

const companyOverview = {
  eyebrow: 'COMPANY OVERVIEW',
  title: 'A Manufacturing Partner Built Around Long-Term Supply',
  paragraphs: [
    'Tianyuan Waterproof is a specialized manufacturer and supplier of waterproofing materials for construction, infrastructure and industrial applications.',
    'Our portfolio includes bitumen waterproofing membranes, polymer membranes, liquid coatings, sealing tapes and geosynthetic materials.',
    'We work with regional distributors and project procurement teams that require stable production, clear technical specifications and practical logistics coordination.',
    'B2B support covers product configuration, export documentation, OEM branding and destination-port quotation (CIF/FOB).'
  ],
  image: 'https://img.tyuanwaterproof.com/factory-main.webp?v=2',
  imageAlt: 'Tianyuan Waterproof production facility and material warehouse'
};

const companyHighlights = [
  { title: 'China Supply Base', description: 'Located in Shandong Province, at the heart of China’s waterproofing industrial cluster.', Icon: MapPin },
  { title: 'B2B Project Service', description: 'Dedicated support for distributors, contractors and infrastructure project teams.', Icon: Users },
  { title: 'Technical Coordination', description: 'In-depth specification review, TDS preparation and laboratory testing support.', Icon: FileCheck2 }
] as const;

const productSystems = [
  {
    title: 'Bitumen Membranes',
    description: 'SBS, APP and self-adhesive bituminous membranes for roofing and basement systems.',
    image: 'https://img.tyuanwaterproof.com/cat-bitumen-membranes.webp',
    href: '/categories/bitumen-membranes/',
    products: ['SBS Modified Bitumen', 'APP Modified Bitumen', 'Self-Adhesive Bitumen']
  },
  {
    title: 'Polymer Membranes',
    description: 'PVC, TPO and HDPE sheet membranes for exposed roofing, tunnels and infrastructure.',
    image: 'https://img.tyuanwaterproof.com/cat-polymer-membranes.webp',
    href: '/categories/polymer-membranes/',
    products: ['TPO Roofing Membrane', 'PVC Tunnel Membrane', 'HDPE Pre-Applied']
  },
  {
    title: 'Waterproof Coatings',
    description: 'Liquid-applied materials for basements, balconies and specialized concrete structures.',
    image: 'https://img.tyuanwaterproof.com/cat-waterproof-coatings-v2.webp',
    href: '/categories/waterproof-coatings/',
    products: ['Polyurethane Coating', 'Acrylic Waterproofing', 'Cementitious Coating']
  }
] as const;

const factoryCapabilities = [
  { title: 'Production Line Coordination', description: 'Manufacturing arrangements for bulk orders of membranes, coatings and sealing materials.', Icon: Factory },
  { title: 'Specification Control', description: 'Production based on confirmed thickness, reinforcement (PY/PYG) and surface requirements.', Icon: Activity },
  { title: 'Bulk Order Management', description: 'Batch planning, warehouse coordination and repeat-order supply for project buyers.', Icon: Warehouse },
  { title: 'Export Packing', description: 'Roll wrapping, palletization, strapping and container loading coordination for overseas shipment.', Icon: PackageCheck }
] as const;

const qualitySteps = [
  { number: '01', title: 'Raw Material Inspection', description: 'Bitumen modifiers, reinforcement carriers and surface materials are checked before production.', Icon: ClipboardCheck },
  { number: '02', title: 'Parameter Control', description: 'Temperature, coating consistency and production speed are monitored continuously.', Icon: Settings2 },
  { number: '03', title: 'Dimension Check', description: 'Membrane thickness, roll width, weight and surface condition are inspected strictly.', Icon: Ruler },
  { number: '04', title: 'Performance Testing', description: 'Tensile, elongation and low-temperature flexibility tested in our standard laboratory.', Icon: FlaskConical },
  { number: '05', title: 'Final Inspection', description: 'Labels, wrapping, pallet condition and shipment markings checked before dispatch.', Icon: PackageCheck }
] as const;

const technicalDocuments = [
  { title: 'Technical Data Sheets', description: 'Product-specific material structure and performance information for project evaluation.', actionLabel: 'Request TDS', Icon: FileText },
  { title: 'Selected Test Reports', description: 'Available test documentation discussed according to product and project requirements.', actionLabel: 'Request Reports', Icon: ShieldCheck },
  { title: 'Installation Guidance', description: 'Application and installation references for selected membrane and coating systems.', actionLabel: 'View Resources', Icon: BookOpenCheck },
  { title: 'Export Documents', description: 'Support for packing lists, commercial invoices and relevant shipment documentation.', actionLabel: 'Discuss Docs', Icon: Truck }
] as const;

const siteOrigin = (Astro.site ?? new URL('https://www.tyuanwaterproof.com')).toString().replace(/\/$/, '');
const aboutPageUrl = `${siteOrigin}/about/`;

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'AboutPage',
      '@id': `${aboutPageUrl}#webpage`,
      url: aboutPageUrl,
      name: pageTitle,
      description: pageDescription,
      inLanguage: 'en',
      about: { '@id': `${siteOrigin}/#organization` }
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(aboutPageSchema)} />

  <main class="overflow-hidden bg-white text-slate-600 font-sans">
    <!-- 1. Hero -->
    <section class="relative isolate min-h-[580px] overflow-hidden bg-[#0E2A47]">
      <img
        src={hero.image}
        alt={hero.imageAlt}
        width="1920"
        height="1080"
        loading="eager"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-[#07192B]/80"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#07192B] via-[#07192B]/85 to-transparent"></div>

      <div class="relative mx-auto flex min-h-[580px] max-w-[1680px] flex-col px-4 pb-16 pt-7 sm:px-6 lg:px-8">
        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm font-medium text-white/60">
          <a href="/" class="transition hover:text-white uppercase tracking-wider">Home</a>
          <span aria-hidden="true">/</span>
          <span class="text-white uppercase tracking-wider">About Us</span>
        </nav>

        <div class="my-auto max-w-5xl py-12 lg:py-16">
          <div class="mb-6 flex items-center gap-3">
            <span class="h-px w-12 bg-[#F58A1F]"></span>
            <p class="text-sm font-bold uppercase tracking-[0.22em] text-[#F6A956]">{hero.eyebrow}</p>
          </div>
          <h1 style="line-height: 1.5;" class="text-4xl font-black tracking-tight text-white sm:text-5xl lg:text-6xl">{hero.title}</h1>
          <p class="mt-7 max-w-3xl text-base leading-8 text-slate-200 sm:text-lg">{hero.description}</p>
          <p class="mt-3 max-w-3xl text-base leading-8 text-slate-400">{hero.supportText}</p>
          <div class="mt-9 flex flex-col gap-4 sm:flex-row">
            <a href={hero.primaryCta.href} class="inline-flex items-center justify-center gap-2 rounded-lg bg-[#F58A1F] px-8 py-4 text-sm font-bold text-white transition hover:bg-[#E77911] shadow-lg shadow-orange-950/20">
              {hero.primaryCta.label} <ArrowRight size={18} strokeWidth={2} />
            </a>
            <a href={hero.secondaryCta.href} class="inline-flex items-center justify-center gap-2 rounded-lg border border-white/25 bg-white/5 px-8 py-4 text-sm font-bold text-white backdrop-blur-sm transition hover:bg-white/10">
              <Mail size={18} strokeWidth={1.9} /> {hero.secondaryCta.label}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. Statistics -->
    <section class="border-b border-slate-100 bg-white">
      <div class="mx-auto max-w-[1680px] px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 lg:grid-cols-4">
          {stats.map((stat, index) => (
            <div class={`relative py-10 lg:px-8 ${index > 0 ? 'lg:border-l border-slate-100' : ''} ${index >= 2 ? 'border-t border-slate-100 lg:border-t-0' : ''}`}>
              <p class="text-3xl font-black tracking-tight text-[#0E2A47] sm:text-4xl">{stat.value}</p>
              <p class="mt-2 text-sm font-bold text-slate-800 uppercase tracking-wide">{stat.label}</p>
              <p class="mt-2 text-xs leading-5 text-slate-500 max-w-[200px]">{stat.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 3. Company Overview -->
    <section class="bg-white px-4 py-20 lg:py-28">
      <div class="mx-auto max-w-[1680px]">
        <div class="grid gap-16 lg:grid-cols-2 lg:items-center">
          <div class="relative order-2 lg:order-1">
            <div class="overflow-hidden rounded-2xl bg-slate-100 shadow-2xl">
              <img src={companyOverview.image} alt={companyOverview.imageAlt} width="1100" height="900" loading="lazy" class="aspect-[5/4] h-full w-full object-cover" />
            </div>
            <div class="mt-6 grid grid-cols-2 gap-4 sm:absolute sm:-bottom-6 sm:right-6 sm:mt-0 sm:w-[80%]">
              <div class="rounded-xl border border-slate-100 bg-white p-6 shadow-xl">
                <Factory size={24} class="text-[#F58A1F]" />
                <p class="mt-4 text-sm font-bold text-[#0E2A47]">Factory Production</p>
                <p class="mt-1 text-xs text-slate-500">Stability & Coordination</p>
              </div>
              <div class="rounded-xl border border-slate-100 bg-white p-6 shadow-xl">
                <Globe2 size={24} class="text-[#F58A1F]" />
                <p class="mt-4 text-sm font-bold text-[#0E2A47]">Export Excellence</p>
                <p class="mt-1 text-xs text-slate-500">Global Supply Chain</p>
              </div>
            </div>
          </div>
          <div class="lg:pl-8 order-1 lg:order-2">
            <div class="flex items-center gap-3">
              <span class="h-0.5 w-10 bg-[#F58A1F]"></span>
              <p class="text-sm font-bold uppercase tracking-[0.2em] text-[#F58A1F]">{companyOverview.eyebrow}</p>
            </div>
            <h2 class="mt-5 text-3xl font-black text-[#0E2A47] sm:text-4xl lg:text-5xl">{companyOverview.title}</h2>
            <div class="mt-8 space-y-5">
              {companyOverview.paragraphs.map((p) => <p class="text-base leading-8 text-slate-600">{p}</p>)}
            </div>
            <div class="mt-10 divide-y divide-slate-100 border-y border-slate-100">
              {companyHighlights.map(({ title, description, Icon }) => (
                <div class="flex gap-5 py-6">
                  <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-orange-50 text-[#F58A1F]">
                    <Icon size={20} strokeWidth={2} />
                  </div>
                  <div>
                    <h3 class="text-base font-black text-[#0E2A47]">{title}</h3>
                    <p class="mt-1 text-sm leading-6 text-slate-500">{description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. Manufacturing Portfolio -->
    <section class="bg-slate-50 px-4 py-20 lg:py-28">
      <div class="mx-auto max-w-[1680px]">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <div class="flex items-center justify-center gap-3">
            <span class="h-0.5 w-8 bg-[#F58A1F]"></span>
            <p class="text-sm font-bold uppercase tracking-[0.2em] text-[#F58A1F]">MANUFACTURING SCOPE</p>
            <span class="h-0.5 w-8 bg-[#F58A1F]"></span>
          </div>
          <h2 class="mt-5 text-3xl font-black text-[#0E2A47] sm:text-4xl lg:text-5xl">Professional Material Synthesis</h2>
          <p class="mt-5 text-base leading-7 text-slate-600">Focusing on high-performance synthesis for global infrastructure projects.</p>
        </div>

        <div class="grid gap-8 md:grid-cols-3">
          {productSystems.map((system) => (
            <a href={system.href} class="bg-white border border-slate-200 rounded-3xl overflow-hidden hover:shadow-2xl transition-all duration-300 group cursor-pointer block">
              <div class="aspect-[16/9] overflow-hidden">
                <img src={system.image} alt={system.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              </div>
              <div class="p-8">
                <h3 class="text-xl font-black text-[#0E2A47] uppercase tracking-tight group-hover:text-[#F58A1F] transition-colors">{system.title}</h3>
                <p class="mt-3 text-sm leading-6 text-slate-500">{system.description}</p>
                <div class="mt-6 pt-6 border-t border-slate-50">
                   <ul class="flex flex-wrap gap-2">
                     {system.products.map(p => <li class="text-[11px] font-bold bg-slate-50 text-slate-600 px-2.5 py-1 rounded-full border border-slate-100">{p}</li>)}
                   </ul>
                </div>
              </div>
            </a>
          ))}
        </div>
        <div class="mt-12 text-center">
           <a href="/products/" class="inline-flex items-center gap-2 text-sm font-black text-[#0E2A47] border-b-2 border-[#F58A1F] pb-1 hover:text-[#F58A1F] transition-colors">
             View Full Product Catalog <ArrowRight size={16} />
           </a>
        </div>
      </div>
    </section>

    <!-- 5. Quality Control (FIXED READABILITY) -->
    <section class="bg-[#0E2A47] py-20 text-white lg:py-28">
      <div class="mx-auto max-w-[1680px] px-4 sm:px-6 lg:px-8">
        <div class="grid gap-16 lg:grid-cols-[0.8fr_1.2fr]">
          <div>
            <div class="flex items-center gap-3">
              <span class="h-0.5 w-10 bg-[#F58A1F]"></span>
              <p class="text-sm font-bold uppercase tracking-[0.2em] text-[#F58A1F]">QUALITY CONTROL</p>
            </div>
            <h2 class="mt-5 text-3xl font-black text-white md:text-5xl leading-tight">Inspection Organized for Every Shipment</h2>
            <p class="mt-7 text-lg text-slate-200 leading-relaxed">Stable thickness, weight, tensile performance and low-temperature flexibility are our non-negotiable standards.</p>
            <div class="mt-10 p-8 rounded-2xl bg-white/5 border border-white/10">
              <p class="text-sm font-bold text-[#F58A1F] uppercase tracking-widest">Laboratory Standard</p>
              <p class="mt-3 text-sm text-slate-200 leading-7">We maintain an on-site laboratory for batch testing. All technical documents (TDS/MSDS) are generated based on actual performance data.</p>
            </div>
          </div>
          <div class="space-y-4">
            {qualitySteps.map((step) => (
              <div class="bg-white/5 border border-white/10 rounded-2xl p-6 flex gap-6 hover:bg-white/10 transition-colors">
                <span class="text-2xl font-black text-[#F58A1F] opacity-80">{step.number}</span>
                <div>
                  <h3 class="text-lg font-black text-white">{step.title}</h3>
                  <p class="mt-2 text-sm text-slate-300 leading-6">{step.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- 6. Certifications -->
    <section id="certifications" class="bg-white px-4 py-20 lg:py-28 overflow-hidden">
      <div class="mx-auto max-w-[1280px]">
        <!-- Header -->
        <div class="text-center mb-16 relative">
          <span class="inline-block rounded-full border border-[#F58A1F]/20 bg-[#F58A1F]/5 px-5 py-1.5 text-xs font-bold text-[#F58A1F] uppercase tracking-[0.15em]">Professional Certifications</span>
          <div class="relative mt-6">
            <h2 class="absolute inset-0 flex items-center justify-center text-6xl sm:text-7xl lg:text-8xl font-black text-slate-100 pointer-events-none select-none tracking-tight leading-none">CERTIFICATIONS</h2>
            <h2 class="relative text-3xl font-black text-[#0E2A47] sm:text-4xl lg:text-5xl pt-[0.6em]">Our Certifications</h2>
          </div>
          <p class="mt-5 text-base leading-7 text-slate-500 max-w-xl mx-auto">Third-party tested and certified to meet EU regulatory standards.</p>
        </div>

        <!-- Certificate Cards — Fan Layout -->
        <div class="grid grid-cols-2 gap-5 sm:gap-6 lg:flex lg:justify-center lg:items-start lg:gap-0 lg:pt-4 lg:pb-4">
          <!-- Card 1: ISO 9001:2015 -->
          <div class="relative rounded-2xl bg-white border border-slate-200 shadow-lg lg:max-w-[210px] lg:-rotate-[10deg] lg:z-0 lg:hover:rotate-0 lg:hover:z-30 lg:hover:scale-110 transition-all duration-400">
            <div class="p-3 sm:p-4 bg-[#F8F9FA] rounded-t-2xl border-b border-slate-100">
              <img
                src="https://img.tyuanwaterproof.com/certs/iso-9001-2015-en.jpg"
                alt="ISO 9001:2015 Quality Management System Certificate"
                width="748"
                height="956"
                loading="lazy"
                class="w-full object-contain rounded-lg"
              />
            </div>
            <div class="px-3 py-3 sm:px-4 sm:py-4 text-center">
              <h3 class="text-sm font-black text-[#0E2A47] leading-tight">ISO 9001:2015</h3>
              <p class="mt-1 text-[11px] text-slate-400">Quality Management</p>
            </div>
          </div>

          <!-- Card 2: ISO 14001:2015 -->
          <div class="relative rounded-2xl bg-white border border-slate-200 shadow-lg lg:max-w-[210px] lg:-rotate-[5deg] lg:-ml-6 lg:z-10 lg:hover:rotate-0 lg:hover:z-30 lg:hover:scale-110 transition-all duration-400">
            <div class="p-3 sm:p-4 bg-[#F8F9FA] rounded-t-2xl border-b border-slate-100">
              <img
                src="https://img.tyuanwaterproof.com/certs/iso-14001-2015.jpg"
                alt="ISO 14001:2015 Environmental Management System Certificate"
                width="748"
                height="956"
                loading="lazy"
                class="w-full object-contain rounded-lg"
              />
            </div>
            <div class="px-3 py-3 sm:px-4 sm:py-4 text-center">
              <h3 class="text-sm font-black text-[#0E2A47] leading-tight">ISO 14001:2015</h3>
              <p class="mt-1 text-[11px] text-slate-400">Environmental Management</p>
            </div>
          </div>

          <!-- Card 3: ISO 45001:2018 -->
          <div class="relative rounded-2xl bg-white border border-slate-200 shadow-lg lg:max-w-[210px] lg:-ml-6 lg:z-20 lg:hover:rotate-0 lg:hover:z-30 lg:hover:scale-110 transition-all duration-400">
            <div class="p-3 sm:p-4 bg-[#F8F9FA] rounded-t-2xl border-b border-slate-100">
              <img
                src="https://img.tyuanwaterproof.com/certs/iso-45001-2018.jpg"
                alt="ISO 45001:2018 Occupational Health and Safety Management System Certificate"
                width="748"
                height="956"
                loading="lazy"
                class="w-full object-contain rounded-lg"
              />
            </div>
            <div class="px-3 py-3 sm:px-4 sm:py-4 text-center">
              <h3 class="text-sm font-black text-[#0E2A47] leading-tight">ISO 45001:2018</h3>
              <p class="mt-1 text-[11px] text-slate-400">Occupational Health & Safety</p>
            </div>
          </div>

          <!-- Card 4: CE RoHS Membrane -->
          <div class="relative rounded-2xl bg-white border border-slate-200 shadow-lg lg:max-w-[210px] lg:rotate-[4deg] lg:-ml-6 lg:z-10 lg:hover:rotate-0 lg:hover:z-30 lg:hover:scale-110 transition-all duration-400">
            <div class="p-3 sm:p-4 bg-[#F8F9FA] rounded-t-2xl border-b border-slate-100">
              <img
                src="https://img.tyuanwaterproof.com/certs/ce-rohs-membrane.jpg"
                alt="CE RoHS Certificate — Waterproof Membrane"
                width="1200"
                height="848"
                loading="lazy"
                class="w-full object-contain rounded-lg"
              />
            </div>
            <div class="px-3 py-3 sm:px-4 sm:py-4 text-center">
              <h3 class="text-sm font-black text-[#0E2A47] leading-tight">CE RoHS</h3>
              <p class="mt-1 text-[11px] text-slate-400">Waterproof Membrane</p>
            </div>
          </div>

          <!-- Card 5: CE RoHS Coating -->
          <div class="relative rounded-2xl bg-white border border-slate-200 shadow-lg lg:max-w-[210px] lg:rotate-[9deg] lg:-ml-6 lg:z-0 lg:hover:rotate-0 lg:hover:z-30 lg:hover:scale-110 transition-all duration-400 col-span-2 lg:col-span-1 mx-auto lg:mx-0 max-w-[280px] lg:max-w-[210px]">
            <div class="p-3 sm:p-4 bg-[#F8F9FA] rounded-t-2xl border-b border-slate-100">
              <img
                src="https://sc02.alicdn.com/kf/H12cbac410e914fa98d17c9cd95a0cf55B.jpg"
                alt="CE RoHS Certificate — Waterproof Coating"
                width="1200"
                height="848"
                loading="lazy"
                class="w-full object-contain rounded-lg"
              />
            </div>
            <div class="px-3 py-3 sm:px-4 sm:py-4 text-center">
              <h3 class="text-sm font-black text-[#0E2A47] leading-tight">CE RoHS</h3>
              <p class="mt-1 text-[11px] text-slate-400">Waterproof Coating</p>
            </div>
          </div>
        </div>

        <div class="mt-14 text-center">
          <a href="/contact/" class="inline-flex items-center justify-center gap-2 rounded-xl bg-[#0E2A47] px-8 py-4 text-sm font-bold text-white transition hover:bg-[#152E4A] shadow-lg shadow-[#0E2A47]/10">
            Request Full Test Reports <ArrowRight size={16} />
          </a>
        </div>
      </div>
    </section>

    <!-- 7. Technical Documents -->
    <section class="bg-white px-4 py-20 lg:py-28">
      <div class="mx-auto max-w-[1680px]">
        <div class="flex flex-col lg:flex-row gap-12 lg:items-center">
          <div class="lg:w-1/2">
            <p class="text-sm font-bold text-[#F58A1F] uppercase tracking-[0.2em] mb-4">TECHNICAL SUPPORT</p>
            <h2 class="text-3xl lg:text-5xl font-black text-[#0E2A47] leading-tight tracking-tight">Full Documentation for Project Evaluation</h2>
            <p class="mt-6 text-base leading-8 text-slate-600">We coordinate all necessary technical, testing and shipment documents to help you reduce engineering approval time.</p>
            <div class="mt-10 flex flex-wrap gap-4">
               {['TDS Support', 'Test Reports', 'Export Documents', 'OEM Packing'].map(tag => <span class="px-4 py-2 bg-slate-50 border border-slate-100 text-slate-700 text-xs font-bold rounded-lg">{tag}</span>)}
            </div>
          </div>
