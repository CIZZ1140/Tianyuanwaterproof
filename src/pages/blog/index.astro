---
import { getCollection } from 'astro:content';
import { ArrowRight, BookOpen, Building2, FileText, Layers3 } from 'lucide-astro';

import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';
import BlogCard from '../../components/BlogCard.astro';

const PAGE_SIZE = 6;

const pageTitle = 'Blog | Waterproofing Insights & Guides | Tianyuan Waterproof';
const pageDescription =
  'Explore waterproofing product guides, roofing and basement system insights, installation knowledge, coating solutions and B2B sourcing guidance from Tianyuan Waterproof.';

const allArticles = await getCollection('blog', ({ data }) => !data.draft);
const articles = [...allArticles].sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const firstPageArticles = articles.slice(0, PAGE_SIZE);
const totalPages = Math.ceil(articles.length / PAGE_SIZE);
const featuredArticle = articles[0];

const topicCards = [
  { title: 'Roofing Systems', description: 'Guides for flat roofs, exposed roof membranes, mineral granule finishes and hot-climate waterproofing.', href: '/blog/', Icon: Building2 },
  { title: 'Basement & Foundation', description: 'Selection guidance for underground waterproofing, basement membranes and foundation protection systems.', href: '/blog/', Icon: Layers3 },
  { title: 'Product Guides', description: 'Compare SBS, APP, self-adhesive membranes, polymer membranes, coatings and waterproofing accessories.', href: '/blog/', Icon: BookOpen },
  { title: 'Technical Resources', description: 'Installation, membrane thickness, reinforcement, surface finish and project RFQ preparation guidance.', href: '/technical/', Icon: FileText }
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  preloadImage={featuredArticle?.data.coverImage}
>
  <main class="bg-[#F5F7FA] text-[#102033]">
    <section class="bg-[#0E2A47] px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <div class="mx-auto max-w-[1680px]">
        <nav aria-label="Breadcrumb" class="mb-8 flex flex-wrap items-center gap-2 text-sm font-medium text-slate-300">
          <a href="/" class="transition hover:text-white">Home</a>
          <span>/</span>
          <span class="text-white">Blog</span>
        </nav>

        <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
          <div>
            <p class="text-sm font-bold uppercase tracking-[0.22em] text-orange-300">Tianyuan Waterproof Blog</p>
            <h1 class="mt-4 max-w-4xl text-4xl font-black leading-tight text-white sm:text-5xl lg:text-6xl">
              Industry Insights & Technical Guides
            </h1>
            <p class="mt-6 max-w-3xl text-base leading-7 text-slate-200 sm:text-lg">
              Practical waterproofing knowledge for contractors, distributors,
              project teams and B2B buyers. Explore membrane selection,
              application systems, installation guidance and factory sourcing insights.
            </p>
            <a
              href="#latest-articles"
              class="mt-8 inline-flex items-center gap-2 rounded-xl bg-[#F58A1F] px-5 py-3 text-sm font-bold text-white transition hover:bg-orange-500"
            >
              Explore Latest Articles
              <ArrowRight size={18} strokeWidth={2} />
            </a>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            {topicCards.map(({ title, description, href, Icon }) => (
              <a
                href={href}
                class="rounded-2xl border border-white/15 bg-white/10 p-5 backdrop-blur transition hover:border-orange-300 hover:bg-white/15"
              >
                <Icon size={22} class="text-orange-300" strokeWidth={1.9} />
                <h2 class="mt-4 text-lg font-black text-white">{title}</h2>
                <p class="mt-2 text-sm leading-6 text-slate-300">{description}</p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="latest-articles" class="scroll-mt-24 px-4 py-8 sm:px-6 lg:px-8 lg:py-12">
      <div class="mx-auto max-w-[1680px]">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-bold uppercase tracking-[0.18em] text-brand">Latest Articles</p>
            <h2 class="mt-2 text-3xl font-black text-[#102033] sm:text-4xl">Waterproofing Insights for B2B Buyers</h2>
          </div>
          <p class="text-sm font-medium text-slate-500">
            {articles.length} article{articles.length === 1 ? '' : 's'} published
          </p>
        </div>

        {
          firstPageArticles.length > 0 ? (
            <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
              {firstPageArticles.map((article) => <BlogCard post={article} />)}
            </div>
          ) : (
            <div class="mt-8 rounded-2xl border border-dashed border-slate-300 bg-white px-6 py-16 text-center">
              <p class="text-xl font-black text-[#102033]">No blog articles have been published yet.</p>
              <p class="mt-3 text-sm text-slate-600">
                Add Markdown files under <code class="font-bold">src/content/blog/</code>.
              </p>
            </div>
          )
        }

        {
          totalPages > 1 && (
            <nav aria-label="Blog pagination" class="mt-10 flex flex-wrap items-center justify-center gap-2">
              {Array.from({ length: totalPages }, (_, i) => i + 1).map((n) => (
                <a
                  href={n === 1 ? '/blog/' : `/blog/page/${n}/`}
                  aria-current={n === 1 ? 'page' : undefined}
                  class={`flex h-10 min-w-10 items-center justify-center rounded-xl border px-3 text-sm font-bold transition ${
                    n === 1
                      ? 'border-brand bg-brand text-white'
                      : 'border-slate-200 bg-white text-slate-600 hover:border-brand hover:text-brand'
                  }`}
                >
                  {n}
                </a>
              ))}
            </nav>
          )
        }
      </div>
    </section>

    <section class="px-4 pb-4 pt-2 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-[1680px]">
        <div class="rounded-3xl border border-orange-100 bg-orange-50 p-6 sm:p-8 lg:p-10">
          <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
            <div>
              <p class="text-sm font-bold uppercase tracking-[0.18em] text-[#F58A1F]">Technical Documentation</p>
              <h2 class="mt-3 text-3xl font-black text-[#102033]">Need Product-Specific Waterproofing Documentation?</h2>
              <p class="mt-4 max-w-3xl text-base leading-7 text-slate-600">
                Request technical data sheets, installation guidance, selected test reports,
                export packing details and product configuration support for your project or distributor inquiry.
              </p>
            </div>
            <a
              href="/technical/"
              class="inline-flex items-center justify-center gap-2 rounded-xl bg-[#0E2A47] px-5 py-3 text-sm font-bold text-white transition hover:bg-navy"
            >
              Browse Resources
              <ArrowRight size={18} strokeWidth={2} />
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 pb-8 pt-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-[1680px]">
        <CTA />
      </div>
    </section>
  </main>
</Layout>
