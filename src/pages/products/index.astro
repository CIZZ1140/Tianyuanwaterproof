---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';

const categories = [
  {
    id: "asphalt-membranes",
    name: "Asphalt Membranes",
    desc: "Premium modified bitumen and self-adhesive waterproofing membranes.",
    image: "https://sc04.alicdn.com/kf/Hfe087a70867f43a8bd7c11db0b7f9e20T.png_960x960q80.jpg"
  },
  {
    id: "asphalt-shingles",
    name: "Asphalt Shingles",
    desc: "Lightweight, flexible, and extremely durable roofing shingles.",
    image: "https://sc04.alicdn.com/kf/H7e087a70867f43a8bd7c11db0b7f9e20T.jpg"
  },
  {
    id: "waterproof-tapes",
    name: "Waterproof Tapes",
    desc: "High-adhesion butyl sealant tapes and aluminum flashing tapes.",
    image: "https://sc04.alicdn.com/kf/Hfe087a70867f43a8bd7c11db0b7f9e20T.png_960x960q80.jpg"
  },
  {
    id: "waterproof-coatings",
    name: "Waterproof Coatings",
    desc: "Liquid-applied high-elasticity waterproof coatings.",
    image: "https://sc01.alicdn.com/kf/Hdb438925582c4ac683687a185028b305u.png"
  },
  {
    id: "geosynthetics",
    name: "Geosynthetics",
    desc: "High-strength geomembranes and drainage geogrids.",
    image: "https://sc04.alicdn.com/kf/Hfe087a70867f43a8bd7c11db0b7f9e20T.png_960x960q80.jpg"
  },
  {
    id: "polymer-membranes",
    name: "Polymer Membranes",
    desc: "Advanced EPDM, TPO, PVC, and HDPE membranes.",
    image: "https://sc04.alicdn.com/kf/Hfe087a70867f43a8bd7c11db0b7f9e20T.png_960x960q80.jpg"
  }
];

const allProducts = await getCollection('products');
---

<Layout title="All Products | Weifang Tianyuan Waterproof" description="Explore our full range of professional waterproofing materials.">
  <main class="bg-slate-50 min-h-screen">
    <section class="py-20 bg-slate-900 text-white">
      <div class="max-w-7xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Product Center</h1>
        <p class="text-lg text-slate-300 max-w-2xl">High-performance waterproofing solutions for global construction projects.</p>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 py-16">
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-8">Browse by Category</h2>
        <div class="grid md:grid-cols-3 lg:grid-cols-6 gap-4">
          {categories.map(cat => (
            <a href={`/categories/${cat.id}`} class="group bg-white rounded-2xl p-4 border border-slate-100 shadow-sm hover:shadow-md transition-all text-center">
              <div class="aspect-square rounded-xl bg-slate-50 mb-4 overflow-hidden">
                <img src={cat.image} alt={cat.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
              </div>
              <h3 class="font-bold text-slate-900 text-sm group-hover:text-blue-600 transition-colors">{cat.name}</h3>
            </a>
          ))}
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-slate-900 mb-8">All Products ({allProducts.length})</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {allProducts.map(p => (
            <a href={`/products/${p.slug}/`} class="group block bg-white rounded-3xl p-6 shadow-sm border border-slate-100 hover:shadow-md transition-all">
              <div class="relative overflow-hidden rounded-2xl mb-6 aspect-[4/3] bg-slate-50 flex items-center justify-center">
                {p.data.image ? (
                  <img src={p.data.image} alt={p.data.title} class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500" />
                ) : (
                  <div class="w-full h-full flex flex-col items-center justify-center text-slate-400 p-6 text-center select-none">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 mb-3 text-slate-300">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                    </svg>
                    <span class="text-xs font-bold uppercase tracking-wider text-slate-400">Image Coming Soon</span>
                  </div>
                )}
              </div>
              <p class="text-blue-600 text-xs font-bold uppercase tracking-wider mb-2">{p.data.category.replace('-', ' ')}</p>
              <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors line-clamp-2">{p.data.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed line-clamp-3 mb-6">{p.data.description}</p>
              <span class="inline-flex items-center gap-2 font-bold text-brand text-sm">Product Specs <span class="text-xl leading-none">›</span></span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
