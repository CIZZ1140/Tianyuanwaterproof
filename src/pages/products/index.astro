---
import Layout from '@/layouts/Layout.astro';
import ProductCard from '@/components/ProductCard.astro';
import CTA from '@/components/CTA.astro';
import { categories, products } from '@/data/products';
const base = import.meta.env.BASE_URL;
---
<Layout title="Products | Waterproofing Materials Manufacturer">
  <section class="bg-navy py-16 text-white"><div class="container-wrap"><p class="eyebrow">Products</p><h1 class="mt-3 text-4xl font-black text-white md:text-5xl">Waterproofing product center</h1><p class="mt-5 max-w-3xl text-white/70">High-performance bitumen membranes, self-adhesive series, and roofing underlayment for global construction projects.</p></div></section>

  <section class="py-16">
    <div class="container-wrap">
      <div class="grid gap-6 md:grid-cols-3">
        {categories.map((cat) => <a href={`${base}products/${cat.slug}/`} class="card"><h2 class="text-2xl font-bold">{cat.name}</h2><p class="mt-3 text-sm leading-6">{cat.intro}</p></a>)}
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>
  <CTA />
</Layout>
