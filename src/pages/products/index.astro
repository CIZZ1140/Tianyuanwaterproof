---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const pageTitle = "Product Center | Tianyuan Waterproof";
const pageDescription =
  "Browse waterproofing membranes, waterproof tapes, coatings and construction waterproofing materials for global B2B projects.";

const slugify = (value: string) =>
  value
    .toLowerCase()
    .trim()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const pickString = (...values: unknown[]) => {
  for (const value of values) {
    if (typeof value === "string" && value.trim().length > 0) {
      return value.trim();
    }
  }

  return "";
};

const toCategoryLabel = (value: unknown) => {
  if (Array.isArray(value)) {
    return pickString(value[0]) || "Other Waterproof Products";
  }

  return pickString(value) || "Other Waterproof Products";
};

const rawProducts = await getCollection("products");

const products = rawProducts
  .filter((entry) => {
    const data = entry.data as Record<string, unknown>;
    return data.draft !== true;
  })
  .map((entry) => {
    const data = entry.data as Record<string, unknown>;

    const title =
      pickString(data.title) ||
      entry.slug
        .split("/")
        .pop()
        ?.replace(/-/g, " ") ||
      "Waterproofing Product";

    const categoryLabel = toCategoryLabel(
      data.category || data.productCategory || data.type
    );

    const description =
      pickString(data.description, data.summary, data.excerpt) ||
      "High-performance waterproofing material for construction and industrial projects.";

    const image =
      pickString(data.image, data.cover, data.thumbnail, data.heroImage) ||
      "/images/product-placeholder.webp";

    const imageAlt =
      pickString(data.imageAlt, data.alt) || `${title} product image`;

    const dateValue = pickString(data.date, data.pubDate, data.updatedAt);
    const timestamp = dateValue ? new Date(dateValue).getTime() || 0 : 0;

    return {
      title,
      categoryLabel,
      categorySlug: slugify(categoryLabel),
      description,
      image,
      imageAlt,
      href:
        pickString(data.href, data.url, data.permalink) ||
        `/products/${entry.slug}/`,
      timestamp,
    };
  })
  .sort((a, b) => b.timestamp - a.timestamp || a.title.localeCompare(b.title));

const preferredCategoryOrder = [
  "Asphalt Membranes",
  "Polymer Membranes",
  "Waterproof Tapes",
  "Waterproof Coatings",
  "Geosynthetics",
  "Tools & Accessories",
];

const categoryMap = new Map<
  string,
  { label: string; slug: string; count: number }
>();

products.forEach((product) => {
  if (!categoryMap.has(product.categorySlug)) {
    categoryMap.set(product.categorySlug, {
      label: product.categoryLabel,
      slug: product.categorySlug,
      count: 1,
    });
  } else {
    const current = categoryMap.get(product.categorySlug);
    if (current) current.count += 1;
  }
});

const sortedCategories = Array.from(categoryMap.values()).sort((a, b) => {
  const indexA = preferredCategoryOrder.indexOf(a.label);
  const indexB = preferredCategoryOrder.indexOf(b.label);

  if (indexA !== -1 && indexB !== -1) return indexA - indexB;
  if (indexA !== -1) return -1;
  if (indexB !== -1) return 1;

  return a.label.localeCompare(b.label);
});

const categories = [
  {
    label: "All Products",
    slug: "all",
    count: products.length,
  },
  ...sortedCategories,
];
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="relative w-full bg-[#F5F7FA] text-[#102033]">
    <section class="relative overflow-hidden bg-[#0E2A47] text-white">
      <div class="absolute inset-0">
        <img
          src="/images/waterproof-hero.jpg"
          alt="Waterproofing membrane installation on construction roof"
          class="h-full w-full object-cover opacity-35"
        />
        <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(8,24,49,0.94)_0%,rgba(14,42,71,0.82)_50%,rgba(14,42,71,0.55)_100%)]"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 py-14 md:px-6 md:py-20 lg:px-8">
        <div class="max-w-3xl">
          <h1 class="text-4xl font-extrabold leading-tight text-white md:text-5xl">
            Product Center
          </h1>

          <p class="mt-4 max-w-2xl text-base leading-7 text-white/85 md:text-lg">
            High-performance waterproofing solutions for global construction
            projects.
          </p>
        </div>
      </div>
    </section>

    <section class="relative mx-auto max-w-7xl px-4 py-10 md:px-6 md:py-14 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[280px_minmax(0,1fr)]">
        <aside class="relative">
          <div class="rounded-2xl border border-[#D9E2EC] bg-white p-4 shadow-sm lg:sticky lg:top-24">
            <h2 class="px-2 text-lg font-extrabold text-[#102033]">
              Product Overview
            </h2>

            <nav
              class="mt-4 flex gap-2 overflow-x-auto pb-2 lg:flex-col lg:overflow-visible lg:pb-0"
              aria-label="Product categories"
            >
              {categories.map((category, index) => (
                <button
                  type="button"
                  data-category-filter={category.slug}
                  data-category-label={category.label}
                  class={`flex shrink-0 items-center justify-between gap-4 rounded-xl px-4 py-3 text-left text-sm font-bold transition lg:w-full ${
                    index === 0
                      ? "bg-[#EAF3FF] text-[#1F4E8C]"
                      : "text-[#102033] hover:bg-[#F5F7FA] hover:text-[#F58A1F]"
                  }`}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  <span>{category.label}</span>
                  <span class="text-xs font-bold text-[#5B6B7C]">
                    {category.count}
                  </span>
                </button>
              ))}
            </nav>
          </div>
        </aside>

        <section class="relative">
          <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div>
              <h2 class="text-2xl font-extrabold text-[#102033] md:text-3xl">
                <span data-list-title>All Products</span>
                <span class="text-[#5B6B7C]">
                  (<span data-product-count>{products.length}</span>)
                </span>
              </h2>
            </div>

            <div class="flex items-center gap-3">
              <label class="text-sm font-bold text-[#5B6B7C]">
                Sort by
              </label>

              <select
                data-product-sort
                class="rounded-xl border border-[#D9E2EC] bg-white px-4 py-3 text-sm font-bold text-[#102033] outline-none transition focus:border-[#1F4E8C]"
              >
                <option value="newest">Newest</option>
                <option value="title-asc">Name A-Z</option>
                <option value="title-desc">Name Z-A</option>
              </select>
            </div>
          </div>

          {products.length > 0 ? (
            <div
              data-product-grid
              class="grid gap-6 md:grid-cols-2 xl:grid-cols-3"
            >
              {products.map((product) => (
                <article
                  data-product-card
                  data-product-category={product.categorySlug}
                  data-product-title={product.title}
                  data-product-date={product.timestamp}
                  class="group relative overflow-hidden rounded-2xl border border-[#D9E2EC] bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl"
                >
                  <a href={product.href} class="block">
                    <div class="aspect-[4/3] overflow-hidden bg-[#F5F7FA]">
                      <img
                        src={product.image}
                        alt={product.imageAlt}
                        loading="lazy"
                        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                      />
                    </div>

                    <div class="p-5">
                      <p class="text-xs font-extrabold uppercase tracking-wide text-[#1F4E8C]">
                        {product.categoryLabel}
                      </p>

                      <h3 class="mt-2 line-clamp-2 text-xl font-extrabold leading-snug text-[#102033]">
                        {product.title}
                      </h3>

                      <p class="mt-3 line-clamp-3 text-sm leading-6 text-[#5B6B7C]">
                        {product.description}
                      </p>

                      <div class="mt-5 inline-flex items-center text-sm font-extrabold text-[#1F4E8C] transition group-hover:text-[#F58A1F]">
                        Product Specs →
                      </div>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          ) : (
            <div class="rounded-2xl border border-[#D9E2EC] bg-white p-8 text-center">
              <h2 class="text-2xl font-extrabold text-[#102033]">
                No products found
              </h2>

              <p class="mt-3 text-[#5B6B7C]">
                Please add products to the products content collection.
              </p>
            </div>
          )}
        </section>
      </div>
    </section>

    <section class="relative mx-auto max-w-7xl px-4 pb-14 md:px-6 lg:px-8">
      <div class="overflow-hidden rounded-3xl bg-[linear-gradient(90deg,#0E2A47_0%,#1F4E8C_100%)] text-white shadow-xl">
        <div class="grid gap-6 p-6 md:grid-cols-[1fr_520px] md:items-center md:p-8 lg:p-10">
          <div>
            <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#F58A1F]">
              Request a Quotation
            </p>

            <h2 class="mt-3 max-w-2xl text-2xl font-extrabold leading-tight text-white md:text-3xl lg:text-4xl">
              Need Waterproofing Materials for Your Project?
            </h2>

            <p class="mt-4 max-w-2xl text-sm leading-6 text-[#D6E1EE] md:text-base">
              Send us your product type, specification, quantity and destination
              port. We will provide quotation, TDS and export packaging details.
            </p>

            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
              <a
                href="https://wa.me/8615263640998"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 rounded-xl bg-[#F58A1F] px-5 py-3 text-sm font-extrabold text-white transition hover:bg-[#25D366]"
              >
                <svg
                  aria-hidden="true"
                  viewBox="0 0 32 32"
                  class="h-5 w-5 shrink-0 fill-current"
                >
                  <path d="M16.02 3.2C9 3.2 3.3 8.82 3.3 15.75c0 2.4.69 4.64 1.88 6.55L3.2 28.8l6.7-1.9a12.9 12.9 0 0 0 6.12 1.55c7.02 0 12.72-5.62 12.72-12.55S23.04 3.2 16.02 3.2Zm0 22.96c-1.95 0-3.76-.55-5.3-1.5l-.38-.23-3.97 1.13 1.16-3.82-.25-.4a10.03 10.03 0 0 1-1.62-5.59c0-5.66 4.65-10.26 10.36-10.26 5.72 0 10.36 4.6 10.36 10.26 0 5.66-4.64 10.41-10.36 10.41Zm5.72-7.78c-.31-.16-1.84-.9-2.13-1-.28-.1-.49-.16-.7.16-.2.31-.8 1-.98 1.2-.18.21-.36.23-.67.08-.31-.16-1.31-.48-2.5-1.53-.92-.82-1.55-1.83-1.73-2.14-.18-.31-.02-.48.14-.64.14-.14.31-.36.47-.54.16-.18.21-.31.31-.52.1-.21.05-.39-.03-.55-.08-.16-.7-1.67-.95-2.29-.25-.6-.5-.52-.7-.53h-.6c-.21 0-.55.08-.84.39-.29.31-1.1 1.07-1.1 2.61s1.13 3.03 1.29 3.24c.16.21 2.22 3.36 5.38 4.71.75.32 1.34.51 1.8.66.76.24 1.45.21 1.99.13.61-.09 1.84-.75 2.1-1.47.26-.72.26-1.34.18-1.47-.08-.13-.29-.21-.6-.36Z" />
                </svg>

                <span>Contact by WhatsApp →</span>
              </a>

              <a
                href="mailto:sales@tyuanwaterproof.com"
                class="inline-flex items-center justify-center rounded-xl border border-white/25 px-5 py-3 text-sm font-bold text-white transition hover:bg-white hover:text-[#0E2A47]"
              >
                Email Us
              </a>
            </div>
          </div>

          <form
            action="https://formspree.io/f/mzdqdpwd"
            method="POST"
            class="rounded-2xl border border-white/10 bg-white p-5 text-[#102033] shadow-lg"
          >
            <div class="grid gap-4">
              <div class="grid gap-4 sm:grid-cols-2">
                <label class="block">
                  <span class="mb-2 block text-sm font-bold text-[#102033]">
                    Your Email
                  </span>
                  <input
                    type="email"
                    name="email"
                    required
                    placeholder="your@email.com"
                    class="w-full rounded-xl border border-[#D9E2EC] bg-white px-4 py-3 text-sm text-[#102033] outline-none transition placeholder:text-[#5B6B7C]/60 focus:border-[#1F4E8C]"
                  />
                </label>

                <label class="block">
                  <span class="mb-2 block text-sm font-bold text-[#102033]">
                    Product Type
                  </span>
                  <input
                    type="text"
                    name="product_type"
                    placeholder="Membrane, tape, coating..."
                    class="w-full rounded-xl border border-[#D9E2EC] bg-white px-4 py-3 text-sm text-[#102033] outline-none transition placeholder:text-[#5B6B7C]/60 focus:border-[#1F4E8C]"
                  />
                </label>
              </div>

              <label class="block">
                <span class="mb-2 block text-sm font-bold text-[#102033]">
                  Requirement Details
                </span>
                <textarea
                  name="message"
                  required
                  rows="3"
                  placeholder="Quantity, specification, destination port..."
                  class="w-full resize-none rounded-xl border border-[#D9E2EC] bg-white px-4 py-3 text-sm text-[#102033] outline-none transition placeholder:text-[#5B6B7C]/60 focus:border-[#1F4E8C]"
                ></textarea>
              </label>

              <button
                type="submit"
                class="inline-flex w-full items-center justify-center rounded-xl bg-[#F58A1F] px-5 py-3.5 text-sm font-extrabold text-white transition hover:bg-[#E37812]"
              >
                Submit Inquiry →
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>
  </main>

  <script>
    const filterButtons = Array.from(
      document.querySelectorAll("[data-category-filter]")
    );

    const productCards = Array.from(
      document.querySelectorAll("[data-product-card]")
    );

    const productGrid = document.querySelector("[data-product-grid]");
    const productCount = document.querySelector("[data-product-count]");
    const listTitle = document.querySelector("[data-list-title]");
    const sortSelect = document.querySelector("[data-product-sort]");

    const getVisibleCards = () =>
      productCards.filter((card) => !card.classList.contains("hidden"));

    const updateCount = () => {
      if (!productCount) return;
      productCount.textContent = String(getVisibleCards().length);
    };

    const setActiveButton = (activeButton) => {
      filterButtons.forEach((button) => {
        const isActive = button === activeButton;

        button.setAttribute("aria-pressed", String(isActive));
        button.classList.toggle("bg-[#EAF3FF]", isActive);
        button.classList.toggle("text-[#1F4E8C]", isActive);
        button.classList.toggle("text-[#102033]", !isActive);
        button.classList.toggle("hover:bg-[#F5F7FA]", !isActive);
        button.classList.toggle("hover:text-[#F58A1F]", !isActive);
      });
    };

    const filterProducts = (category, label, activeButton) => {
      productCards.forEach((card) => {
        const productCategory = card.getAttribute("data-product-category");
        const shouldShow = category === "all" || productCategory === category;

        card.classList.toggle("hidden", !shouldShow);
      });

      if (listTitle) {
        listTitle.textContent = label;
      }

      setActiveButton(activeButton);
      updateCount();
    };

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const category = button.getAttribute("data-category-filter") || "all";
        const label =
          button.getAttribute("data-category-label") || "All Products";

        filterProducts(category, label, button);
      });
    });

    if (sortSelect instanceof HTMLSelectElement && productGrid) {
      sortSelect.addEventListener("change", () => {
        const value = sortSelect.value;

        const sortedCards = [...productCards].sort((a, b) => {
          const titleA = a.getAttribute("data-product-title") || "";
          const titleB = b.getAttribute("data-product-title") || "";
          const dateA = Number(a.getAttribute("data-product-date") || "0");
          const dateB = Number(b.getAttribute("data-product-date") || "0");

          if (value === "title-asc") {
            return titleA.localeCompare(titleB);
          }

          if (value === "title-desc") {
            return titleB.localeCompare(titleA);
          }

          return dateB - dateA;
        });

        sortedCards.forEach((card) => {
          productGrid.appendChild(card);
        });
      });
    }

    updateCount();
  </script>
</Layout>
