---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Standardize specs format
const specsList = Array.isArray(entry.data.specs)
  ? entry.data.specs
  : Object.entries(entry.data.specs || {}).map(([label, value]) => ({ label, value }));
---

<Layout title={`${entry.data.title} - Weifang Tianyuan Waterproof`} description={entry.data.description}>
  <div class="bg-slate-50 min-h-screen">
    <!-- Breadcrumbs -->
    <div class="max-w-7xl mx-auto px-4 py-6">
      <nav class="flex text-sm text-slate-500 gap-2 items-center">
        <a href="/" class="hover:text-blue-600 transition-colors">Home</a>
        <span class="text-slate-300">/</span>
        <a href="/#products-grid" class="hover:text-blue-600 transition-colors">Products</a>
        <span class="text-slate-300">/</span>
        <span class="text-slate-800 font-medium truncate max-w-[200px] sm:max-w-none">{entry.data.title}</span>
      </nav>
    </div>

    <!-- Product Intro Hero -->
    <div class="max-w-7xl mx-auto px-4 pb-16">
      <div class="bg-white rounded-3xl p-6 md:p-12 shadow-sm border border-slate-100 grid md:grid-cols-12 gap-12">
        <!-- Product Image (Left) -->
        <div class="md:col-span-6 flex flex-col justify-center">
          <div class="overflow-hidden rounded-2xl border border-slate-100 bg-slate-50 aspect-[4/3] relative group">
            <img src={entry.data.image} alt={entry.data.title} class="object-cover w-full h-full" />
            <div class="absolute bottom-4 left-4 bg-slate-900/80 backdrop-blur-sm text-white px-3 py-1.5 rounded-lg text-xs font-semibold">
              {entry.data.category || 'Waterproofing Systems'}
            </div>
          </div>
        </div>

        <!-- Product Key Info (Right) -->
        <div class="md:col-span-6 flex flex-col justify-between">
          <div>
            <span class="text-blue-600 font-bold tracking-wider text-xs uppercase block mb-2">B2B Premium Sourcing</span>
            <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4 leading-tight">{entry.data.title}</h1>
            <p class="text-slate-600 mb-8 leading-relaxed text-sm md:text-base">{entry.data.description}</p>
          </div>

          <!-- Specifications Summary -->
          {specsList.length > 0 && (
            <div class="border-t border-slate-100 pt-6">
              <h2 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-4">Key Specifications</h2>
              <div class="grid grid-cols-2 gap-4 text-sm mb-6">
                {specsList.slice(0, 4).map(spec => (
                  <div>
                    <div class="text-slate-400 text-xs font-medium mb-1">{spec.label || spec.Material ? 'Material' : spec.label}</div>
                    <div class="text-slate-800 font-bold">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          )}

          <div class="flex gap-4">
            <a href="#inquiry" class="flex-1 bg-blue-600 text-white text-center font-bold py-4 rounded-xl hover:bg-blue-700 transition-all shadow-lg shadow-blue-600/15">
              Get Price & Catalog
            </a>
            <a href="mailto:zheng7842@gmail.com" class="border border-slate-200 text-slate-700 font-semibold px-6 py-4 rounded-xl hover:bg-slate-50 transition-all flex items-center justify-center">
              ✉
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Product Deep Details & Inquiry Form (Split Layout) -->
    <div class="max-w-7xl mx-auto px-4 pb-24 grid lg:grid-cols-12 gap-12">
      <!-- Left Column: Rich Content -->
      <div class="lg:col-span-7 space-y-12">
        <div class="bg-white rounded-3xl p-8 md:p-12 shadow-sm border border-slate-100">
          <div class="prose prose-slate max-w-none prose-headings:font-extrabold prose-h2:text-2xl prose-h3:text-lg prose-p:leading-relaxed prose-li:leading-relaxed prose-a:text-blue-600">
            <Content />
          </div>
        </div>
      </div>

      <!-- Right Column: Inquiry Sidebar -->
      <div class="lg:col-span-5">
        <div id="inquiry" class="bg-slate-900 text-white rounded-3xl p-8 md:p-10 shadow-xl border border-slate-800 sticky top-6">
          <h3 class="text-2xl font-bold mb-2">Request Wholesale Quote</h3>
          <p class="text-slate-400 text-sm mb-8">Get expert recommendations, a comprehensive price list, and free samples for your construction project within 2 hours.</p>

          <form class="space-y-5" onsubmit="event.preventDefault(); alert('Inquiry sent successfully! Our sales manager will contact you via email.');">
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1.5">Your Name *</label>
              <input type="text" required class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-blue-500 transition-colors" placeholder="e.g. John Doe" />
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1.5">Business Email *</label>
                <input type="email" required class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-blue-500 transition-colors" placeholder="john@company.com" />
              </div>
              <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1.5">Phone / WhatsApp</label>
                <input type="text" class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-blue-500 transition-colors" placeholder="+1 234 567 890" />
              </div>
            </div>

            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1.5">Company Name & Country *</label>
              <input type="text" required class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-blue-500 transition-colors" placeholder="e.g. Apex Roofing Ltd, USA" />
            </div>

            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1.5">Required Quantity & Details *</label>
              <textarea required rows="4" class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-blue-500 transition-colors resize-none" placeholder="Please specify thickness, estimated quantity, and destination port (e.g., 5000 SQM SBS 4mm, FOB Qingdao)..."></textarea>
            </div>

            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-blue-600/20 text-center block">
              Send Inquiry Now
            </button>
          </form>

          <!-- Trust Badges -->
          <div class="mt-8 border-t border-slate-800 pt-6 flex justify-between items-center text-xs text-slate-500">
            <span class="flex items-center gap-1.5">
              🛡️ ISO 9001:2015
            </span>
            <span class="flex items-center gap-1.5">
              🇪🇺 CE Certified
            </span>
            <span class="flex items-center gap-1.5">
              ⚡ Rapid Response
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
