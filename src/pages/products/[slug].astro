---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import CTA from "../../components/CTA.astro";
import {
  ArrowRight,
  Box,
  Boxes,
  Building2,
  ChevronDown,
  ClipboardCheck,
  Download,
  Droplets,
  Factory,
  FileText,
  Flame,
  FlaskConical,
  Hammer,
  Image as ImageIcon,
  Layers,
  Leaf,
  MessageCircle,
  Package,
  Ruler,
  ShieldCheck,
  Sun,
  TrainTrack,
  Truck,
  Warehouse,
  Waves,
  Wrench,
  Snowflake,
} from "lucide-astro";

function normalizeAsset(value: any) {
  if (!value) return "";
  if (typeof value === "string") return value;
  return value?.src || value?.url || "";
}

function normalizeString(value: any, fallback = "") {
  return (typeof value === "string" && value.trim()) ? value.trim() : fallback;
}

function normalizeRows(value: any) {
  if (!Array.isArray(value)) return [];
  return value.map(item => ({
    label: item?.label || item?.name || item?.item || "",
    value: item?.value || item?.result || item?.detail || "",
    unit: item?.unit || "",
    standard: item?.standard || item?.test_method || "",
    requirement: item?.requirement || item?.class || ""
  })).filter(i => i.label || i.value);
}

function normalizeCards(value: any) {
  if (!Array.isArray(value)) return [];
  return value.map(item => ({
    title: item?.title || item?.label || "",
    text: item?.text || item?.description || "",
    image: normalizeAsset(item?.image),
    icon: item?.icon || ""
  })).filter(i => i.title || i.text);
}

const ICON_MAP: Record<string, any> = {
  box: Box, boxes: Boxes, building: Building2, clipboard: ClipboardCheck,
  droplets: Droplets, factory: Factory, flame: Flame, flask: FlaskConical,
  hammer: Hammer, layers: Layers, leaf: Leaf, package: Package,
  ruler: Ruler, shield: ShieldCheck, sun: Sun, snowflake: Snowflake,
  traintrack: TrainTrack, truck: Truck, warehouse: Warehouse, waves: Waves, wrench: Wrench,
};

function getCardIcon(item: any, fallbackIcons: any[], index: number) {
  if (item.icon && ICON_MAP[item.icon.toLowerCase()]) {
    return ICON_MAP[item.icon.toLowerCase()];
  }
  return fallbackIcons[index % fallbackIcons.length];
}

function normalizeGallery(value: any) {
  if (!Array.isArray(value)) return [];
  return value.map(item => ({
    image: normalizeAsset(typeof item === 'string' ? item : (item.image || item.src)),
    title: item.title || "Product Detail"
  })).filter(i => i.image);
}

function getSpecValue(rows: any[], keywords: string[]) {
  const target = rows.find((row) => {
    const label = String(row?.label ?? "").toLowerCase();
    return keywords.some((keyword) => label.includes(keyword.toLowerCase()));
  });
  return target?.value ?? "";
}

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((entry) => ({
    params: { slug: (entry.slug || entry.id).replace(/\.mdx?$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data as any;

const title = normalizeString(data.displayName || data.title, "Product Detail");
// SEO title: use frontmatter title when explicitly different from displayName (custom crafted), otherwise fallback to "displayName | Brand"
const hasCustomSeoTitle = data.displayName && data.title && data.title.trim() !== data.displayName.trim();
const seoTitle = hasCustomSeoTitle ? data.title.trim() : `${title} | Tianyuan Waterproof`;
const productCategory = normalizeString(data.product_category || data.category, "Waterproofing");
const mainImage = normalizeAsset(data.main_image || data.image);
const gallery = normalizeGallery(data.gallery || []);
const initialImage = gallery.length > 0 ? gallery[0].image : mainImage;

const heroTags = data.hero_tags || [];
const heroDesc = normalizeString(data.hero_description, `Industrial grade ${title} for global B2B supply.`);

const specTable = normalizeRows(data.spec_table || []);
const quickFacts = normalizeCards(data.quick_facts || []);
const features = normalizeCards(data.features || data.key_benefits || []);
const applications = normalizeCards(data.applications || []);
const technicalData = normalizeRows(data.technical_data || []);
const applicationGuide = normalizeCards(data.application_guide || []);
const packaging = normalizeCards(data.packaging || data.packaging_oem || data.oem_packaging || []);
const loadingData = normalizeRows(data.loading_data || []);
const downloads = (data.downloads || []).filter((d: any) => d.title);
const configurations = Array.isArray(data.configurations) ? data.configurations : [];

const allProducts = await getCollection("products");
const relatedProducts = allProducts
  .filter(p => p.slug !== entry.slug && p.data.category === entry.data.category)
  .slice(0, 4);

const heroSpecCards = [
  { label: "Reinforcement Options", value: getSpecValue(specTable, ["reinforcement options"]), icon: Boxes },
  { label: "Typical Applications", value: getSpecValue(specTable, ["typical applications"]), icon: Factory },
  { label: "Standard Roll Size", value: getSpecValue(specTable, ["standard roll size"]), icon: Ruler },
].filter((item) => item.value);

const applicationIcons = [Factory, Box, Truck, Wrench, Droplets, ShieldCheck];
const benefitIcons = [ShieldCheck, Ruler, Snowflake, Sun];
const installationIcons = [Hammer, Droplets, Ruler, Flame, Package, ClipboardCheck];
const packagingIcons = [Package, Truck, Box, Factory, FileText, FlaskConical];

const hasBody = entry.body && entry.body.replace(/---[\s\S]*?---/, "").trim().length > 0;
const isSimpleTechnicalTable = technicalData.every(row => !row.unit && !row.standard && !row.requirement);
const isSbsOrApp = ["sbs-bitumen-waterproofing-membrane-manufacturer", "app-modified-bitumen-waterproofing-membrane-manufacturer"].includes(entry.slug);

// B2B Schema
const productJsonLd = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": title,
  "image": [mainImage],
  "description": heroDesc,
  "brand": { "@type": "Brand", "name": "Tianyuan Waterproof" },
  "sku": `TY-${entry.slug.toUpperCase()}`,
  "additionalProperty": specTable.map(row => ({
    "@type": "PropertyValue",
    "name": row.label,
    "value": row.value
  }))
};
---

<Layout title={seoTitle} description={heroDesc} ogImage={mainImage}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productJsonLd)} />
  <main class="bg-slate-50 text-slate-950 pb-12">
    
    <!-- 1. Breadcrumb -->
    <nav class="mx-auto w-full max-w-[1680px] px-4 pt-4 pb-2 sm:px-6 lg:px-8" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-1 text-sm font-medium text-slate-500">
        <li><a href="/" class="hover:text-blue-700 transition">Home</a></li>
        <li class="mx-1">/</li>
        <li><a href="/products/" class="hover:text-blue-700 transition">Products</a></li>
        <li class="mx-1">/</li>
        <li><a href={`/categories/${entry.data.category}/`} class="hover:text-blue-700 transition">{productCategory}</a></li>
      </ol>
    </nav>

    <!-- 2. Hero Card -->
    <section class="mx-auto w-full max-w-[1680px] px-4 py-4 sm:px-6 lg:px-8 lg:py-8">
      <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6 lg:p-10">
        <div class="grid gap-12 lg:grid-cols-[0.7fr_1.3fr] lg:items-center">
          <!-- Left: Gallery Switcher -->
          <div>
            <div class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 flex items-center justify-center relative shadow-inner">
              <img id="main-product-image" src={initialImage} alt={title} class="max-h-[460px] w-full object-contain transition-all duration-300" />
            </div>
            {gallery.length > 0 && (
              <div class="mt-4 grid gap-3 grid-cols-4">
                {gallery.slice(0, 4).map((item) => (
                  <button class="gallery-thumb group flex flex-col rounded-2xl border-2 border-slate-200 bg-white shadow-sm transition hover:border-blue-400 overflow-hidden" data-full={item.image}>
                    <div class="aspect-[4/3] w-full bg-slate-50 p-1 flex items-center justify-center border-b border-slate-100">
                      <img src={item.image} alt={item.title} class="h-full w-full object-contain transition group-hover:scale-105" />
                    </div>
                    <div class="flex items-center justify-center px-1.5 py-2.5 min-h-[48px] bg-white group-[.active]:bg-blue-50/50">
                      <p class="text-center text-[11px] font-black leading-tight text-slate-700 group-[.active]:text-blue-700 transition-colors uppercase tracking-tight">{item.title}</p>
                    </div>
                  </button>
                ))}
              </div>
            )}
          </div>
          <!-- Right: Info Area -->
          <div>
            <p class="mb-4 text-[10px] font-black uppercase tracking-[0.3em] text-blue-700 opacity-80">Factory Direct Supply</p>
            <h1 class="text-3xl font-black text-slate-950 sm:text-4xl lg:text-5xl tracking-tight leading-tight">{title}</h1>
            <p class="mt-6 text-base leading-8 text-slate-600 sm:text-lg">{heroDesc}</p>
            
            <div class="mt-6 flex flex-wrap gap-3">
              {heroTags.map((tag: string) => <span class="rounded-full border border-blue-100 bg-blue-50 px-4 py-1.5 text-xs font-bold text-blue-800">{tag}</span>)}
            </div>

            {heroSpecCards.length > 0 && (
              <div class="mt-8 grid gap-4 sm:grid-cols-3">
                {heroSpecCards.map((item) => {
                  const Icon = item.icon;
                  return (
                    <div class="rounded-2xl border border-slate-100 bg-slate-50/50 p-4 transition hover:bg-slate-50">
                      <div class="mb-3 flex items-center gap-2 text-blue-700">
                        <Icon class="h-4 w-4" /><p class="text-[9px] font-black uppercase tracking-widest opacity-60">{item.label}</p>
                      </div>
                      <p class="text-sm font-bold text-slate-950 leading-relaxed">{item.value}</p>
                    </div>
                  );
                })}
              </div>
            )}

            <div class="mt-10 flex flex-col items-center gap-3 sm:flex-row">
              <a href="/contact/" class="inline-flex w-full items-center justify-center rounded-xl bg-blue-700 px-10 py-3.5 text-sm font-black text-white shadow-xl shadow-blue-700/20 transition hover:bg-blue-800 sm:w-auto">Get Factory Quote</a>
              <a href="https://wa.me/8615263640998" target="_blank" rel="noopener" class="inline-flex w-full items-center justify-center gap-2 rounded-xl border-2 border-emerald-100 bg-emerald-50 px-8 py-3.5 text-sm font-black text-emerald-700 transition hover:bg-emerald-100 sm:w-auto"><MessageCircle class="h-4 w-4" /> WhatsApp</a>
              <a href="/contact/" class="inline-flex w-full items-center justify-center gap-2 rounded-xl border-2 border-blue-100 bg-blue-50 px-8 py-3.5 text-sm font-black text-blue-800 transition hover:bg-blue-100 sm:w-auto"><FileText class="h-4 w-4" /> Request TDS</a>
            </div>
            
            <p class="mt-4 text-[11px] font-medium text-slate-400 italic">For project-specific pricing, send your technical requirements and destination port.</p>

            <div class="mt-8 flex flex-wrap gap-x-6 gap-y-3 text-[10px] font-black uppercase tracking-widest text-slate-400 border-t border-slate-100 pt-6">
              <span class="flex items-center gap-2"><Factory class="h-3.5 w-3.5" /> Direct Supply</span>
              <span class="flex items-center gap-2"><ShieldCheck class="h-3.5 w-3.5" /> OEM Labeling</span>
              <span class="flex items-center gap-2"><FileText class="h-3.5 w-3.5" /> Technical Support</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. Full Width Modular Blocks -->
    <div class="mx-auto w-full max-w-[1680px] space-y-4 px-4 sm:px-6 lg:px-8">
      
      <!-- MOVED UP: Product Overview Content -->
      {hasBody && (
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-12 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-10 uppercase tracking-tight">Product Overview</h2>
          <div class="prose prose-slate max-w-none 
            prose-headings:font-black prose-headings:text-slate-950
            prose-p:text-slate-600 prose-p:leading-8
            prose-img:rounded-3xl prose-img:shadow-xl
            prose-table:rounded-xl prose-table:overflow-hidden prose-table:border prose-table:border-slate-100
            prose-th:bg-slate-50 prose-th:font-black
            prose-hr:my-12 prose-hr:border-slate-100">
            <Content />
          </div>
        </section>
      )}

      {configurations.length > 0 && (
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-8 uppercase tracking-tight">Available Configurations</h2>
          <p class="mb-6 max-w-3xl text-sm font-medium leading-7 text-slate-600">Select the reinforcement, thickness and surface finish to match your project requirements. Contact us with your specification for a tailored quotation.</p>
          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full min-w-[700px] border-collapse text-left text-sm">
              <thead class="bg-slate-50 text-slate-950">
                <tr class="border-b border-slate-200">
                  <th class="px-4 py-4 font-black">Configuration</th>
                  <th class="px-4 py-4 font-black">Reinforcement</th>
                  <th class="px-4 py-4 font-black">Thickness</th>
                  <th class="px-4 py-4 font-black">Surface</th>
                  <th class="px-4 py-4 font-black">Recommended Use</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-200">
                {configurations.map((config: any) => (
                  <tr class="transition hover:bg-blue-50/40">
                    <td class="px-4 py-4 font-bold text-slate-800">{config.code || "—"}</td>
                    <td class="px-4 py-4 font-medium text-slate-600">{config.reinforcement || "—"}</td>
                    <td class="px-4 py-4 font-medium text-slate-600">{Array.isArray(config.thickness) ? config.thickness.join(" / ") : (config.thickness || "—")}</td>
                    <td class="px-4 py-4 font-medium text-slate-600">{config.surface || "—"}</td>
                    <td class="px-4 py-4 text-sm leading-6 text-slate-600">{config.use || "—"}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="mt-4 text-sm font-medium text-slate-400">Final configuration should be selected according to climate, substrate, waterproofing system design, exposure condition and local project specifications.</p>
        </section>
      )}

      {applications.length > 0 && (
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-8 uppercase tracking-tight">Applications</h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
            {applications.slice(0, 5).map((item, index) => {
              const Icon = getCardIcon(item, applicationIcons, index);
              return (
                <article class="rounded-2xl border border-slate-100 bg-slate-50/50 p-6">
                  <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-white text-blue-700 shadow-sm border border-blue-50"><Icon class="h-6 w-6" /></div>
                  <h3 class="text-sm font-black text-slate-950 mb-2">{item.title}</h3>
                  <p class="text-sm font-medium leading-relaxed text-slate-600">{item.text}</p>
                </article>
              );
            })}
          </div>
        </section>
      )}

      {features.length > 0 && (
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-8 uppercase tracking-tight">Key Benefits</h2>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {features.slice(0, 4).map((item, index) => {
              const Icon = getCardIcon(item, benefitIcons, index);
              return (
                <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm border-l-4 border-l-blue-600">
                  <Icon class="mb-5 h-8 w-8 text-blue-700" />
                  <h3 class="text-base font-black text-slate-950 mb-3">{item.title}</h3>
                  <p class="text-sm font-medium leading-7 text-slate-600">{item.text}</p>
                </article>
              );
            })}
          </div>
        </section>
      )}

      {technicalData.length > 0 && (
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-4 flex items-center gap-3"><FlaskConical class="text-blue-600" /> Technical Specifications</h2>
          {data.technical_scope && <p class="mb-6 text-sm font-medium text-slate-500">{data.technical_scope}</p>}
          <div class="overflow-x-auto rounded-2xl border border-slate-200 bg-white">
            <table class="w-full text-left text-sm border-collapse">
              <thead class="bg-slate-50">
                <tr class="border-b border-slate-200">
                  <th class="px-6 py-4 font-black">Test Item</th>
                  {!isSimpleTechnicalTable && <th class="px-6 py-4 font-black">Unit</th>}
                  {!isSimpleTechnicalTable && <th class="px-6 py-4 font-black">Test Method</th>}
                  {!isSimpleTechnicalTable && <th class="px-6 py-4 font-black">Requirement</th>}
                  <th class="px-6 py-4 font-black">Result / Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {technicalData.map(row => (
                  <tr class="hover:bg-blue-50/20 transition-colors">
                    <td class="px-6 py-4 font-bold text-slate-800">{row.label}</td>
                    {!isSimpleTechnicalTable && <td class="px-6 py-4 text-slate-600 font-medium">{row.unit || "—"}</td>}
                    {!isSimpleTechnicalTable && <td class="px-6 py-4 text-slate-600 font-medium">{row.standard || "—"}</td>}
                    {!isSimpleTechnicalTable && <td class="px-6 py-4 text-slate-600 font-medium">{row.requirement || "—"}</td>}
                    <td class="px-6 py-4 font-bold text-slate-900">{row.value || "Pass"}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          {data.technical_disclaimer && <p class="mt-4 text-sm font-medium text-slate-400">{data.technical_disclaimer}</p>}
        </section>
      )}

      {applicationGuide.length > 0 && (
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-8 flex items-center gap-3"><Hammer class="text-blue-600" /> Installation Guide</h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {applicationGuide.slice(0, 4).map((item, index) => {
              const Icon = installationIcons[index % installationIcons.length];
              return (
                <article class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
                  <Icon class="mb-5 h-8 w-8 text-blue-700" />
                  <h3 class="text-sm font-black uppercase text-slate-950 mb-3">{item.title}</h3>
                  <p class="text-sm font-medium leading-relaxed text-slate-600">{item.text}</p>
                </article>
              );
            })}
          </div>
        </section>
      )}

      {(packaging.length > 0 || loadingData.length > 0) && (
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-8 uppercase tracking-tight">Packaging & OEM</h2>
          <div class={packaging.length > 0 ? "grid gap-8 lg:grid-cols-[0.8fr_1.2fr]" : "block"}>
            {packaging.length > 0 && (
              <div class="grid gap-4 sm:grid-cols-2">
                {packaging.slice(0, 4).map((item, index) => {
                  const Icon = packagingIcons[index % packagingIcons.length];
                  return (
                    <div class="p-5 rounded-2xl bg-slate-50 border border-slate-100 transition hover:bg-white hover:shadow-md">
                      <Icon class="mb-4 h-6 w-6 text-blue-700" />
                      <h3 class="text-[10px] font-black uppercase text-slate-950 mb-2">{item.title}</h3>
                      <p class="text-sm font-medium leading-relaxed text-slate-600">{item.text}</p>
                    </div>
                  );
                })}
              </div>
            )}
            {loadingData.length > 0 && (
              <div class="overflow-hidden rounded-2xl border border-blue-200 bg-white shadow-sm">
                <div class="bg-blue-700 px-6 py-4 text-white flex items-center gap-3">
                  <Truck class="h-5 w-5" />
                  <span class="text-xs font-black uppercase tracking-widest">Export Loading Reference</span>
                </div>
                <div class="divide-y divide-slate-100">
                  {loadingData.map(row => (
                    <div class="grid grid-cols-[0.4fr_0.6fr] px-6 py-4 text-sm transition hover:bg-blue-50/30">
                      <div class="font-black text-blue-800">{row.label}</div>
                      <div class="font-medium text-slate-600">{row.value}</div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </section>
      )}

      <div class="grid gap-4 lg:grid-cols-2">
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 mb-8 uppercase tracking-tight">Technical Downloads</h2>
          <div class="space-y-3">
            {downloads.map((doc: any) => (
              <div class="flex items-center justify-between p-5 rounded-2xl border border-slate-100 bg-slate-50/50 hover:bg-white hover:shadow-md transition-all">
                <div class="flex items-center gap-4">
                  <div class="h-10 w-10 flex items-center justify-center rounded-xl bg-red-50 text-red-600 shadow-inner"><FileText size={20} /></div>
                  <div>
                    <h3 class="text-sm font-black text-slate-900 leading-tight">{doc.title}</h3>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-1">Ready for PDF Request</p>
                  </div>
                </div>
                <a 
                  href={doc.href && doc.href !== "#" ? doc.href : "/contact/"} 
                  target={doc.href && doc.href !== "#" ? "_blank" : "_self"}
                  class="px-5 py-2 rounded-xl bg-white border border-slate-200 text-[10px] font-black uppercase tracking-widest text-slate-600 hover:border-blue-300 hover:text-blue-700 transition shadow-sm"
                >
                  {doc.href && doc.href !== "#" ? "Download" : "Request"}
                </a>
              </div>
            ))}
          </div>
        </section>
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 mb-8 uppercase tracking-tight">RELATED PRODUCT</h2>
          <div class="grid grid-cols-2 gap-4">
            {relatedProducts.map(rp => (
              <a href={`/products/${rp.slug}/`} class="group flex flex-col gap-3">
                <div class="aspect-[4/3] overflow-hidden rounded-2xl bg-slate-100 border border-slate-200">
                  <img src={normalizeAsset(rp.data.main_image || rp.data.image)} class="h-full w-full object-contain transition duration-500 group-hover:scale-105" alt={rp.data.title} />
                </div>
                <h4 class="text-xs font-black text-slate-900 line-clamp-1 group-hover:text-blue-700 transition-colors">{rp.data.displayName || rp.data.title}</h4>
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>
    <CTA />

    <script is:inline>
      const mainImg = document.getElementById('main-product-image');
      const thumbs = document.querySelectorAll('.gallery-thumb');
      if (mainImg && thumbs.length > 0) {
        thumbs[0].classList.add('active');
        thumbs.forEach(thumb => {
          const handleSwitch = () => {
            const newSrc = thumb.getAttribute('data-full');
            if (newSrc && mainImg.src !== newSrc) {
              thumbs.forEach(t => t.classList.remove('active'));
              thumb.classList.add('active');
              mainImg.style.opacity = '0';
              setTimeout(() => { mainImg.src = newSrc; mainImg.style.opacity = '1'; }, 200);
            }
          };
          thumb.addEventListener('click', handleSwitch);
          thumb.addEventListener('mouseenter', handleSwitch);
        });
      }
    </script>
    <style is:global>
      .gallery-thumb.active { border-color: #3b82f6 !important; background-color: #eff6ff !important; }
    </style>
  </main>
</Layout>
