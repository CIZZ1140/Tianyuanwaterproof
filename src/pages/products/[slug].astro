---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import CTA from "../../components/CTA.astro";
import {
  ArrowRight,
  Box,
  Boxes,
  Building2,
  ChevronDown,
  ClipboardCheck,
  Download,
  Droplets,
  Factory,
  FileText,
  Flame,
  FlaskConical,
  Hammer,
  Image as ImageIcon,
  Layers,
  Leaf,
  MessageCircle,
  Package,
  Ruler,
  ShieldCheck,
  Sun,
  TrainTrack,
  Truck,
  Warehouse,
  Waves,
  Wrench,
  Snowflake,
} from "lucide-astro";

function normalizeAsset(value: any) {
  if (!value) return "";
  if (typeof value === "string") return value;
  return value?.src || value?.url || "";
}

function normalizeString(value: any, fallback = "") {
  return (typeof value === "string" && value.trim()) ? value.trim() : fallback;
}

function normalizeRows(value: any) {
  if (!Array.isArray(value)) return [];
  return value.map(item => ({
    label: item?.label || item?.name || item?.item || "",
    value: item?.value || item?.result || item?.detail || "",
    unit: item?.unit || "",
    standard: item?.standard || item?.test_method || "",
    requirement: item?.requirement || item?.class || ""
  })).filter(i => i.label || i.value);
}

function normalizeCards(value: any) {
  if (!Array.isArray(value)) return [];
  return value.map(item => ({
    title: item?.title || item?.label || "",
    text: item?.text || item?.description || "",
    image: normalizeAsset(item?.image),
    icon: item?.icon || ""
  })).filter(i => i.title || i.text);
}

const ICON_MAP: Record<string, any> = {
  box: Box, boxes: Boxes, building: Building2, clipboard: ClipboardCheck,
  droplets: Droplets, factory: Factory, flame: Flame, flask: FlaskConical,
  hammer: Hammer, layers: Layers, leaf: Leaf, package: Package,
  ruler: Ruler, shield: ShieldCheck, sun: Sun, snowflake: Snowflake,
  traintrack: TrainTrack, truck: Truck, warehouse: Warehouse, waves: Waves, wrench: Wrench,
};

function getCardIcon(item: any, fallbackIcons: any[], index: number) {
  if (item.icon && ICON_MAP[item.icon.toLowerCase()]) {
    return ICON_MAP[item.icon.toLowerCase()];
  }
  return fallbackIcons[index % fallbackIcons.length];
}

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((entry) => ({
    params: { slug: (entry.slug || entry.id).replace(/\.mdx?$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data as any;

const title = normalizeString(data.displayName || data.title, "Product Detail");
const productCategory = normalizeString(data.product_category || data.category, "Waterproofing");
const mainImage = normalizeAsset(data.main_image || data.image);
const heroTags = data.hero_tags || [];
const heroDesc = normalizeString(data.hero_description, `Industrial grade ${title} for global B2B supply.`);

const specTable = normalizeRows(data.spec_table || []);
const quickFacts = normalizeCards(data.quick_facts || []);
const features = normalizeCards(data.features || data.key_benefits || []);
const applications = normalizeCards(data.applications || []);
const technicalData = normalizeRows(data.technical_data || []);
const applicationGuide = normalizeCards(data.application_guide || []);
const packaging = normalizeCards(data.packaging || []);
const loadingData = normalizeRows(data.loading_data || []);
const downloads = (data.downloads || []).filter((d: any) => d.title);

const allProducts = await getCollection("products");
const relatedProducts = allProducts
  .filter(p => p.slug !== entry.slug && p.data.category === entry.data.category)
  .slice(0, 4);

const isSbsOrApp = ["sbs-bitumen-waterproofing-membrane-manufacturer", "app-modified-bitumen-waterproofing-membrane-manufacturer"].includes(entry.slug);

const applicationIcons = [Factory, Box, Truck, Wrench, Droplets, ShieldCheck];
const benefitIcons = [ShieldCheck, Ruler, Snowflake, Sun];
const installationIcons = [Hammer, Droplets, Ruler, Flame, Package, ClipboardCheck];
const packagingIcons = [Package, Truck, Box, Factory, FileText, FlaskConical];

const hasBody = entry.body && entry.body.replace(/---[\s\S]*?---/, "").trim().length > 0;
const isSimpleTechnicalTable = technicalData.every(row => !row.unit && !row.standard && !row.requirement);
---

<Layout title={`${title} | Tianyuan Waterproof`} description={heroDesc}>
  <main class="bg-slate-50 text-slate-950 pb-12">
    <!-- 1. Breadcrumb -->
    <nav class="mx-auto w-full max-w-[1680px] px-4 pt-4 pb-2 sm:px-6 lg:px-8" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-1 text-sm font-medium text-slate-500">
        <li><a href="/" class="hover:text-blue-700 transition">Home</a></li>
        <li class="mx-1">/</li>
        <li><a href="/products/" class="hover:text-blue-700 transition">Products</a></li>
        <li class="mx-1">/</li>
        <li class="font-bold text-slate-900">{title}</li>
      </ol>
    </nav>

    <!-- 2. Hero Card -->
    <section class="mx-auto w-full max-w-[1680px] px-4 py-4 sm:px-6 lg:px-8 lg:py-8">
      <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6 lg:p-10">
        <div class="grid gap-12 lg:grid-cols-[0.7fr_1.3fr] lg:items-center">
          <div class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 flex items-center justify-center">
             <img src={mainImage} alt={title} class="max-h-[440px] w-full object-contain" />
          </div>
          <div>
            <p class="mb-4 text-xs font-bold uppercase tracking-[0.25em] text-blue-700">Factory Direct Supply</p>
            <h1 class="text-3xl font-black text-slate-950 sm:text-4xl lg:text-5xl tracking-tight leading-tight">{title}</h1>
            <p class="mt-6 text-base leading-8 text-slate-600 sm:text-lg">{heroDesc}</p>
            <div class="mt-6 flex flex-wrap gap-3">
              {heroTags.map((tag: string) => <span class="rounded-full border border-blue-100 bg-blue-50 px-4 py-1.5 text-sm font-bold text-blue-800">{tag}</span>)}
            </div>
            <div class="mt-10 flex flex-col items-center gap-3 sm:flex-row">
              <a href="/contact/" class="inline-flex w-full items-center justify-center rounded-xl bg-blue-700 px-10 py-3.5 text-sm font-black text-white shadow-xl shadow-blue-700/20 transition hover:bg-blue-800 sm:w-auto">Get Factory Quote</a>
              <a href="https://wa.me/8615263640998" target="_blank" class="inline-flex w-full items-center justify-center gap-2 rounded-xl border-2 border-emerald-100 bg-emerald-50 px-8 py-3.5 text-sm font-black text-emerald-700 transition hover:bg-emerald-100 sm:w-auto">Chat on WhatsApp</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. Full Width Sections -->
    <div class="mx-auto w-full max-w-[1680px] space-y-4 px-4 sm:px-6 lg:px-8">
      
      <!-- Applications -->
      {applications.length > 0 && (
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-8 uppercase tracking-tight">Applications</h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
            {applications.slice(0, 5).map((item, index) => {
              const Icon = getCardIcon(item, applicationIcons, index);
              return (
                <article class="rounded-2xl border border-slate-100 bg-slate-50/50 p-6 transition hover:shadow-md">
                  <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-white text-blue-700 shadow-sm border border-blue-50"><Icon class="h-6 w-6" /></div>
                  <h3 class="text-sm font-black text-slate-950 mb-2">{item.title}</h3>
                  <p class="text-xs font-medium leading-relaxed text-slate-500">{item.text}</p>
                </article>
              );
            })}
          </div>
        </section>
      )}

      <!-- Key Benefits -->
      {features.length > 0 && (
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-8 uppercase tracking-tight">Key Benefits</h2>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {features.slice(0, 4).map((item, index) => {
              const Icon = getCardIcon(item, benefitIcons, index);
              return (
                <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm border-l-4 border-l-blue-600">
                  <Icon class="mb-5 h-8 w-8 text-blue-700" />
                  <h3 class="text-base font-black text-slate-950 mb-3">{item.title}</h3>
                  <p class="text-sm font-medium leading-7 text-slate-600">{item.text}</p>
                </article>
              );
            })}
          </div>
        </section>
      )}

      <!-- Technical Specifications Table -->
      {technicalData.length > 0 && (
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-8 flex items-center gap-3"><FlaskConical class="text-blue-600" /> Technical Specifications</h2>
          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-left text-sm border-collapse">
              <thead class="bg-slate-50">
                <tr class="border-b border-slate-200">
                  <th class="px-6 py-4 font-black">Test Item</th>
                  {!isSimpleTechnicalTable && <th class="px-6 py-4 font-black">Unit</th>}
                  {!isSimpleTechnicalTable && <th class="px-6 py-4 font-black">Test Method / Standard</th>}
                  {!isSimpleTechnicalTable && <th class="px-6 py-4 font-black">Requirement / Class</th>}
                  <th class="px-6 py-4 font-black">Result / Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {technicalData.map(row => (
                  <tr class="hover:bg-blue-50/30 transition-colors">
                    <td class="px-6 py-4 font-bold text-slate-800">{row.label}</td>
                    {!isSimpleTechnicalTable && <td class="px-6 py-4 text-slate-600">{row.unit}</td>}
                    {!isSimpleTechnicalTable && <td class="px-6 py-4 text-slate-600">{row.standard}</td>}
                    {!isSimpleTechnicalTable && <td class="px-6 py-4 text-slate-600">{row.requirement}</td>}
                    <td class="px-6 py-4 font-bold text-slate-900">{row.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}

      <!-- Installation Guide -->
      {applicationGuide.length > 0 && (
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-8 flex items-center gap-3"><Hammer class="text-blue-600" /> Installation Guide</h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {applicationGuide.slice(0, 4).map((item, index) => {
              const Icon = installationIcons[index % installationIcons.length];
              return (
                <article class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
                  <Icon class="mb-5 h-8 w-8 text-blue-700" />
                  <h3 class="text-sm font-black uppercase text-slate-950 mb-3">{item.title}</h3>
                  <p class="text-sm font-medium leading-relaxed text-slate-600">{item.text}</p>
                </article>
              );
            })}
          </div>
        </section>
      )}

      <!-- Packaging & Loading -->
      {(packaging.length > 0 || loadingData.length > 0) && (
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-8 uppercase tracking-tight">Packaging & OEM</h2>
          <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
            <div class="grid gap-4 sm:grid-cols-2">
              {packaging.slice(0, 4).map((item, index) => {
                const Icon = packagingIcons[index % packagingIcons.length];
                return (
                  <div class="p-5 rounded-2xl bg-slate-50 border border-slate-100">
                    <Icon class="mb-4 h-6 w-6 text-blue-700" />
                    <h3 class="text-xs font-black uppercase text-slate-950 mb-2">{item.title}</h3>
                    <p class="text-[11px] font-medium leading-relaxed text-slate-500">{item.text}</p>
                  </div>
                );
              })}
            </div>
            {loadingData.length > 0 && (
              <div class="overflow-hidden rounded-2xl border border-blue-200 bg-white">
                <div class="bg-blue-700 px-6 py-4 text-white flex items-center gap-3">
                  <Truck class="h-5 w-5" />
                  <span class="text-sm font-black uppercase tracking-widest">Export Loading Reference</span>
                </div>
                <div class="divide-y divide-slate-100">
                  {loadingData.map(row => (
                    <div class="grid grid-cols-[0.4fr_0.6fr] px-6 py-4 text-sm">
                      <div class="font-black text-blue-800">{row.label}</div>
                      <div class="font-medium text-slate-600">{row.value}</div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </section>
      )}

      <!-- Product Overview Content -->
      {hasBody && (
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-12 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-10 uppercase tracking-tight">Product Overview</h2>
          <div class="prose prose-slate max-w-none 
            prose-headings:font-black prose-headings:text-slate-950
            prose-p:text-slate-600 prose-p:leading-8 prose-p:text-lg
            prose-img:rounded-3xl prose-img:shadow-xl prose-img:my-10
            prose-table:rounded-xl prose-table:overflow-hidden prose-table:border prose-table:border-slate-100
            prose-th:bg-slate-50 prose-th:font-black
            prose-hr:my-12 prose-hr:border-slate-100">
            <Content />
          </div>
        </section>
      )}

      <!-- Bottom Split: Downloads & Related -->
      <div class="grid gap-4 lg:grid-cols-2">
        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 mb-6 uppercase">Downloads</h2>
          <div class="space-y-3">
            {downloads.map((doc: any) => (
              <div class="flex items-center justify-between p-4 rounded-2xl border border-slate-100 bg-slate-50/50">
                <div class="flex items-center gap-4">
                  <div class="h-10 w-10 flex items-center justify-center rounded-xl bg-red-50 text-red-600"><FileText size={20} /></div>
                  <h3 class="text-sm font-black text-slate-900">{doc.title}</h3>
                </div>
                <a href="/contact/" class="px-4 py-2 rounded-xl bg-white border border-slate-200 text-[10px] font-black uppercase tracking-widest text-slate-600 hover:bg-slate-50 transition">Request</a>
              </div>
            ))}
          </div>
        </section>

        <section class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-8 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 mb-6 uppercase">Related Products</h2>
          <div class="grid grid-cols-2 gap-4">
            {relatedProducts.map(rp => (
              <a href={`/products/${rp.slug}/`} class="group flex flex-col gap-3">
                <div class="aspect-video overflow-hidden rounded-xl bg-slate-100 border border-slate-200">
                  <img src={normalizeAsset(rp.data.main_image || rp.data.image)} class="h-full w-full object-cover transition group-hover:scale-105" alt={rp.data.title} />
                </div>
                <h4 class="text-xs font-black text-slate-900 line-clamp-1 group-hover:text-blue-700">{rp.data.displayName || rp.data.title}</h4>
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>

    <!-- Final CTA -->
    <div class="mt-12">
      <CTA />
    </div>
  </main>
</Layout>
