---
import Layout from '@/layouts/Layout.astro';
import CTA from '@/components/CTA.astro';
import ProductCard from '@/components/ProductCard.astro';
import { products, categories } from '@/data/products';

export function getStaticPaths() {
  const productPaths = products.map((product) => ({ params: { slug: product.slug }, props: { type: 'product', item: product } }));
  const categoryPaths = categories.map((cat) => ({ params: { slug: cat.slug }, props: { type: 'category', item: cat } }));
  return [...productPaths, ...categoryPaths];
}
const { type, item } = Astro.props;
const base = import.meta.env.BASE_URL;
const categoryProducts = type === 'category' ? products.filter((p) => p.category === item.name) : [];
---
<Layout title={`${item.name} | Waterproofing Materials`} description={item.intro}>
  <section class="bg-navy py-16 text-white">
    <div class="container-wrap">
      <p class="eyebrow">{type === 'product' ? item.category : 'Product category'}</p>
      <h1 class="mt-3 max-w-4xl text-4xl font-black text-white md:text-5xl">{item.name}</h1>
      <p class="mt-5 max-w-3xl text-white/70">{item.intro}</p>
      <div class="mt-8 flex flex-wrap gap-3"><a class="btn-primary" href={`${base}contact/`}>Get Quotation</a><a class="btn-secondary" href={`${base}technical/download-center/`}>Download TDS</a></div>
    </div>
  </section>

  {type === 'category' ? (
    <section class="py-16"><div class="container-wrap"><div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">{categoryProducts.map((product) => <ProductCard product={product} />)}</div></div></section>
  ) : (
    <section class="py-16">
      <div class="container-wrap grid gap-10 lg:grid-cols-[.9fr_1.1fr]">
        <div class="card">
          <div class="grid h-80 place-items-center rounded-2xl bg-gradient-to-br from-slate-100 to-slate-200"><div class="h-40 w-64 rounded-[50%] border-[28px] border-industrial bg-white shadow-inner"></div></div>
          <p class="mt-5 text-sm text-slate-500">Replace this placeholder with real product image.</p>
        </div>
        <div>
          <h2 class="text-3xl font-bold">Product overview</h2>
          <p class="mt-4 leading-7 text-slate-600">{item.intro}</p>
          <div class="mt-8 grid gap-5 md:grid-cols-2">
            <div class="card"><h3 class="text-xl font-bold">Key Features</h3><ul class="mt-4 space-y-2 text-sm">{item.features.map((feature) => <li>✓ {feature}</li>)}</ul></div>
            <div class="card"><h3 class="text-xl font-bold">Applications</h3><ul class="mt-4 space-y-2 text-sm">{item.applications.map((app) => <li>✓ {app}</li>)}</ul></div>
          </div>
        </div>
      </div>
      <div class="container-wrap mt-12">
        <h2 class="text-3xl font-bold">Technical specifications</h2>
        <div class="mt-6 overflow-x-auto"><table class="table-spec"><tbody>{item.specs.map(([k, v]) => <tr><th>{k}</th><td>{v}</td></tr>)}</tbody></table></div>
      </div>
      <div class="container-wrap mt-12 grid gap-6 md:grid-cols-3">
        {['Packaging & Loading','Installation Method','OEM Support'].map((title) => <div class="card"><h3 class="text-xl font-bold">{title}</h3><p class="mt-3 text-sm leading-6 text-slate-600">Detailed data can be customized according to product specification, destination market and project requirement.</p></div>)}
      </div>
    </section>
  )}
  <CTA />
</Layout>
