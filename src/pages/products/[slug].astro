---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import CTA from "../../components/CTA.astro";
import {
  ArrowRight,
  Box,
  Boxes,
  Building2,
  ChevronDown,
  ClipboardCheck,
  Download,
  Droplets,
  Factory,
  FileText,
  Flame,
  FlaskConical,
  Hammer,
  Image as ImageIcon,
  Layers,
  Leaf,
  MessageCircle,
  Package,
  Ruler,
  ShieldCheck,
  Sun,
  TrainTrack,
  Truck,
  Warehouse,
  Waves,
  Wrench,
  Snowflake,
  Clock3,
} from "lucide-astro";

function normalizeAsset(value: any) {
  if (!value) return "";
  if (typeof value === "string") return value;
  return value?.src || value?.url || "";
}

function normalizeString(value: any, fallback = "") {
  return (typeof value === "string" && value.trim()) ? value.trim() : fallback;
}

function normalizeRows(value: any) {
  if (!Array.isArray(value)) return [];
  return value.map(item => ({
    label: item?.label || item?.name || "",
    value: item?.value || item?.result || "",
    unit: item?.unit || ""
  })).filter(i => i.label);
}

function normalizeCards(value: any) {
  if (!Array.isArray(value)) return [];
  return value.map(item => ({
    title: item?.title || item?.label || "",
    text: item?.text || item?.description || "",
    image: normalizeAsset(item?.image),
    icon: item?.icon || ""
  })).filter(i => i.title || i.text);
}

const ICON_MAP: Record<string, any> = {
  box: Box, boxes: Boxes, building: Building2, clipboard: ClipboardCheck,
  droplets: Droplets, factory: Factory, flame: Flame, flask: FlaskConical,
  hammer: Hammer, layers: Layers, leaf: Leaf, package: Package,
  ruler: Ruler, shield: ShieldCheck, sun: Sun, snowflake: Snowflake,
  traintrack: TrainTrack, truck: Truck, warehouse: Warehouse, waves: Waves, wrench: Wrench,
};

function getCardIcon(item: any, fallbackIcons: any[], index: number) {
  if (item.icon && ICON_MAP[item.icon.toLowerCase()]) {
    return ICON_MAP[item.icon.toLowerCase()];
  }
  return fallbackIcons[index % fallbackIcons.length];
}

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((entry) => ({
    params: { slug: (entry.slug || entry.id).replace(/\.mdx?$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data as any;

const title = normalizeString(data.displayName || data.title, "Product Detail");
const productCategory = normalizeString(data.product_category || data.category, "Waterproofing");
const specTable = normalizeRows(data.spec_table || []);
const quickFacts = normalizeCards(data.quick_facts || []);
const applications = normalizeCards(data.applications || []);
const downloads = (data.downloads || []).filter((d: any) => d.title);
const mainImage = normalizeAsset(data.main_image || data.image);
const heroTags = data.hero_tags || [];
const heroDesc = normalizeString(data.hero_description, `Industrial grade ${title} for global B2B supply.`);
const contactHref = "/contact/";
const whatsappHref = "https://wa.me/8615263640998";

// SEO & Meta Enhancement
const seoTitle = data.seo_title || `${title} | Professional B2B Supply | Tianyuan Waterproof`;
const seoDesc = data.meta_description || heroDesc;

// Sidebar Logic
const allProducts = await getCollection("products");
const relatedProducts = allProducts
  .filter(p => p.slug !== entry.slug && p.data.category === entry.data.category)
  .slice(0, 4);

const isSbsOrApp = ["sbs-bitumen-waterproofing-membrane-manufacturer", "app-modified-bitumen-waterproofing-membrane-manufacturer"].includes(entry.slug);
const applicationIcons = [Factory, Box, Truck, Wrench, Droplets, ShieldCheck];
const packaging = normalizeCards(data.packaging || []);
const loadingData = normalizeRows(data.loading_data || []);
const packagingIcons = [Package, Truck, Box, Factory, FileText, FlaskConical];

const hasOverview = (entry.body && entry.body.trim().length > 0) || quickFacts.length > 0;
const isRealFile = (url: string) => url && url !== "#" && (url.startsWith("http") || url.startsWith("/assets/") || url.endsWith(".pdf"));

// --- B2B SEO / GEO ENGINE INJECTION ---

// 1. Enhanced Product JSON-LD
const productJsonLd = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": title,
  "image": [mainImage],
  "description": seoDesc,
  "brand": { "@type": "Brand", "name": "Tianyuan Waterproof" },
  "sku": `TY-${entry.slug.toUpperCase()}`,
  "manufacturer": {
    "@type": "Organization",
    "name": "Weifang Tianyuan Waterproof Material Co., Ltd.",
    "url": "https://www.tyuanwaterproof.com"
  },
  "additionalProperty": specTable.map(row => ({
    "@type": "PropertyValue",
    "name": row.label,
    "value": row.value
  }))
};

// 2. FAQ Schema Logic
const faqs = Array.isArray(data.faqs) ? data.faqs : [];
const faqJsonLd = faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f: any) => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
} : null;
---

<Layout title={seoTitle} description={seoDesc} ogImage={mainImage}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />}

  <main class="bg-[#F8FAFC]">
    <!-- Hero Header -->
    <section class="bg-[#0E2A47] pt-12 pb-16 text-white border-b border-white/5">
      <div class="mx-auto max-w-[1680px] px-4 sm:px-6 lg:px-8">
        <nav class="mb-8 flex items-center gap-2 text-sm font-medium text-slate-400">
          <a href="/" class="hover:text-white transition">Home</a>
          <span>/</span>
          <a href="/products/" class="hover:text-white transition">Products</a>
          <span>/</span>
          <span class="text-white">{title}</span>
        </nav>

        <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
          <div class="aspect-square overflow-hidden rounded-3xl border border-white/10 bg-white/5 p-2 backdrop-blur-sm relative group">
              <img src={mainImage} alt={title} class="h-full w-full object-cover rounded-2xl shadow-2xl transition duration-500 group-hover:scale-105" />
          </div>
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-[10px] font-bold uppercase tracking-widest mb-6">Factory Direct Supply</div>
            <h1 class="text-4xl font-black md:text-5xl lg:text-6xl tracking-tight leading-[1.1]">{title}</h1>
            <p class="mt-8 text-lg text-slate-300 max-w-2xl font-medium">{heroDesc}</p>
            <div class="mt-8 flex flex-wrap gap-3">
              {heroTags.map((tag: string) => (
                <span class="px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-sm font-bold text-slate-200">{tag}</span>
              ))}
            </div>
            <div class="mt-10 flex flex-col sm:flex-row gap-4">
              <a href={contactHref} class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl bg-blue-600 text-white font-black hover:bg-blue-700 transition shadow-lg">Get Factory Quote <ArrowRight size={18} /></a>
              <a href={whatsappHref} target="_blank" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl bg-white/5 border border-white/10 text-white font-black hover:bg-white/10 transition">Chat on WhatsApp</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Layout -->
    <section class="mx-auto max-w-[1680px] px-4 py-16 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[1fr_360px]">
        <div class="space-y-12">
          {specTable.length > 0 && (
            <div class="rounded-[2.5rem] border border-slate-200 bg-white p-8 md:p-12 shadow-sm">
              <h2 class="text-2xl font-black text-[#102033] mb-8 flex items-center gap-3"><ClipboardCheck class="text-blue-600" /> Technical Specifications</h2>
              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {specTable.map(row => (
                  <div class="p-5 rounded-2xl bg-slate-50 border border-slate-100 transition hover:border-blue-200">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">{row.label}</p>
                    <p class="text-lg font-black text-[#102033]">{row.value} <span class="text-sm font-medium text-slate-500">{row.unit}</span></p>
                  </div>
                ))}
              </div>
            </div>
          )}

          {isSbsOrApp && (
            <div class="rounded-[2.5rem] border border-amber-200 bg-amber-50/30 p-8 md:p-12 shadow-sm relative overflow-hidden">
              <div class="absolute top-0 right-0 p-8 opacity-10"><Sun size={120} /></div>
              <h2 class="text-2xl font-black text-[#102033] mb-8 flex items-center gap-3 relative z-10">Comparison Guide: SBS vs APP</h2>
              <div class="overflow-x-auto rounded-3xl border border-slate-200 bg-white relative z-10">
                <table class="w-full text-left text-sm border-collapse">
                  <thead class="bg-slate-50 border-b border-slate-200">
                    <tr><th class="px-6 py-5 font-black text-slate-900">Property</th><th class="px-6 py-5 font-black text-amber-700 bg-amber-50/50">APP (Plastomeric)</th><th class="px-6 py-5 font-black text-blue-700 bg-blue-50/50">SBS (Elastomeric)</th></tr>
                  </thead>
                  <tbody class="divide-y divide-slate-100">
                    <tr><td class="px-6 py-4 font-bold text-slate-700">Best Climate</td><td class="px-6 py-4">Hot, high solar load</td><td class="px-6 py-4">Cold, wide temp swings</td></tr>
                    <tr><td class="px-6 py-4 font-bold text-slate-700">Heat Resistance</td><td class="px-6 py-4 font-bold text-amber-700">Up to 130°C</td><td class="px-6 py-4">Up to 105°C</td></tr>
                    <tr><td class="px-6 py-4 font-bold text-slate-700">Low Temp</td><td class="px-6 py-4">-15°C</td><td class="px-6 py-4 font-bold text-blue-700">-25°C</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          )}

          <div class="rounded-[2.5rem] border border-slate-200 bg-white p-8 md:p-12 shadow-sm">
            <h2 class="text-2xl font-black text-[#102033] mb-10 uppercase tracking-tight">Product Overview & Engineering Analysis</h2>
            <div class="prose prose-slate max-w-none 
              prose-headings:font-black prose-headings:text-[#102033]
              prose-p:text-slate-600 prose-p:leading-8 prose-p:text-lg
              prose-strong:font-black prose-strong:text-[#102033]
              prose-img:rounded-3xl prose-img:border prose-img:border-slate-200 prose-img:shadow-xl prose-img:my-12
              prose-table:rounded-2xl prose-table:overflow-hidden prose-table:border prose-table:border-slate-200
              prose-th:bg-slate-50 prose-th:px-4 prose-th:py-4 prose-th:font-black
              prose-td:px-4 prose-td:py-4 prose-td:border-t prose-td:border-slate-100
              prose-hr:my-16 prose-hr:border-slate-100">
              <Content />
            </div>
          </div>

          {downloads.length > 0 && (
            <div class="rounded-[2.5rem] border border-blue-200 bg-blue-50/20 p-8 md:p-12 shadow-sm">
              <h2 class="text-2xl font-black text-[#102033] mb-8 flex items-center gap-3"><FileText class="text-blue-600" /> Technical Document Hub</h2>
              <div class="grid gap-6 sm:grid-cols-2">
                {downloads.map((doc: any) => (
                  <div class="flex items-center justify-between p-6 rounded-3xl border border-white bg-white/60 shadow-sm transition hover:shadow-md hover:-translate-y-1">
                    <div class="flex items-center gap-4">
                      <div class="h-12 w-12 flex items-center justify-center rounded-2xl bg-blue-100 text-blue-700 shadow-inner"><FileText size={24} strokeWidth={2.5} /></div>
                      <div><h3 class="font-black text-[#102033] leading-tight text-sm">{doc.title}</h3><p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-1">Ready for Request</p></div>
                    </div>
                    <a href={contactHref} class="px-5 py-2.5 rounded-xl bg-[#0E2A47] text-white text-[11px] font-black uppercase tracking-widest hover:bg-blue-900 transition shadow-lg shadow-navy/10">Request TDS</a>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <aside class="space-y-8">
          <div class="sticky top-28 space-y-8">
            <div class="rounded-3xl bg-[#0E2A47] p-8 text-white shadow-2xl relative overflow-hidden group">
              <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:rotate-12 transition-transform duration-500"><MessageCircle size={100} /></div>
              <h3 class="text-xl font-black relative z-10">B2B Sourcing Support</h3>
              <p class="mt-4 text-slate-300 text-sm leading-relaxed relative z-10">Direct factory pricing, custom specifications, and global logistics support for large-scale projects.</p>
              <a href={contactHref} class="mt-8 flex w-full items-center justify-center gap-2 rounded-2xl bg-blue-600 py-4 font-black hover:bg-blue-700 transition relative z-10">Contact Sales <ArrowRight size={18} /></a>
            </div>

            {relatedProducts.length > 0 && (
              <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
                <h3 class="text-lg font-black text-[#102033] mb-6 flex items-center gap-2"><Boxes size={20} class="text-blue-600" /> Related Products</h3>
                <div class="space-y-6">
                  {relatedProducts.map(rp => (
                    <a href={`/products/${rp.slug}/`} class="group flex gap-4 items-center">
                      <div class="h-16 w-16 shrink-0 overflow-hidden rounded-xl border border-slate-100 bg-slate-50">
                        <img src={normalizeAsset(rp.data?.main_image || rp.data?.image)} class="h-full w-full object-cover transition duration-500 group-hover:scale-110" alt={rp.data?.title} onerror="this.src='/placeholder.webp'; this.onerror=null;" />
                      </div>
                      <div class="min-w-0">
                        <h4 class="text-sm font-black text-[#102033] line-clamp-2 group-hover:text-blue-600 transition">{rp.data?.displayName || rp.data?.title}</h4>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-1">{productCategory}</p>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </aside>
      </div>
    </section>

    <CTA />
  </main>
</Layout>

<script>
  const mainImg = document.getElementById('main-product-image') as HTMLImageElement;
  const thumbs = document.querySelectorAll('.gallery-thumb');
  thumbs.forEach(thumb => {
    thumb.addEventListener('click', () => {
      const src = thumb.getAttribute('data-full');
      if (src && mainImg) {
        mainImg.style.opacity = '0.5';
        mainImg.src = src;
        setTimeout(() => mainImg.style.opacity = '1', 100);
      }
    });
  });
</script>
