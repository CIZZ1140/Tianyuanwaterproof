                    const Icon = packagingIcons[index % packagingIcons.length];
                    return (
                      <article class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-white text-blue-700">
                          <Icon class="h-7 w-7" />
                        </div>
                        <h3 class="text-sm font-black uppercase leading-6 text-slate-950">{item.title}</h3>
                        {item.text && <p class="mt-3 text-sm font-medium leading-6 text-slate-600">{item.text}</p>}
                      </article>
                    );
                  })}
                </div>
              )}
              {loadingData.length > 0 && (
                <div class="overflow-hidden rounded-2xl border border-blue-200 bg-white">
                  <div class="bg-blue-700 px-5 py-4 text-white">
                    <div class="flex items-center gap-3">
                      <Truck class="h-5 w-5" />
                      <h3 class="text-sm font-black uppercase tracking-wide">Efficient Loading · Secure Packing · Global Delivery</h3>
                    </div>
                  </div>
                  <div class="divide-y divide-slate-200">
                    {loadingData.map((row) => (
                      <div class="grid gap-2 px-5 py-4 sm:grid-cols-[0.36fr_0.64fr]">
                        <div class="flex items-center gap-3 text-sm font-black text-blue-800">
                          <Box class="h-5 w-5" /> {row.label}
                        </div>
                        <p class="text-sm font-medium leading-7 text-slate-600">{row.value || "Contact us for loading details"}</p>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </div>
        </section>
      )
    }

    {
      supplyInfo.length > 0 && (
        <section class="mx-auto w-full max-w-[1680px] px-4 py-4 sm:px-6 lg:px-8">
          <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6 lg:p-8">
            <div class="mb-6 flex items-center gap-3"><Truck class="h-7 w-7 text-blue-700" />
              <h2 class="text-xl font-black text-slate-950 sm:text-2xl">Supply & Quality Assurance</h2>
            </div>
            <div class="grid gap-6 lg:grid-cols-[1fr_1fr]">
              <div class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-100">
                <img src="/assets/images/app-factory-floor.webp" alt="Tianyuan Waterproof Factory" loading="lazy" class="aspect-[4/3] w-full object-contain" onerror="this.src='/placeholder.webp'; this.onerror=null;" />
              </div>
              <div class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-100">
                <img src="/assets/images/app-production-line.webp" alt="Production Line" loading="lazy" class="aspect-[4/3] w-full object-contain" onerror="this.src='/placeholder.webp'; this.onerror=null;" />
              </div>
            </div>
            <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
              {supplyInfo.map((item, index) => {
                const icons = [Box, Package, ShieldCheck, MessageCircle];
                const Icon = icons[index % icons.length];
                return (
                  <article class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                    <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-white text-blue-700">
                      <Icon class="h-7 w-7" />
                    </div>
                    <h3 class="text-sm font-black uppercase leading-6 text-slate-950">{item.title}</h3>
                    {item.text && <p class="mt-3 text-sm font-medium leading-6 text-slate-600">{item.text}</p>}
                  </article>
                );
              })}
            </div>
          </div>
        </section>
      )
    }

    {
      (downloads.length > 0 || relatedProducts.length > 0) && (
        <section class="mx-auto grid w-full max-w-[1680px] gap-4 px-4 py-4 sm:px-6 lg:grid-cols-[0.86fr_1.14fr] lg:px-8">
          {downloads.length > 0 && (
            <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6 lg:p-8">
              <div class="mb-6 flex items-center gap-3"><h2 class="text-xl font-black text-slate-950 sm:text-2xl">Document Hub</h2>
              </div>
              <div class="grid gap-4 sm:grid-cols-2">
                {downloads.map((item) => {
                  const iconBg = item.title.toLowerCase().includes("safety") || item.title.toLowerCase().includes("sds") ? "bg-amber-50 text-amber-600" :
                    item.title.toLowerCase().includes("test") ? "bg-green-50 text-green-600" :
                    item.title.toLowerCase().includes("install") ? "bg-blue-50 text-blue-700" :
                    "bg-red-50 text-red-600";
                  const FileIcon = FileText;
                  return (
                    <article class="flex flex-col rounded-2xl border border-slate-200 bg-slate-50 p-5 transition hover:shadow-md">
                      <div class="mb-3 flex h-14 w-14 items-center justify-center rounded-xl {iconBg}">
                        <FileIcon class="h-7 w-7" />
                      </div>
                      <h3 class="text-sm font-black text-slate-950">{item.title}</h3>
                      {item.description && <p class="mt-2 text-sm leading-6 text-slate-500">{item.description}</p>}
                      <div class="mt-auto pt-4">
                        <p class="mb-3 text-xs font-bold uppercase tracking-wide text-slate-400">{item.type || "PDF"}</p>
                        <a href={isRealFile(item.href) ? item.href : contactHref} class="inline-flex items-center justify-center gap-2 rounded-xl border border-blue-200 bg-white px-5 py-2.5 text-xs font-black uppercase tracking-wide text-blue-800 transition hover:border-blue-400 hover:bg-blue-50 w-full">
                          {isRealFile(item.href) ? <><Download class="h-4 w-4" /> Download {item.type || "PDF"}</> : <><FileText class="h-4 w-4" /> Request by Email</>}
                        </a>
                      </div>
                    </article>
                  );
                })}
              </div>
            </div>
          )}
          {relatedProducts.length > 0 && (
            <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6 lg:p-8">
              <div class="mb-6 flex items-center gap-3"><h2 class="text-xl font-black text-slate-950 sm:text-2xl">Related Products</h2>
              </div>
              <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
                {relatedProducts.slice(0, 4).map((product) => (
                  <a href={product.href} class="group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-md">
                    {product.image ? (
                      <img src={product.image} alt={product.title} loading="lazy" class="aspect-[4/3] w-full bg-slate-100 object-cover" />
                    ) : (
                      <div class="flex aspect-[4/3] w-full items-center justify-center bg-slate-100 p-5 text-center text-sm font-bold text-slate-500">
                        <ImageIcon class="mr-2 h-5 w-5" /> Product image
                      </div>
                    )}
                    <div class="p-4">
                      <h3 class="text-sm font-black leading-6 text-slate-950 group-hover:text-blue-700">{product.title}</h3>
                      {product.description && <p class="mt-2 text-sm font-medium leading-6 text-slate-500">{product.description}</p>}
                      <p class="mt-4 inline-flex items-center gap-2 text-xs font-black uppercase tracking-wide text-blue-700">View Product <ArrowRight class="h-4 w-4" /></p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </section>
      )
    }

    {
      faqs.length > 0 && (
        <section class="mx-auto w-full max-w-[1680px] px-4 py-4 sm:px-6 lg:px-8">
          <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6 lg:p-8">
            <div class="mb-6 flex items-center gap-3"><h2 class="text-xl font-black text-slate-950 sm:text-2xl">FAQ</h2>
            </div>
            <div class="space-y-3">
              {faqs.map((item, index) => (
                <details name="product-faq" open={index === 0} class="group rounded-2xl border border-slate-200 bg-slate-50 p-5 open:border-blue-200 open:bg-white">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-6 text-sm font-black leading-6 text-slate-950 sm:text-base">
                    <span>{item.question}</span>
                    <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-blue-200 bg-white text-blue-700 transition group-open:rotate-180">
                      <ChevronDown class="h-4 w-4" />
                    </span>
                  </summary>
                  {item.answer && <p class="mt-4 max-w-5xl text-sm font-medium leading-7 text-slate-600">{item.answer}</p>}
                </details>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <section class="mx-auto w-full max-w-[1680px] px-4 py-6 sm:px-6 lg:px-8 lg:pb-12">
      <div class="overflow-hidden rounded-3xl border border-blue-200 bg-white shadow-sm">
        <div class="grid gap-6 p-6 sm:p-8 lg:grid-cols-[1fr_1.1fr] lg:items-center">
          <div>
            <div class="flex gap-5">
              <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-blue-50 text-blue-700">
                <Factory class="h-9 w-9" />
              </div>
              <div>
                <h2 class="text-2xl font-black tracking-tight text-slate-950 sm:text-3xl">Get Your Factory Quote in 24 Hours</h2>
                <p class="mt-3 max-w-3xl text-sm font-medium leading-7 text-slate-600 sm:text-base">Send us your reinforcement type, thickness, surface finish, quantity, and destination port — we return a competitive quotation within one business day.</p>
              </div>
            </div>
          </div>
          <div class="flex flex-col gap-3">
            <div class="grid gap-3 sm:grid-cols-2">
              <a href={contactHref} class="inline-flex items-center justify-center gap-2 rounded-xl bg-blue-700 px-5 py-3.5 text-sm font-black tracking-wide text-white shadow-sm transition hover:bg-blue-800">
                <FileText class="h-4 w-4" /> Send Inquiry
              </a>
              <a href={isRealFile(primaryDownload?.href) ? primaryDownload.href : contactHref} class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-blue-200 bg-blue-50 px-5 py-3.5 text-sm font-black tracking-wide text-blue-800 transition hover:border-blue-400 hover:bg-blue-100">
                <Download class="h-4 w-4" /> {isRealFile(primaryDownload?.href) ? 'Download TDS' : 'Request TDS'}
              </a>
              <a href={whatsappHref} class="inline-flex items-center justify-center gap-2 rounded-xl bg-emerald-600 px-5 py-3.5 text-sm font-black tracking-wide text-white shadow-sm transition hover:bg-emerald-700">
                <MessageCircle class="h-4 w-4" /> WhatsApp
              </a>
              <a href={contactHref} class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-slate-200 bg-white px-5 py-3.5 text-sm font-black tracking-wide text-slate-700 transition hover:border-slate-300 hover:bg-slate-50">
                <Package class="h-4 w-4" /> Request Sample
              </a>
            </div>
            <p class="text-center text-xs font-medium text-slate-400">Or email: sales@tyuanwaterproof.com</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
