---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import {
  ArrowRight,
  Box,
  Boxes,
  Building2,
  ChevronDown,
  ClipboardCheck,
  Download,
  Droplets,
  Factory,
  FileText,
  Flame,
  FlaskConical,
  Hammer,
  Image as ImageIcon,
  Layers,
  Leaf,
  MessageCircle,
  Package,
  Ruler,
  ShieldCheck,
  Sun,
  TrainTrack,
  Truck,
  Warehouse,
  Waves,
  Wrench,
  Snowflake,
} from "lucide-astro";

/**
 * Technical Table Strategy:
 * If all rows lack specialized B2B fields (unit, standard, requirement),
 * we switch to a simplified 2-column mode to avoid empty '-' dashes.
 */

function normalizeAsset(value: any) {
  if (!value) return "";
  if (typeof value === "string") return value;
  if (typeof value?.src === "string") return value.src;
  if (typeof value?.url === "string") return value.url;
  return "";
}

function normalizeString(value: any, fallback = "") {
  if (typeof value === "string" && value.trim()) return value.trim();
  if (typeof value === "number") return String(value);
  return fallback;
}

function normalizeTagList(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item) => {
      if (!item) return "";
      if (typeof item === "string") return item;
      return item.title ?? item.label ?? item.name ?? item.value ?? "";
    })
    .map((item) => String(item).trim())
    .filter(Boolean);
}

function normalizeRows(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item) => {
      if (!item) return null;
      if (typeof item === "string") return { label: item, value: "", unit: "", standard: "", requirement: "" };
      return {
        label: item.label ?? item.name ?? item.item ?? item.title ?? item.test_item ?? "",
        value: item.value ?? item.result ?? item.notes ?? item.detail ?? item.text ?? "",
        unit: item.unit ?? "",
        standard: item.standard ?? item.test_standard ?? item.testMethod ?? item.test_method ?? item.method ?? "",
        requirement: item.requirement ?? item.class ?? item.requirement_class ?? item.requirement_or_class ?? "",
      };
    })
    .filter((item) => item && (item.label || item.value));
}

function normalizeCards(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item) => {
      if (!item) return null;
      if (typeof item === "string") return { title: item, text: "", image: "", href: "" };
      return {
        title: item.title ?? item.label ?? item.name ?? "",
        text: item.text ?? item.description ?? item.value ?? item.detail ?? "",
        image: normalizeAsset(item.image ?? item.main_image ?? item.img),
        icon: item.icon ?? "",
        href: item.href ?? item.url ?? item.link ?? "",
      };
    })
    .filter((item) => item && (item.title || item.text || item.image));
}

const ICON_MAP: Record<string, any> = {
  box: Box,
  boxes: Boxes,
  building: Building2,
  clipboard: ClipboardCheck,
  droplets: Droplets,
  factory: Factory,
  flame: Flame,
  flask: FlaskConical,
  hammer: Hammer,
  layers: Layers,
  leaf: Leaf,
  package: Package,
  ruler: Ruler,
  shield: ShieldCheck,
  sun: Sun,
  snowflake: Snowflake,
  traintrack: TrainTrack,
  truck: Truck,
  warehouse: Warehouse,
  waves: Waves,
  wrench: Wrench,
};

function getCardIcon(item: any, fallbackIcons: any[], index: number) {
  if (item.icon && ICON_MAP[item.icon.toLowerCase()]) {
    return ICON_MAP[item.icon.toLowerCase()];
  }
  return fallbackIcons[index % fallbackIcons.length];
}

function normalizeApplicationGuide(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item, index) => {
      if (!item) return null;
      if (typeof item === "string") {
        return {
          title: `Step ${index + 1}`,
          text: item,
          image: "",
          href: "",
        };
      }
      return {
        title: item.title ?? item.label ?? item.name ?? `Step ${index + 1}`,
        text: item.text ?? item.description ?? item.value ?? item.detail ?? "",
        image: normalizeAsset(item.image ?? item.main_image ?? item.img),
        href: item.href ?? item.url ?? item.link ?? "",
      };
    })
    .filter((item) => item && (item.title || item.text));
}

function normalizeGallery(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item) => {
      if (!item) return null;
      if (typeof item === "string") return { image: item, title: "Product Detail" };
      return {
        image: normalizeAsset(item.image ?? item.src ?? item.url),
        title: item.title ?? item.label ?? item.name ?? "Product Detail",
      };
    })
    .filter((item) => item && item.image);
}

function normalizeDownloads(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item) => {
      if (!item) return null;
      if (typeof item === "string") return { title: item, description: "", type: "PDF", href: "" };
      return {
        title: item.title ?? item.label ?? item.name ?? "Technical Document",
        description: item.description ?? item.text ?? item.detail ?? "",
        type: item.type ?? item.format ?? "PDF",
        href: item.href ?? item.url ?? item.file ?? "",
      };
    })
    .filter((item) => item && item.title);
}

function normalizeRelatedProducts(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item) => {
      if (!item) return null;
      return {
        title: item.title ?? item.name ?? "",
        description: item.description ?? item.text ?? item.summary ?? "",
        image: normalizeAsset(item.image ?? item.main_image ?? item.img),
        href: item.href ?? item.url ?? item.link ?? "#",
      };
    })
    .filter((item) => item && item.title);
}

function normalizeFaqs(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item) => {
      if (!item) return null;
      return {
        question: item.question ?? item.title ?? item.q ?? "",
        answer: item.answer ?? item.text ?? item.a ?? "",
      };
    })
    .filter((item) => item && item.question);
}

function getSpecValue(rows: any[], keywords: string[]) {
  const target = rows.find((row) => {
    const label = String(row?.label ?? "").toLowerCase();
    return keywords.some((keyword) => label.includes(keyword.toLowerCase()));
  });
  return target?.value ?? "";
}

function buildFallbackHeroTags(specTable: any[]) {
  const standard = getSpecValue(specTable, ["standard"]);
  const thickness = getSpecValue(specTable, ["thickness", "thick"]);
  const width = getSpecValue(specTable, ["width"]);
  const method = getSpecValue(specTable, ["application method", "method"]);
  const oem = getSpecValue(specTable, ["oem", "customization"]);
  return [standard, thickness, width, method, oem]
    .map((item) => String(item).trim())
    .filter(Boolean)
    .slice(0, 6);
}

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((entry) => ({
    params: {
      slug: (entry?.slug ?? entry?.id ?? "").replace(/\.mdx?$/, "").replace(/\/index$/, ""),
    },
    props: {
      entry,
    },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = (entry.data ?? {}) as Record<string, any>;

const title = normalizeString(data.title, "Product Details");
const pageTitle = title.length > 60 ? title : `${title} | TY-SHIELD™`;

const productCategory = normalizeString(data.product_category ?? data.category, "Waterproofing Membrane");
const mainImage = normalizeAsset(data.main_image);
const gallery = normalizeGallery(data.gallery ?? []);

// Default to the first gallery image if available, otherwise use mainImage
const initialImage = gallery.length > 0 ? gallery[0].image : mainImage;

const specTable = normalizeRows(data.spec_table ?? []);
const quickFacts = normalizeCards(data.quick_facts ?? data.quickFacts ?? data.highlights ?? []);
const features = normalizeCards(data.features ?? []);
const applications = normalizeCards(data.applications ?? data.application ?? data.application_areas ?? data.where_to_use ?? []);
const technicalData = normalizeRows(data.technical_data ?? data.technicalData ?? data.test_data ?? []);

// New B2B fields
const configurations = Array.isArray(data.configurations) ? data.configurations : [];
const structure = data.structure ?? null;
const supplyInfo = normalizeCards(data.supply_info ?? data.supplyInfo ?? []);

const isSimpleTechnicalTable = technicalData.every(row => !row.unit && !row.standard && !row.requirement);

const applicationGuide = normalizeApplicationGuide(data.application_guide ?? data.applicationGuide ?? data.installation_steps ?? data.installation ?? []);
const installationEssentials = Array.isArray(data.installation_essentials) ? data.installation_essentials : [];
const packaging = normalizeCards(data.packaging ?? data.packaging_oem ?? data.oem_packaging ?? []);
const loadingData = normalizeRows(data.loading_data ?? data.loadingData ?? data.container_loading ?? []);
const downloads = normalizeDownloads(data.downloads ?? []);
const allProducts = await getCollection("products");

const relatedProducts = normalizeRelatedProducts(data.related_products ?? []).map((rp) => {
  const slug = rp.href.replace(/^\/products\//, "").replace(/\/$/, "");
  const matched = allProducts.find((p) => {
    const pSlug = (p.slug ?? p.id ?? "").replace(/\.mdx?$/, "").replace(/\/index$/, "");
    return pSlug === slug;
  });

  if (matched) {
    return {
      ...rp,
      title: matched.data.displayName || matched.data.title || rp.title,
      image: normalizeAsset(matched.data.main_image || matched.data.image || rp.image),
    };
  }
  return rp;
});
const faqs = normalizeFaqs(data.faqs ?? data.faq ?? []);

const explicitHeroTags = normalizeTagList(data.hero_tags ?? []);
const fallbackHeroTags = buildFallbackHeroTags(specTable);
const heroTags = explicitHeroTags.length > 0 ? explicitHeroTags : fallbackHeroTags;

const heroDescription = normalizeString(
  data.hero_description ?? data.short_description ?? data.summary,
  `Factory supplied ${title.toLowerCase()} for distributors, contractors, importers, and building material suppliers.`
);

const standardValue = getSpecValue(specTable, ["standard"]);
const thicknessValue = getSpecValue(specTable, ["thickness", "thick"]);
const widthValue = getSpecValue(specTable, ["width"]);
const lengthValue = getSpecValue(specTable, ["length"]);
const rollSizeValue = widthValue && lengthValue ? `${widthValue} × ${lengthValue}` : widthValue || lengthValue;

const heroSpecCards = [
  { label: "Reinforcement Options", value: getSpecValue(specTable, ["reinforcement options"]), icon: Boxes },
  { label: "Typical Applications", value: getSpecValue(specTable, ["typical applications"]), icon: Factory },
  { label: "Standard Roll Size", value: getSpecValue(specTable, ["standard roll size"]), icon: Ruler },
].filter((item) => item.value);

const rawBody = typeof entry.body === "string" ? entry.body : "";
const hasBody = rawBody.trim().length > 0;
const hasOverview = hasBody || quickFacts.length > 0;
const primaryDownload = downloads.find((item) => item.href && item.title.toLowerCase().includes("tds")) ?? downloads.find((item) => item.href);
const contactHref = normalizeString(data.inquiry_url, "/contact/");
const whatsappHref = normalizeString(data.whatsapp_url, "https://wa.me/8615263640998");

const isRealFile = (url: string) => url && url !== "#" && (url.startsWith("http") || url.startsWith("/assets/") || url.endsWith(".pdf"));

const quickFactIcons = [Layers, Droplets, Boxes, Package];
const applicationIcons = [Factory, Box, Truck, Wrench, Droplets, ShieldCheck];
const benefitIcons = [ShieldCheck, Ruler, Snowflake, Sun];
const installationIcons = [Hammer, Droplets, Ruler, Flame, Package, ClipboardCheck];
const packagingIcons = [Package, Truck, Box, Factory, FileText, FlaskConical];

// --- SEO Structured Data (JSON-LD) ---
const productSlug = (entry?.slug ?? entry?.id ?? "").replace(/\.mdx?$/, "").replace(/\/index$/, "");
const productSku = data.sku ?? `TY-${productSlug.slice(0, 20).toUpperCase().replace(/-/g, "")}`;
const productMpn = data.mpn ?? data.model ?? getSpecValue(specTable, ["standard"]);
const productGtin = data.gtin ?? data.upc ?? data.ean ?? null;

const hasPrice = data.price && data.price !== "0" && data.price !== 0;

const jsonLd: Record<string, any> = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": title,
  "image": [mainImage, ...gallery.map(item => item.image)].filter(Boolean),
  "description": heroDescription,
  "sku": productSku,
  "brand": {
    "@type": "Brand",
    "name": "Tianyuan Waterproof"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "Weifang Tianyuan Waterproof Material Co., Ltd.",
    "url": "https://www.tyuanwaterproof.com"
  },
  "additionalProperty": specTable.map(row => ({
    "@type": "PropertyValue",
    "name": row.label,
    "value": row.value
  }))
};

// Only include Offer when a real price is provided; B2B inquiry-based pages skip this
if (hasPrice) {
  jsonLd["offers"] = {
    "@type": "AggregateOffer",
    "priceCurrency": data.price_currency ?? "USD",
    "availability": data.availability ?? "https://schema.org/InStock",
    "url": Astro.url.href,
    "itemCondition": "https://schema.org/NewCondition",
    "offerCount": "1",
    "lowPrice": String(data.price),
    "highPrice": String(data.price),
    "description": "Contact factory for wholesale pricing and OEM quotation.",
  };
}

if (productMpn) jsonLd["mpn"] = productMpn;
if (productGtin) jsonLd["gtin"] = productGtin;

const faqJsonLd = faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;

const imageFitClass = data.image_fit === 'cover' ? "object-cover" : "object-contain";

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Products", href: "/products/" },
  { label: productCategory, href: `/categories/${entry.data.category}/` },
];
---

<Layout title={pageTitle} description={heroDescription} ogImage={mainImage}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  {faqJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />}
  <main class="bg-slate-50 text-slate-950">
    <!-- Breadcrumb -->
    <nav class="mx-auto w-full max-w-[1680px] px-4 pt-4 pb-2 sm:px-6 lg:px-8" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-1 text-sm">
        {breadcrumbItems.map((item, i) => (
          <li class="flex items-center gap-1">
            {i > 0 && <span class="text-slate-400 select-none">/</span>}
            {item.href ? (
              <a href={item.href} class="font-medium text-slate-500 transition hover:text-blue-700">{item.label}</a>
            ) : (
              <span class="font-bold text-slate-900">{item.label}</span>
            )}
          </li>
        ))}
      </ol>
    </nav>
    <section class="mx-auto w-full max-w-[1680px] px-4 py-4 sm:px-6 lg:px-8 lg:py-8">
      <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6 lg:p-8">
        <div class="grid gap-8 lg:grid-cols-[0.7fr_1.3fr] lg:items-center">
          <div>
            <div class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 flex items-center justify-center">
              {
                initialImage ? (
                  <img 
                    id="main-product-image"
                    src={initialImage} 
                    alt={title} 
                    loading="eager" 
                    class={`max-h-[420px] w-full ${imageFitClass} transition-opacity duration-300`} 
                    onerror="this.src='/placeholder.webp'; this.onerror=null;"
                  />
                ) : (
                  <div class="flex aspect-[4/3] h-full w-full items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200 p-8 text-center text-sm font-semibold text-slate-500">
                    <ImageIcon class="mr-2 h-5 w-5" /> Product image
                  </div>
                )
              }
            </div>
            {
              gallery.length > 0 && (
                <div class="mt-4 grid gap-2 sm:grid-cols-4">
                  {gallery.slice(0, 4).map((item) => (
                    <button 
                      class="gallery-thumb group rounded-2xl border-2 border-slate-200 bg-white shadow-sm transition hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-500 active:border-blue-500 active:bg-blue-50"
                      data-full={item.image}
                    >
                      <img 
                        src={item.image} 
                        alt={item.title} 
                        loading="lazy" 
                        class="aspect-[4/3] w-full rounded-t-xl bg-white object-contain p-2" 
                        onerror="this.src='/placeholder.webp'; this.onerror=null;"
                      />
                      <p class="px-1.5 py-2 text-center text-[11px] font-bold leading-tight text-slate-700 sm:text-xs line-clamp-2 group-[.active]:text-blue-700">{item.title}</p>
                    </button>
                  ))}
                </div>
              )
            }
          </div>

          <script>
            // Simple logic for image gallery switching
            const mainImg = document.getElementById('main-product-image') as HTMLImageElement;
            const thumbs = document.querySelectorAll('.gallery-thumb');

            thumbs.forEach(thumb => {
              const handleSwitch = () => {
                const newSrc = thumb.getAttribute('data-full');
                if (newSrc && mainImg && mainImg.src !== newSrc) {
                  // Remove active from all thumbs
                  thumbs.forEach(t => t.classList.remove('active'));
                  // Add active to current
                  thumb.classList.add('active');
                  // Fade out
                  mainImg.style.opacity = '0';
                  
                  setTimeout(() => {
                    mainImg.src = newSrc;
                    // Fade in
                    mainImg.style.opacity = '1';
                  }, 200);
                }
              };

              // Click for mobile/standard
              thumb.addEventListener('click', handleSwitch);
              // Hover for desktop quick view
              thumb.addEventListener('mouseenter', handleSwitch);
            });

            // Set first thumbnail as active on page load
            if (thumbs.length > 0) {
              thumbs[0].classList.add('active');
            }
          </script>

          <div>
            <p class="mb-3 text-sm font-bold uppercase tracking-[0.28em] text-blue-700">{productCategory}</p>
            <h1 class="max-w-4xl text-3xl font-black tracking-tight text-slate-950 sm:text-4xl lg:text-5xl">{title}</h1>
            <p class="mt-5 max-w-3xl text-base leading-8 text-slate-600 sm:text-lg">{heroDescription}</p>

            {
              heroTags.length > 0 && (
                <div class="mt-6 flex flex-wrap gap-3">
                  {heroTags.slice(0, 6).map((tag) => (
                    <span class="rounded-full border border-blue-100 bg-blue-50 px-4 py-2 text-sm font-bold text-blue-800">{tag}</span>
                  ))}
                </div>
              )
            }
            {
              heroSpecCards.length > 0 && (
                <div class="mt-6 grid gap-3 sm:grid-cols-3">
                  {heroSpecCards.map((item) => {
                    const Icon = item.icon;
                    return (
                        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                          <div class="mb-3 flex items-center gap-2 text-blue-700">
                            <Icon class="h-5 w-5" />
                            <p class="text-[10px] font-black uppercase tracking-[0.15em] text-blue-800/80">{item.label}</p>
                          </div>
                          {item.value.split(' | ').map((val: string) => (
                            <p class="text-sm font-bold leading-6 text-slate-950">{val}</p>
                          ))}
                        </div>
                    );
                  })}
                </div>
              )
            }
            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap items-center">
              <a href={contactHref} class="inline-flex items-center justify-center rounded-xl bg-blue-700 px-8 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-blue-800">
                Get Factory Quote
              </a>
              <a href={whatsappHref} class="inline-flex items-center justify-center gap-2 rounded-xl border border-emerald-200 bg-emerald-50 px-6 py-3 text-sm font-bold text-emerald-700 transition hover:border-emerald-300 hover:bg-emerald-100">
                <MessageCircle class="h-4 w-4" /> Chat on WhatsApp
              </a>
              <a href={isRealFile(primaryDownload?.href) ? primaryDownload.href : contactHref} class="inline-flex items-center justify-center gap-2 rounded-xl border border-blue-200 bg-blue-50 px-6 py-3 text-sm font-bold text-blue-800 transition hover:border-blue-300 hover:bg-blue-100">
                <FileText class="h-4 w-4" /> Request TDS
              </a>
            </div>
            <p class="mt-4 text-sm leading-6 text-slate-500 font-medium italic">For a project-specific quote, send your membrane thickness, reinforcement, surface finish, application, and destination port.</p>
            
            <div class="mt-8 border-t border-slate-100 pt-6">
              <div class="flex flex-wrap gap-x-6 gap-y-3 text-[11px] font-black uppercase tracking-widest text-slate-500">
                <span class="flex items-center gap-2"><Factory class="h-3.5 w-3.5" /> Factory Direct Supply</span>
                <span class="flex items-center gap-2"><ShieldCheck class="h-3.5 w-3.5" /> OEM Private Label</span>
                <span class="flex items-center gap-2"><FileText class="h-3.5 w-3.5" /> Technical Document Support</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {
      specTable.length > 0 && (
        <section class="mx-auto w-full max-w-[1680px] px-4 py-4 sm:px-6 lg:px-8">
          <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6 lg:p-8">
            <div class="mb-6 flex items-center gap-3">
              <h2 class="text-xl font-black text-slate-950 sm:text-2xl">Quick Specifications</h2>
            </div>
            <div class="grid overflow-hidden rounded-2xl border border-slate-200 lg:grid-cols-2">
              {specTable.map((row) => (
                <div class="grid grid-cols-[0.42fr_0.58fr] border-b border-slate-200 last:border-b-0 lg:[&:nth-last-child(-n+2)]:border-b-0">
                  <div class="flex items-center justify-center border-r border-slate-200 bg-slate-50 px-4 py-4 text-center text-sm font-black text-slate-800">{row.label}</div>
                  <div class="flex items-center px-4 py-4 text-sm font-medium leading-7 text-slate-600">{row.value || "Contact us for details"}</div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )
    }

    {
      applications.length > 0 && (
        <section class="mx-auto w-full max-w-[1680px] px-4 py-4 sm:px-6 lg:px-8">
          <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6 lg:p-8">
            <div class="mb-6 flex items-center gap-3"><h2 class="text-xl font-black text-slate-950 sm:text-2xl">Applications</h2>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
              {applications.slice(0, 4).map((item, index) => {
                const Icon = getCardIcon(item, applicationIcons, index);
                return (
                  <article class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-center">
                    <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl border border-blue-100 bg-white text-blue-700">
                      <Icon class="h-7 w-7" />
                    </div>
                    <h3 class="text-sm font-black leading-6 text-slate-950">{item.title}</h3>
                    {item.text && <p class="mt-3 text-sm font-medium leading-6 text-slate-600">{item.text}</p>}
                  </article>
                );
              })}
            </div>
          </div>
        </section>
      )
    }

    {
      true && (
        <section class="mx-auto w-full max-w-[1680px] px-4 py-4 sm:px-6 lg:px-8">
          <div class="rounded-3xl border border-l-amber-200 bg-white p-4 shadow-sm sm:p-6 lg:p-8">
