---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import CTA from "../../components/CTA.astro";
import {
  ArrowRight,
  Box,
  Boxes,
  Building2,
  ChevronDown,
  ClipboardCheck,
  Download,
  Droplets,
  Factory,
  FileText,
  Flame,
  FlaskConical,
  Hammer,
  Image as ImageIcon,
  Layers,
  Leaf,
  MessageCircle,
  Package,
  Ruler,
  ShieldCheck,
  Sun,
  TrainTrack,
  Truck,
  Warehouse,
  Waves,
  Wrench,
  Snowflake,
} from "lucide-astro";

function normalizeAsset(value: any) {
  if (!value) return "";
  if (typeof value === "string") return value;
  if (typeof value?.src === "string") return value.src;
  if (typeof value?.url === "string") return value.url;
  return "";
}

function normalizeString(value: any, fallback = "") {
  if (typeof value === "string" && value.trim()) return value.trim();
  if (typeof value === "number") return String(value);
  return fallback;
}

function normalizeTagList(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item) => {
      if (!item) return "";
      if (typeof item === "string") return item;
      return item.title ?? item.label ?? item.name ?? item.value ?? "";
    })
    .map((item) => String(item).trim())
    .filter(Boolean);
}

function normalizeRows(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item) => {
      if (!item) return null;
      if (typeof item === "string") return { label: item, value: "", unit: "", standard: "", requirement: "" };
      return {
        label: item.label ?? item.name ?? item.item ?? item.title ?? item.test_item ?? "",
        value: item.value ?? item.result ?? item.notes ?? item.detail ?? item.text ?? "",
        unit: item.unit ?? "",
        standard: item.standard ?? item.test_standard ?? item.testMethod ?? item.test_method ?? item.method ?? "",
        requirement: item.requirement ?? item.class ?? item.requirement_class ?? item.requirement_or_class ?? "",
      };
    })
    .filter((item) => item && (item.label || item.value));
}

function normalizeCards(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item) => {
      if (!item) return null;
      if (typeof item === "string") return { title: item, text: "", image: "", href: "" };
      return {
        title: item.title ?? item.label ?? item.name ?? "",
        text: item.text ?? item.description ?? item.value ?? item.detail ?? "",
        image: normalizeAsset(item.image ?? item.main_image ?? item.img),
        icon: item.icon ?? "",
        href: item.href ?? item.url ?? item.link ?? "",
      };
    })
    .filter((item) => item && (item.title || item.text || item.image));
}

const ICON_MAP: Record<string, any> = {
  box: Box,
  boxes: Boxes,
  building: Building2,
  clipboard: ClipboardCheck,
  droplets: Droplets,
  factory: Factory,
  flame: Flame,
  flask: FlaskConical,
  hammer: Hammer,
  layers: Layers,
  leaf: Leaf,
  package: Package,
  ruler: Ruler,
  shield: ShieldCheck,
  sun: Sun,
  snowflake: Snowflake,
  traintrack: TrainTrack,
  truck: Truck,
  warehouse: Warehouse,
  waves: Waves,
  wrench: Wrench,
};

function getCardIcon(item: any, fallbackIcons: any[], index: number) {
  if (item.icon && ICON_MAP[item.icon.toLowerCase()]) {
    return ICON_MAP[item.icon.toLowerCase()];
  }
  return fallbackIcons[index % fallbackIcons.length];
}

function normalizeApplicationGuide(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item, index) => {
      if (!item) return null;
      if (typeof item === "string") {
        return { title: `Step ${index + 1}`, text: item, image: "", href: "" };
      }
      return {
        title: item.title ?? item.label ?? item.name ?? `Step ${index + 1}`,
        text: item.text ?? item.description ?? item.value ?? item.detail ?? "",
        image: normalizeAsset(item.image ?? item.main_image ?? item.img),
        href: item.href ?? item.url ?? item.link ?? "",
      };
    })
    .filter((item) => item && (item.title || item.text));
}

function normalizeGallery(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item) => {
      if (!item) return null;
      if (typeof item === "string") return { image: item, title: "Product Detail" };
      return {
        image: normalizeAsset(item.image ?? item.src ?? item.url),
        title: item.title ?? item.label ?? item.name ?? "Product Detail",
      };
    })
    .filter((item) => item && item.image);
}

function normalizeDownloads(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item) => {
      if (!item) return null;
      if (typeof item === "string") return { title: item, description: "", type: "PDF", href: "" };
      return {
        title: item.title ?? item.label ?? item.name ?? "Technical Document",
        description: item.description ?? item.text ?? item.detail ?? "",
        type: item.type ?? item.format ?? "PDF",
        href: item.href ?? item.url ?? item.file ?? "",
      };
    })
    .filter((item) => item && item.title);
}

function normalizeRelatedProducts(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item) => {
      if (!item) return null;
      return {
        title: item.title ?? item.name ?? "",
        description: item.description ?? item.text ?? item.summary ?? "",
        image: normalizeAsset(item.image ?? item.main_image ?? item.img),
        href: item.href ?? item.url ?? item.link ?? "#",
      };
    })
    .filter((item) => item && item.title);
}

function normalizeFaqs(value: any) {
  if (!Array.isArray(value)) return [];
  return value
    .map((item) => {
      if (!item) return null;
      return {
        question: item.question ?? item.title ?? item.q ?? "",
        answer: item.answer ?? item.text ?? item.a ?? "",
      };
    })
    .filter((item) => item && item.question);
}

function getSpecValue(rows: any[], keywords: string[]) {
  const target = rows.find((row) => {
    const label = String(row?.label ?? "").toLowerCase();
    return keywords.some((keyword) => label.includes(keyword.toLowerCase()));
  });
  return target?.value ?? "";
}

function buildFallbackHeroTags(specTable: any[]) {
  return [
    getSpecValue(specTable, ["standard"]),
    getSpecValue(specTable, ["thickness", "thick"]),
    getSpecValue(specTable, ["width"]),
    getSpecValue(specTable, ["application method", "method"])
  ].map(i => String(i).trim()).filter(Boolean).slice(0, 6);
}

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((entry) => ({
    params: { slug: (entry?.slug ?? entry?.id ?? "").replace(/\.mdx?$/, "").replace(/\/index$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = (entry.data ?? {}) as Record<string, any>;

const title = normalizeString(data.title, "Product Details");
const pageTitle = title.length > 60 ? title : `${title} | TY-SHIELD™`;
const productCategory = normalizeString(data.product_category ?? data.category, "Waterproofing Membrane");
const mainImage = normalizeAsset(data.main_image);
const gallery = normalizeGallery(data.gallery ?? []);
const initialImage = gallery.length > 0 ? gallery[0].image : mainImage;
const specTable = normalizeRows(data.spec_table ?? []);
const quickFacts = normalizeCards(data.quick_facts ?? data.quickFacts ?? []);
const features = normalizeCards(data.features ?? []);
const applications = normalizeCards(data.applications ?? data.application ?? data.application_areas ?? []);
const technicalData = normalizeRows(data.technical_data ?? data.technicalData ?? []);
const packaging = normalizeCards(data.packaging ?? []);
const loadingData = normalizeRows(data.loading_data ?? []);
const downloads = normalizeDownloads(data.downloads ?? []);

const heroTags = normalizeTagList(data.hero_tags ?? []).length > 0 ? normalizeTagList(data.hero_tags ?? []) : buildFallbackHeroTags(specTable);
const heroDescription = normalizeString(data.hero_description ?? data.short_description, `Factory supplied ${title.toLowerCase()} for B2B global supply.`);
const contactHref = "/contact/";
const whatsappHref = "https://wa.me/8615263640998";
const isRealFile = (url: string) => url && url !== "#" && (url.startsWith("http") || url.startsWith("/assets/") || url.endsWith(".pdf"));

const heroSpecCards = [
  { label: "Reinforcement Options", value: getSpecValue(specTable, ["reinforcement options"]), icon: Boxes },
  { label: "Typical Applications", value: getSpecValue(specTable, ["typical applications"]), icon: Factory },
  { label: "Standard Roll Size", value: getSpecValue(specTable, ["standard roll size"]), icon: Ruler },
].filter((item) => item.value);

const rawBody = typeof entry.body === "string" ? entry.body : "";
const hasBody = rawBody.trim().length > 0;
const hasOverview = hasBody || quickFacts.length > 0;
const primaryDownload = downloads.find((item) => item.href && item.title.toLowerCase().includes("tds")) ?? downloads.find((item) => item.href);

const applicationIcons = [Factory, Box, Truck, Wrench, Droplets, ShieldCheck];
const benefitIcons = [ShieldCheck, Ruler, Snowflake, Sun];
const installationIcons = [Hammer, Droplets, Ruler, Flame, Package, ClipboardCheck];
const packagingIcons = [Package, Truck, Box, Factory, FileText, FlaskConical];

const isSbsOrApp = ["sbs-bitumen-waterproofing-membrane-manufacturer", "app-modified-bitumen-waterproofing-membrane-manufacturer"].includes(entry.slug);

// --- B2B SEO / GEO ENGINE INJECTION (Hidden) ---
const productJsonLd = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": title,
  "image": [mainImage],
  "description": heroDescription,
  "brand": { "@type": "Brand", "name": "Tianyuan Waterproof" },
  "sku": `TY-${entry.slug.toUpperCase()}`,
  "additionalProperty": specTable.map(row => ({
    "@type": "PropertyValue",
    "name": row.label,
    "value": row.value
  }))
};
const faqs = Array.isArray(data.faqs) ? data.faqs : [];
const faqJsonLd = faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f: any) => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
} : null;
---

<Layout title={pageTitle} description={heroDescription} ogImage={mainImage}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />}

  <main class="bg-slate-50 text-slate-950 pb-12">
    <!-- 1. Breadcrumb -->
    <nav class="mx-auto w-full max-w-[1680px] px-4 pt-4 pb-2 sm:px-6 lg:px-8" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-1 text-sm font-medium text-slate-500">
        <li><a href="/" class="hover:text-blue-700 transition">Home</a></li>
        <li class="mx-1">/</li>
        <li><a href="/products/" class="hover:text-blue-700 transition">Products</a></li>
        <li class="mx-1">/</li>
        <li class="font-bold text-slate-900">{title}</li>
      </ol>
    </nav>

    <!-- 2. Hero Card (White Background Design) -->
    <section class="mx-auto w-full max-w-[1680px] px-4 py-4 sm:px-6 lg:px-8 lg:py-8">
      <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6 lg:p-10">
        <div class="grid gap-12 lg:grid-cols-[0.7fr_1.3fr] lg:items-center">
          <div>
            <div class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 flex items-center justify-center relative">
              <img id="main-product-image" src={initialImage} alt={title} class="max-h-[440px] w-full object-contain transition-opacity duration-300" />
            </div>
            {gallery.length > 0 && (
              <div class="mt-4 grid gap-2 sm:grid-cols-4">
                {gallery.slice(0, 4).map((item) => (
                  <button class="gallery-thumb group rounded-2xl border-2 border-slate-200 bg-white shadow-sm transition hover:border-blue-400" data-full={item.image}>
                    <img src={item.image} alt={item.title} class="aspect-[4/3] w-full rounded-xl bg-white object-cover" />
                    <p class="px-1.5 py-2 text-center text-[10px] font-bold text-slate-700 line-clamp-2">{item.title}</p>
                  </button>
                ))}
              </div>
            )}
          </div>
          <div>
            <p class="mb-4 text-xs font-bold uppercase tracking-[0.25em] text-blue-700">{productCategory}</p>
            <h1 class="text-3xl font-black text-slate-950 sm:text-4xl lg:text-5xl tracking-tight leading-tight">{title}</h1>
            <p class="mt-6 text-base leading-8 text-slate-600 sm:text-lg">{heroDescription}</p>

            <div class="mt-6 flex flex-wrap gap-3">
              {heroTags.map(tag => <span class="rounded-full border border-blue-100 bg-blue-50 px-4 py-1.5 text-sm font-bold text-blue-800">{tag}</span>)}
            </div>

            {heroSpecCards.length > 0 && (
              <div class="mt-8 grid gap-4 sm:grid-cols-3">
                {heroSpecCards.map((item) => {
                  const Icon = item.icon;
                  return (
                    <div class="rounded-2xl border border-slate-100 bg-slate-50/80 p-4">
                      <div class="mb-3 flex items-center gap-2 text-blue-700">
                        <Icon class="h-4 w-4" /><p class="text-[10px] font-black uppercase tracking-widest">{item.label}</p>
                      </div>
                      <p class="text-sm font-bold text-slate-950 leading-6">{item.value}</p>
                    </div>
                  );
                })}
              </div>
            )}

            <div class="mt-10 flex flex-col items-center gap-3 sm:flex-row">
              <a href={contactHref} class="inline-flex w-full items-center justify-center rounded-xl bg-blue-700 px-10 py-3.5 text-sm font-black text-white shadow-xl shadow-blue-700/20 transition hover:bg-blue-800 sm:w-auto">Get Factory Quote</a>
              <a href={whatsappHref} target="_blank" class="inline-flex w-full items-center justify-center gap-2 rounded-xl border-2 border-emerald-100 bg-emerald-50 px-8 py-3.5 text-sm font-black text-emerald-700 transition hover:bg-emerald-100 sm:w-auto">Chat on WhatsApp</a>
              <a href={isRealFile(primaryDownload?.href) ? primaryDownload.href : contactHref} class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-blue-200 bg-white px-8 py-3.5 text-sm font-black text-blue-800 transition hover:bg-blue-50 sm:w-auto">Request TDS</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. Specifications & Analysis -->
    <section class="mx-auto w-full max-w-[1680px] px-4 py-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
        <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-8 uppercase">Quick Specifications</h2>
        <div class="grid overflow-hidden rounded-2xl border border-slate-200 lg:grid-cols-2">
          {specTable.map(row => (
            <div class="grid grid-cols-[0.4fr_0.6fr] border-b border-slate-200 last:border-b-0 lg:[&:nth-last-child(-n+2)]:border-b-0">
              <div class="bg-slate-50 p-4 text-sm font-black text-slate-800 border-r border-slate-200 flex items-center justify-center text-center">{row.label}</div>
              <div class="p-4 text-sm font-medium text-slate-600 leading-relaxed flex items-center">{row.value}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {isSbsOrApp && (
      <section class="mx-auto w-full max-w-[1680px] px-4 py-4 sm:px-6 lg:px-8">
        <div class="rounded-3xl border border-l-amber-200 bg-white p-6 sm:p-10 shadow-sm">
          <div class="flex items-center gap-3 mb-8">
            <Sun class="h-7 w-7 text-amber-600" /><Snowflake class="h-7 w-7 text-blue-600" />
            <h2 class="text-xl font-black text-slate-950 sm:text-2xl">APP vs SBS Selection Guide</h2>
          </div>
          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-left text-sm border-collapse">
              <thead class="bg-slate-50">
                <tr class="border-b border-slate-200">
                  <th class="px-5 py-4 font-black">Property</th>
                  <th class="px-5 py-4 font-black bg-amber-50 text-amber-700">APP (Plastomeric)</th>
                  <th class="px-5 py-4 font-black bg-blue-50 text-blue-700">SBS (Elastomeric)</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr><td class="px-5 py-4 font-bold text-slate-800">Best Climate</td><td class="px-5 py-4">Hot, high solar load</td><td class="px-5 py-4">Cold, wide swings</td></tr>
                <tr><td class="px-5 py-4 font-bold text-slate-800">Heat Resistance</td><td class="px-5 py-4 font-bold text-amber-700">Up to 130degC</td><td class="px-5 py-4">Up to 105degC</td></tr>
                <tr><td class="px-5 py-4 font-bold text-slate-800">Low Temp</td><td class="px-5 py-4">-15degC</td><td class="px-5 py-4 font-bold text-blue-700">-25degC</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    )}

    {hasOverview && (
      <section class="mx-auto w-full max-w-[1680px] px-4 py-4 sm:px-6 lg:px-8">
        <div class="rounded-3xl border border-slate-200 bg-white p-6 sm:p-10 shadow-sm">
          <h2 class="text-xl font-black text-slate-950 sm:text-2xl mb-10 uppercase tracking-tight">Product Overview</h2>
          <div class="prose prose-slate max-w-none prose-p:leading-8 prose-p:text-slate-600 prose-headings:font-black prose-img:rounded-3xl prose-img:shadow-lg">
            <Content />
          </div>
        </div>
      </section>
    )}

    <CTA />
  </main>
</Layout>

<script>
  const mainImg = document.getElementById('main-product-image') as HTMLImageElement;
  const thumbs = document.querySelectorAll('.gallery-thumb');
  thumbs.forEach(thumb => {
    thumb.addEventListener('click', () => {
      const src = thumb.getAttribute('data-full');
      if (src && mainImg) {
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = src;
          mainImg.style.opacity = '1';
        }, 200);
      }
    });
  });
</script>
