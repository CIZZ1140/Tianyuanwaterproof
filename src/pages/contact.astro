---
import Layout from '@/layouts/Layout.astro';
import { site } from '@/data/site';
---
<Layout title="Contact Us | Request Waterproofing Materials Quote">
  <section class="bg-navy py-16 text-white"><div class="container-wrap"><p class="eyebrow">Contact</p><h1 class="mt-3 text-4xl font-black text-white md:text-5xl">Request a quotation</h1><p class="mt-5 max-w-3xl text-white/70">Tell us product type, specification, quantity and destination. We will prepare quotation and technical documents.</p></div></section>
  <section class="py-16"><div class="container-wrap grid gap-10 lg:grid-cols-[1.1fr_.9fr]">
    <form class="card grid gap-4" action="https://formspree.io/f/your-form-id" method="POST">
      <div class="grid gap-4 md:grid-cols-2"><input class="input" name="name" placeholder="Name" /><input class="input" name="email" type="email" placeholder="Email" /></div>
      <div class="grid gap-4 md:grid-cols-2"><input class="input" name="whatsapp" placeholder="WhatsApp" /><input class="input" name="country" placeholder="Country" /></div>
      <input class="input" name="product" placeholder="Product interested" />
      <input class="input" name="quantity" placeholder="Quantity / destination port" />
      <textarea class="input min-h-36" name="message" placeholder="Message"></textarea>
      <button class="btn-primary w-fit" type="submit">Send Inquiry</button>
      <p class="text-xs text-slate-500">Replace Formspree action with your real form endpoint before publishing.</p>
    </form>
    <div class="card"><h2 class="text-2xl font-bold">Sales contact</h2><ul class="mt-5 space-y-4 text-sm leading-6"><li><strong>Email:</strong> {site.email}</li><li><strong>WhatsApp:</strong> {site.whatsapp}</li><li><strong>Phone:</strong> {site.phone}</li><li><strong>Address:</strong> {site.address}</li></ul></div>
  </div></section>
</Layout>
