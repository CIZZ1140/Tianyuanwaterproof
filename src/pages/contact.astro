---
import Layout from '@/layouts/Layout.astro';
import { site } from '@/data/site';
---
<Layout title="Contact Us | Request Waterproofing Materials Quote">
  <section class="bg-navy py-16 text-white text-center">
    <div class="container">
      <p class="section-kicker">Contact</p>
      <h1 class="mt-3 text-4xl font-black text-white md:text-5xl uppercase tracking-tight">Request a quotation</h1>
      <p class="mt-5 max-w-2xl mx-auto text-white/70">Tell us product type, specification, quantity and destination. We will prepare quotation and technical documents.</p>
    </div>
  </section>

  <section class="py-16 bg-slate-50">
    <div class="container grid gap-10 lg:grid-cols-[1.2fr_.8fr]">
      <div class="card p-8 bg-white border border-line rounded-2xl shadow-card">
        <form class="grid gap-6" action="https://formspree.io/f/mzdqdpwd" method="POST">
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="block text-xs font-bold text-navy uppercase mb-2">Name</label>
              <input class="w-full rounded-lg border border-line bg-slate-50 px-4 py-3 text-sm focus:border-brand focus:ring-2 focus:ring-brand/10 outline-none transition-all" name="name" placeholder="Enter your name" required />
            </div>
            <div>
              <label class="block text-xs font-bold text-navy uppercase mb-2">Email</label>
              <input class="w-full rounded-lg border border-line bg-slate-50 px-4 py-3 text-sm focus:border-brand focus:ring-2 focus:ring-brand/10 outline-none transition-all" name="email" type="email" placeholder="Enter your email" required />
            </div>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="block text-xs font-bold text-navy uppercase mb-2">WhatsApp</label>
              <input class="w-full rounded-lg border border-line bg-slate-50 px-4 py-3 text-sm focus:border-brand focus:ring-2 focus:ring-brand/10 outline-none transition-all" name="whatsapp" placeholder="Include country code" />
            </div>
            <div>
              <label class="block text-xs font-bold text-navy uppercase mb-2">Country</label>
              <input class="w-full rounded-lg border border-line bg-slate-50 px-4 py-3 text-sm focus:border-brand focus:ring-2 focus:ring-brand/10 outline-none transition-all" name="country" placeholder="Destination country" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-bold text-navy uppercase mb-2">Product interested</label>
            <input class="w-full rounded-lg border border-line bg-slate-50 px-4 py-3 text-sm focus:border-brand focus:ring-2 focus:ring-brand/10 outline-none transition-all" name="product" placeholder="e.g. SBS Bitumen Membrane" />
          </div>
          <div>
            <label class="block text-xs font-bold text-navy uppercase mb-2">Quantity / Specifications</label>
            <input class="w-full rounded-lg border border-line bg-slate-50 px-4 py-3 text-sm focus:border-brand focus:ring-2 focus:ring-brand/10 outline-none transition-all" name="quantity" placeholder="e.g. 500 rolls / 4mm thickness" />
          </div>
          <div>
            <label class="block text-xs font-bold text-navy uppercase mb-2">Message</label>
            <textarea class="w-full rounded-lg border border-line bg-slate-50 px-4 py-3 text-sm min-h-36 focus:border-brand focus:ring-2 focus:ring-brand/10 outline-none transition-all" name="message" placeholder="Detailed requirements..."></textarea>
          </div>
          <button class="btn-primary w-full md:w-fit px-10" type="submit">Send Inquiry →</button>
        </form>
      </div>

      <div class="space-y-6">
        <div class="card p-8 bg-navy text-white rounded-2xl shadow-card">
          <h2 class="text-2xl font-extrabold uppercase tracking-tight">Sales Support</h2>
          <div class="mt-6 h-1 w-12 bg-brand"></div>
          <ul class="mt-8 space-y-6">
            <li class="flex gap-4 items-start">
              <span class="text-brand">📧</span>
              <div>
                <p class="text-xs font-bold text-white/50 uppercase">Email Address</p>
                <a href={`mailto:${site.email}`} class="text-lg font-bold hover:text-brand">{site.email}</a>
              </div>
            </li>
            <li class="flex gap-4 items-start">
              <span class="text-brand">📱</span>
              <div>
                <p class="text-xs font-bold text-white/50 uppercase">WhatsApp / WeChat</p>
                <p class="text-lg font-bold">{site.whatsapp}</p>
              </div>
            </li>
            <li class="flex gap-4 items-start">
              <span class="text-brand">📞</span>
              <div>
                <p class="text-xs font-bold text-white/50 uppercase">Direct Call</p>
                <p class="text-lg font-bold">{site.phone}</p>
              </div>
            </li>
            <li class="flex gap-4 items-start">
              <span class="text-brand">📍</span>
              <div>
                <p class="text-xs font-bold text-white/50 uppercase">Factory Address</p>
                <p class="text-sm font-bold text-white/80">{site.address}</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
