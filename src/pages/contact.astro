---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';

const whatsappNumber = site.whatsapp.replace(/[^0-9]/g, '');
const buyerTypes = [
  'Importer',
  'Distributor / Wholesaler',
  'Building Materials Supplier',
  'Construction Contractor',
  'Waterproofing Contractor',
  'OEM / Private Label Buyer',
  'other'
];
const productInterests = [
  'Waterproofing Membranes',
  'Waterproofing Tapes',
  'Waterproofing Coatings',
  'Tools & Accessories'
];
const contactCards = [
  {
    label: 'WHATSAPP',
    value: `+${site.whatsapp}`,
    href: `https://wa.me/${whatsappNumber}`,
    tone: 'whatsapp',
    icon: 'whatsapp'
  },
  {
    label: 'EMAIL',
    value: site.email,
    href: `mailto:${site.email}`,
    tone: 'email',
    icon: 'email'
  },
  {
    label: 'FACTORY',
    value: site.address,
    href: '',
    tone: 'factory',
    icon: 'pin'
  },
  {
    label: 'ALIBABA STORE',
    value: 'tyfangshui.en.alibaba.com',
    href: site.alibabaStore,
    tone: 'alibaba',
    icon: 'store'
  }
];
---
<Layout
  title="Contact Tianyuan Waterproof | Request a Waterproofing Materials Quote"
  description="Contact Tianyuan Waterproof for waterproofing membranes, tapes and coatings. Send your product interest, buyer type, quantity and project details to get a quotation."
>
  <section class="relative overflow-hidden bg-slate-900 text-white">
    <div class="absolute inset-0 opacity-25">
      <img src={site.heroImage} alt="Torch applied waterproofing membrane construction" class="h-full w-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-slate-950 via-slate-900/95 to-slate-900/70"></div>
    <div class="container mx-auto max-w-7xl px-5 relative py-16 lg:py-20">
      <p class="inline-flex rounded-full border border-white/20 bg-white/10 px-4 py-2 text-xs font-extrabold uppercase tracking-[0.22em] text-blue-100">Contact Tianyuan Waterproof</p>
      <div class="mt-6 max-w-4xl">
        <h1 class="text-4xl font-black leading-tight md:text-6xl text-white">Request a Waterproofing Materials Quote</h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-white/80">Send your product interest, buyer type, size, quantity and project requirements. We will reply with quotation details, technical support and export packaging information.</p>
      </div>
    </div>
  </section>

  <section class="bg-[#f7f3ec] py-14 lg:py-20">
    <div class="container mx-auto max-w-7xl px-5 grid gap-8 lg:grid-cols-[minmax(0,1.25fr)_minmax(340px,.75fr)]">
      <div class="rounded-[1.75rem] border border-[#e5dccd] bg-white p-6 shadow-sm lg:p-10">
        <div class="max-w-2xl">
          <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-accent">Send Inquiry</p>
          <h2 class="mt-3 text-3xl font-black text-slate-900">Tell us about your sourcing request</h2>
          <p class="mt-3 text-slate-600">Fields marked * are required. More details help us match the right waterproofing membrane, tape or coating for your market and project.</p>
        </div>

        <form class="mt-10 space-y-6" action="https://formspree.io/f/mzdqdpwd" method="POST">
          <div class="grid gap-6 md:grid-cols-2">
            <label class="field-label">Full Name *<input required name="name" class="input" placeholder="Your name" /></label>
            <label class="field-label">Company *<input required name="company" class="input" placeholder="Company name" /></label>
            <label class="field-label">Email *<input required type="email" name="email" class="input" placeholder="name@company.com" /></label>
            <label class="field-label">Country<input name="country" class="input" placeholder="Country / Region" /></label>
            <label class="field-label">WhatsApp / Phone<input name="whatsapp" class="input" placeholder="+00 000 0000" /></label>
            <label class="field-label">Buyer Type *<select required name="buyer_type" class="input"><option value="">Select your role...</option>{buyerTypes.map((type) => <option value={type}>{type}</option>)}</select></label>
            <label class="field-label">Product Interest<select name="product_interest" class="input"><option value="">Select product interest...</option>{productInterests.map((item) => <option value={item}>{item}</option>)}</select></label>
            <label class="field-label">Size & Quantity<input name="quantity" class="input" placeholder="e.g. 4.0mm × 1m × 10m, 1 container" /></label>
          </div>
          <label class="field-label">Message *<textarea required name="message" rows="6" class="input" placeholder="Tell us product type, thickness, surface finish, quantity, packaging requirement, destination port or project details."></textarea></label>
          <button class="btn-primary w-full" type="submit">Send Inquiry →</button>
          <p class="text-center text-xs text-slate-500">We usually reply with quotation and technical support within 24 hours.</p>
        </form>
      </div>

      <aside class="rounded-[1.75rem] border border-[#e5dccd] bg-white p-6 shadow-sm lg:p-10 h-fit">
        <h2 class="text-2xl font-bold text-slate-900">Get in touch directly</h2>
        <p class="mt-4 text-base leading-7 text-slate-600">Prefer a quicker channel? We’re available on WhatsApp, email, factory contact and Alibaba store.</p>
        <div class="mt-8 space-y-4">
          {contactCards.map((card) => {
            const isClickable = Boolean(card.href);
            const CardTag = isClickable ? 'a' : 'div';
            return (
            <CardTag href={isClickable ? card.href : undefined} target={isClickable && card.href.startsWith('http') ? '_blank' : undefined} rel={isClickable && card.href.startsWith('http') ? 'noreferrer' : undefined} class={`direct-card group ${!isClickable ? 'cursor-default' : ''}`}>
              <span class={`direct-icon ${card.tone}`} aria-hidden="true">
                {card.icon === 'whatsapp' && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor"><path d="M12.04 2a9.8 9.8 0 0 0-8.47 14.72L2.4 21.6l5-1.12A9.8 9.8 0 1 0 12.04 2Zm0 1.8a8 8 0 0 1 6.84 12.15 8 8 0 0 1-10.88 2.8l-.33-.18-2.9.65.67-2.8-.2-.35A8 8 0 0 1 12.04 3.8Zm-3.15 4.3c-.18 0-.47.07-.72.35-.25.28-.95.93-.95 2.26s.98 2.62 1.12 2.8c.14.19 1.9 3.05 4.72 4.15 2.34.92 2.82.74 3.33.7.51-.05 1.65-.67 1.88-1.32.23-.65.23-1.2.16-1.32-.07-.12-.25-.19-.53-.33l-1.57-.78c-.28-.14-.48-.21-.68.07-.2.28-.78.92-.96 1.1-.18.19-.35.21-.63.07-.28-.14-1.2-.44-2.29-1.41-.85-.76-1.42-1.7-1.59-1.98-.16-.28-.02-.44.12-.58.13-.13.28-.35.42-.53.14-.19.19-.33.28-.56.09-.23.05-.42-.02-.58-.07-.14-.63-1.52-.88-2.08-.23-.54-.47-.47-.65-.48h-.55Z" /></svg>
                )}
                {card.icon === 'email' && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16v12H4z"/><path d="m4 7 8 6 8-6"/></svg>
                )}
                {card.icon === 'pin' && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s7-5.1 7-11a7 7 0 0 0-14 0c0 5.9 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
                )}
                {card.icon === 'store' && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor"><path d="M4 5h16l1 5a4 4 0 0 1-6.5 3.1A4 4 0 0 1 12 14a4 4 0 0 1-2.5-.9A4 4 0 0 1 3 10l1-5Zm2 10.3c.9.42 2 .45 3 .1.94.37 2.06.37 3 0 .94.37 2.06.37 3 0 .96.34 2.05.32 3-.1V20H6v-4.7Z" /></svg>
                )}
              </span>
              <span class="min-w-0">
                <span class="block text-sm font-black uppercase tracking-wide text-slate-500">{card.label}</span>
                <span class="mt-1 block break-words text-base font-semibold text-slate-900">{card.value}</span>
              </span>
            </CardTag>
            );
          })}
        </div>
      </aside>
    </div>
  </section>
</Layout>

<style>
  .field-label {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 800;
    color: #0b2348;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .direct-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    border-radius: 1.25rem;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    padding: 1.25rem;
    transition: all .2s ease;
  }
  .direct-card:hover:not(.cursor-default) {
    transform: translateY(-2px);
    border-color: #cbd5e1;
    background: #fff;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
  }
  .direct-icon {
    display: inline-flex;
    height: 3.5rem;
    width: 3.5rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
  }
  .direct-icon.whatsapp { background: #25d366; color: #fff; }
  .direct-icon.email { background: #f1f5f9; color: #0f172a; }
  .direct-icon.factory { background: #f1f5f9; color: #0f172a; }
  .direct-icon.alibaba { background: #fff7ed; color: #ea580c; }
</style>
