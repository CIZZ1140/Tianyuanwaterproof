---

<Layout 
  title="Contact Us | Tianyuan Waterproof"
  description="Get in touch with Tianyuan Waterproof for factory-direct quotes and technical support."
>
  <style is:global>
    .custom-scrollbar::-webkit-scrollbar {
      width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: #f1f1f1;
      border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #888;
      border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
      background: #555;
    }
  </style>
  <main class="min-h-screen bg-[#F9F7F2] py-16 sm:py-24 font-sans">
    <div class="mx-auto max-w-[1440px] px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-12 max-w-2xl">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#A87835]">
          Contact Tianyuan Waterproof
        </p>
        <h1 class="mt-4 font-serif text-4xl font-bold text-[#241F1A] sm:text-5xl leading-[1.2]">
          Let’s discuss your waterproofing project
        </h1>
        <p class="mt-6 text-base leading-8 text-[#6F6255]">
          Send us your project details, specifications, and destination market. 
          Our team will respond with product matching, quotation, and technical support.
        </p>
      </div>

      <div class="grid gap-8 lg:grid-cols-[1.35fr_0.85fr] lg:items-start">
        <!-- Form Section -->
        <div class="rounded-[2rem] border border-[#D1C7B7] bg-white/80 p-6 shadow-sm sm:p-8 lg:p-10">
          <h2 class="font-serif text-3xl font-semibold text-[#241F1A]">
            Tell us about your project
          </h2>
          <p class="mt-3 text-sm leading-7 text-[#6F6255]">
            Fields marked with an asterisk are required. Please include the product type and quantity so we can reply more precisely.
          </p>

          <form
            class="mt-10 space-y-6"
            action="https://formspree.io/f/mzdqdpwd"
            method="POST"
          >
            <input type="hidden" name="_subject" value="New B2B Inquiry" />
            
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label class={labelClass} for="fullName">Full Name *</label>
                <input id="fullName" name="Full Name" type="text" required placeholder="Your full name" class={inputClass} />
              </div>

              <div>
                <label class={labelClass} for="company">Company</label>
                <input id="company" name="Company" type="text" placeholder="Company name" class={inputClass} />
              </div>

              <div>
                <label class={labelClass} for="email">Email *</label>
                <input id="email" name="Email" type="email" required placeholder="name@company.com" class={inputClass} />
              </div>

              <div>
                <label class={labelClass} for="country">Country</label>
                <input id="country" name="Country" type="text" placeholder="Your country" class={inputClass} />
              </div>

              <!-- Searchable Phone Selector (復刻同行的專業組件) -->
              <div class="relative">
                <label class={labelClass} for="phone">WhatsApp / Phone</label>
                <div class="flex items-stretch rounded-lg border border-[#E8E2D8] bg-white overflow-visible transition focus-within:border-[#A87835]">
                  <!-- Country Code Trigger -->
                  <div class="relative" id="country-selector">
                    <button type="button" class="flex items-center gap-1.5 h-full px-4 border-r border-[#E8E2D8] bg-slate-50/30 hover:bg-slate-50 text-sm font-bold text-[#4A453E] transition-colors rounded-l-lg">
                      <span id="current-code">Code</span>
                      <ChevronDown size={14} class="text-slate-400" />
                    </button>
                    <!-- Searchable Dropdown -->
                    <div id="country-dropdown" class="hidden absolute left-0 top-full z-50 mt-2 w-64 bg-white border border-[#D1C7B7] rounded-xl shadow-2xl overflow-hidden">
                      <div class="p-3 border-b border-slate-100">
                        <div class="relative">
                          <Search size={14} class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400" />
                          <input type="text" id="country-search" placeholder="Search country..." class="w-full pl-9 pr-4 py-2 text-xs border border-slate-200 rounded-lg outline-none focus:border-[#A87835]" />
                        </div>
                      </div>
                      <div class="max-h-60 overflow-y-auto custom-scrollbar" id="country-list">
                        {countries.map(c => (
                          <div class="country-item px-4 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-[#A87835] cursor-pointer flex justify-between items-center transition-colors" data-code={c.code} data-name={c.name}>
                            <span class="font-medium">{c.code}</span>
                            <span class="text-xs text-slate-400">{c.name}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                  <input id="phone" name="Phone" type="text" placeholder="Please enter your mobile phone" class="w-full bg-transparent px-4 py-3 text-sm text-[#4A453E] outline-none" />
                  <input type="hidden" name="Full Phone" id="full-phone" />
                  <input type="hidden" name="Selected Code" id="selected-code" value="" />
                </div>
                <p id="code-hint" class="mt-1.5 text-xs text-red-500/80 hidden">Please select your country code</p>
              </div>

              <div>
                <label class={labelClass} for="role">Your Role *</label>
                <select id="role" name="Your Role" required class={inputClass}>
                  <option value="">Select your role...</option>
                  {buyerTypes.map((type) => <option value={type}>{type}</option>)}
                </select>
              </div>

              <div>
                <label class={labelClass} for="productInterest">Product Interest</label>
                <select id="productInterest" name="Product Interest" class={inputClass}>
                  <option value="">Select product interest...</option>
                  {productInterests.map((item) => <option value={item}>{item}</option>)}
                </select>
              </div>

              <div>
                <label class={labelClass} for="sizeQuantity">Size & Quantity</label>
                <input id="sizeQuantity" name="Size & Quantity" type="text" placeholder="e.g. 4.0mm, 1m x 10m, 1 container" class={inputClass} />
              </div>
            </div>

            <div>
              <label class={labelClass} for="message">Message *</label>
              <textarea id="message" name="Message" rows="6" required placeholder="Tell us your application, required specifications, quantity, destination port, or any technical questions." class={`${inputClass} resize-y`}></textarea>
            </div>

            <div class="flex flex-col gap-4 border-t border-[#D1C7B7]/70 pt-6 sm:flex-row sm:items-center sm:justify-between">
              <div class="flex items-center gap-2 text-[#6F6255]">
                <CheckCircle2 size={16} class="text-[#A87835]" />
                <p class="text-sm">Response within 24 hours.</p>
              </div>
              <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-[#1E4F9A] px-10 py-4 text-sm font-bold text-white shadow-lg transition hover:bg-[#163D79] hover:-translate-y-0.5 group">
                Submit Inquiry
                <ArrowRight class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" />
              </button>
            </div>
          </form>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <div class="rounded-[2rem] border border-[#D1C7B7] bg-white/70 p-8 shadow-sm">
            <h2 class="font-serif text-2xl font-semibold text-[#241F1A]">Get in touch directly</h2>
            <p class="mt-3 text-sm leading-7 text-[#6F6255]">Available on WhatsApp, email and factory visit.</p>
            <div class="mt-8 space-y-4">
              {contactCards.map((card) => (
                <a href={card.href || undefined} class="group flex items-center gap-4 rounded-2xl border border-[#D1C7B7] bg-[#F4F0E8] p-5 transition-all duration-300 hover:-translate-y-1 hover:border-[#A87835] hover:shadow-md">
                  <span class={`flex h-12 w-12 shrink-0 items-center justify-center rounded-full ${card.iconBg} ${card.iconText}`}>
                    {card.icon === 'whatsapp' && <MessageCircle size={24} />}
                    {card.icon === 'email' && <Mail size={24} />}
                    {card.icon === 'location' && <MapPin size={24} />}
                    {card.icon === 'store' && <Store size={24} />}
                  </span>
                  <span class="min-w-0">
                    <span class="block text-xs font-bold tracking-wider text-[#6F6255]">{card.label}</span>
                    <span class="mt-1 block break-words text-sm font-black text-[#241F1A] group-hover:text-[#A87835] transition-colors">{card.value}</span>
                  </span>
                </a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <!-- Phone Selector Logic -->
  <script>
    const selector = document.getElementById('country-selector');
    const trigger = selector?.querySelector('button');
    const dropdown = document.getElementById('country-dropdown');
    const searchInput = document.getElementById('country-search') as HTMLInputElement;
    const currentCodeDisplay = document.getElementById('current-code');
    const selectedCodeInput = document.getElementById('selected-code') as HTMLInputElement;
    const countryItems = document.querySelectorAll('.country-item');

    // Toggle Dropdown
    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown?.classList.toggle('hidden');
      if (!dropdown?.classList.contains('hidden')) searchInput?.focus();
    });

    // Close on outside click
    document.addEventListener('click', () => dropdown?.classList.add('hidden'));

    // Prevent closing when clicking inside dropdown (search input, list etc.)
    dropdown?.addEventListener('click', (e) => e.stopPropagation());

    // Search Logic
    searchInput?.addEventListener('input', (e) => {
      const term = (e.target as HTMLInputElement).value.toLowerCase();
      countryItems.forEach(item => {
        const name = item.getAttribute('data-name')?.toLowerCase() || '';
        const code = item.getAttribute('data-code')?.toLowerCase() || '';
        (item as HTMLElement).style.display = (name.includes(term) || code.includes(term)) ? 'flex' : 'none';
      });
    });

    // Select Logic
    countryItems.forEach(item => {
      item.addEventListener('click', () => {
        const code = item.getAttribute('data-code') || '';
        if (currentCodeDisplay) currentCodeDisplay.innerText = code;
        if (selectedCodeInput) selectedCodeInput.value = code;
        document.getElementById('code-hint')?.classList.add('hidden');
        dropdown?.classList.add('hidden');
      });
    });

    // Form validation — require country code
    const form = selector?.closest('form');
    const phoneContainer = selector?.closest('.flex');
    form?.addEventListener('submit', (e) => {
      if (!selectedCodeInput?.value) {
        e.preventDefault();
        document.getElementById('code-hint')?.classList.remove('hidden');
        phoneContainer?.classList.add('!border-red-400');
        selector?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });
  </script>
</Layout>
