---
import Layout from '@/layouts/Layout.astro';
import CTA from '@/components/CTA.astro';
---
<Layout title="Projects | Waterproofing Materials">
  <section class="bg-navy py-16 text-white"><div class="container-wrap"><p class="eyebrow">Projects</p><h1 class="mt-3 text-4xl font-black text-white md:text-5xl">Application cases</h1><p class="mt-5 max-w-3xl text-white/70">Add real project photos, product used, application area and construction notes when available.</p></div></section>
  <section class="py-16"><div class="container-wrap grid gap-6 md:grid-cols-2 lg:grid-cols-4">{['Roofing Projects','Basement Projects','Tunnel Projects','Industrial Building Projects'].map((title) => <div class="card"><h2 class="text-xl font-bold">{title}</h2><p class="mt-3 text-sm leading-6 text-slate-600">Use this section to build B2B trust with practical application evidence.</p></div>)}</div></section>
  <CTA />
</Layout>
