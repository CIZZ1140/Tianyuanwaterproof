---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = [
    {
      id: "bitumen-membranes",
      name: "Bitumen Membranes",
      desc: "Premium modified bitumen and self-adhesive waterproofing membranes for commercial, residential, and civil engineering structures.",
      image: "https://img.tyuanwaterproof.com/products/sbs-torch-applied-membrane.webp",
      capabilities: [
        "SBS/APP Modified Bitumen (3mm/4mm/5mm)",
        "Self-Adhesive Waterproof Roll",
        "Saturated Organic Asphalt Roofing Felt (15lb/30lb)",
        "High Temperature Resistance & Low Temp Flexibility",
        "Direct Factory Container Pricing & Custom OEM Packaging"
      ]
    },
    {
      id: "asphalt-shingles",
      name: "Asphalt Shingles",
      desc: "Lightweight, flexible, and extremely durable roofing shingles featuring classic 3-tab, multi-layer laminated, and hexagonal artistic designs.",
      image: "https://img.tyuanwaterproof.com/categories/asphalt-shingles.webp",
      capabilities: [
        "3-Tab Classic Shingles",
        "Architectural Laminated Composite Shingles",
        "Hexagonal & Fish-Scale Artistic Shingles",
        "Colored Natural Sintered Mineral Granules Surface",
        "Wind-resistant & Weather-proof Architectural Roofing"
      ]
    },
    {
      id: "waterproof-tapes",
      name: "Waterproof Tapes",
      desc: "High-adhesion butyl sealant tapes, aluminum flashing tapes, and self-adhesive sealing bands for metal roofs, flashing repairs, and window joints.",
      image: "https://img.tyuanwaterproof.com/products/butyl-waterproof-sealing-tape-supplier.webp",
      capabilities: [
        "Double-sided & Single-sided Aluminum Butyl Tapes",
        "Super Adhesion UV-Resistant Roof Sealing Tape",
        "Anti-crack RV / Pipe Joint Repair Tapes",
        "Custom Roll Lengths, Widths, and Thicknesses",
        "Branded Wholesale Packaging & Label Customization"
      ]
    },
    {
      id: "waterproof-coatings",
      name: "Waterproof Coatings",
      desc: "Liquid-applied high-elasticity polyurethane, high-polymer acrylic, and polymer-cementitious waterproof coatings for seamless surface protection.",
      image: "https://img.tyuanwaterproof.com/categories/waterproof-coatings.webp",
      capabilities: [
        "Single-Component Polyurethane Waterproof Coating",
        "Eco-friendly High-Elastic Acrylic Coating",
        "Polymer-Modified Cementitious Waterproofing Slurry",
        "Ideal for Bathrooms, Balconies, Swimming Pools & Roofs",
        "Available in 5kg, 10kg, 20kg B2B Wholesale Drums"
      ]
    },
    {
      id: "geosynthetics",
      name: "Geosynthetics",
      desc: "High-strength non-woven geotextiles, HDPE geomembranes, and drainage geogrids for soil stabilization, landfills, and water conservancy projects.",
      image: "https://img.tyuanwaterproof.com/products/hdpe-waterproof-membrane.webp",
      capabilities: [
        "HDPE Smooth / Textured Geomembrane Liners (0.5mm - 2.0mm)",
        "Polyester (PET) Continuous Filament Non-Woven Geotextiles",
        "Geomembranes for Pond Liners, Aquaculture, Landfills",
        "High Tensile Strength & Outstanding Puncture Resistance",
        "ISO certified factory-direct supply, container shipping"
      ]
    },
    {
      id: "polymer-membranes",
      name: "Polymer Membranes",
      desc: "Advanced high-polymer waterproofing solutions including EPDM, TPO, PVC, and HDPE membranes for long-lasting exposed and buried applications.",
      image: "https://img.tyuanwaterproof.com/products/tpo-waterproof-membrane.webp",
      capabilities: [
        "EPDM Synthetic Rubber Membrane",
        "TPO Thermoplastic Polyolefin Membrane",
        "PVC Waterproofing Roll",
        "HDPE Pre-applied Bonding Membrane",
        "Excellent Aging & UV Resistance for Roofs & Basements"
      ]
    }
  ];

  return categories.map(cat => ({
    params: { category: cat.id },
    props: { cat },
  }));
}

const { cat } = Astro.props;

const products = await getCollection('products', ({ data }) => {
  return data.category === cat.id;
});
---

<Layout 
  title={`${cat.name} Wholesale & OEM - Weifang Tianyuan Waterproof`} 
  description={`High-quality ${cat.name} for global construction. We offer direct factory pricing, OEM manufacturing, and reliable export supply for ${cat.name.toLowerCase()} projects.`}
  preloadImage={cat.image}
>
  <main class="bg-slate-50 min-h-screen">
    <!-- Category Hero Header -->
    <section class="relative py-28 bg-[#0B1E3B] text-white overflow-hidden border-b border-white/10">
      <div class="absolute inset-0 z-0">
        <img 
          src={cat.image} 
          alt="" 
          class="w-full h-full object-cover opacity-20" 
          width="1920"
          height="600"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[#0B1E3B] via-[#0B1E3B]/80 to-transparent"></div>
      </div>
      <div class="absolute inset-0 bg-[url('/assets/images/grid.svg')] opacity-10 mix-blend-overlay"></div>
      
      <div class="relative z-10 max-w-7xl mx-auto px-6 text-center sm:text-left">
        <nav class="flex text-sm font-bold text-blue-200/90 gap-3 justify-center sm:justify-start items-center mb-6 uppercase tracking-wider">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="text-blue-400/50">/</span>
          <span class="text-white">{cat.name}</span>
        </nav>
        <h1 class="text-4xl md:text-5xl font-black mb-4 tracking-tight text-white leading-tight">{cat.name}</h1>
        <p class="text-lg md:text-xl text-slate-200 max-w-3xl leading-relaxed opacity-0 animate-fade-in" style="animation-fill-mode: forwards;">{cat.desc}</p>
      </div>
    </section>

    <!-- Product Showcase / Capabilities split -->
    <section class="max-w-7xl mx-auto px-4 py-20">
      {products.length > 0 ? (
        <div>
          <div class="mb-12">
            <h2 class="text-xs font-bold uppercase tracking-wider text-blue-600 mb-2">Available Products</h2>
            <p class="text-3xl font-extrabold text-slate-900">Standard Specifications</p>
          </div>
          <div class="grid md:grid-cols-3 gap-10">
            {products.map((p, index) => {
              let displayImage = p.data.main_image || p.data.image || "";
              if (displayImage && !displayImage.toLowerCase().endsWith(".webp") && !displayImage.toLowerCase().endsWith(".jpg")) {
                displayImage = displayImage.replace(/\/$/, "") + ".webp";
              }
              
              return (
                <a href={`/products/${p.slug}/`} class="group block bg-white rounded-3xl p-6 shadow-sm border border-slate-100 hover:shadow-md transition-all cursor-pointer">
                  <div class="relative overflow-hidden rounded-2xl mb-6 aspect-[4/3] bg-slate-50 flex items-center justify-center">
                    {displayImage ? (
                      <img 
                        src={displayImage} 
                        alt={p.data.title} 
                        class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500" 
                        loading="lazy"
                        decoding="async"
                        onerror="this.src='/placeholder.webp'; this.onerror=null;"
                      />
                    ) : (
                      <div class="w-full h-full flex flex-col items-center justify-center text-slate-400 p-6 text-center select-none">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 mb-3 text-slate-300">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                        </svg>
                        <span class="text-xs font-bold uppercase tracking-wider text-slate-400">Image Coming Soon</span>
                      </div>
                    )}
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                  </div>
                  <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors line-clamp-2" title={p.data.title}>{p.data.title}</h3>
                  <p class="text-slate-500 mb-6 text-sm leading-relaxed line-clamp-3">{p.data.description}</p>
                  <span class="inline-flex items-center gap-2 font-bold text-blue-600 text-sm">Learn More <span class="text-xl leading-none">›</span></span>
                </a>
              );
            })}
          </div>
        </div>
      ) : (
        /* Empty/Coming-Soon Category Template */
        <div class="grid lg:grid-cols-12 gap-12 items-center">
          <!-- Capabilities List -->
          <div class="lg:col-span-7">
            <span class="text-blue-600 font-bold uppercase tracking-wider text-xs block mb-2">Industrial OEM & Wholesale Sourcing</span>
            <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-6 leading-tight">Custom {cat.name} Supply</h2>
            <p class="text-slate-600 mb-8 leading-relaxed">
              Weifang Tianyuan is a direct factory manufacturer. While our standard catalog for online retail is being updated, we offer **full customization, OEM manufacturing, and wholesale export supply** for all types of {cat.name.toLowerCase()} for commercial and industrial construction projects worldwide.
            </p>

            <div class="bg-white rounded-3xl p-8 border border-slate-100 shadow-sm">
              <h3 class="font-bold text-slate-900 mb-4">Our Manufacturing Capabilities & Ranges:</h3>
              <ul class="space-y-3">
                {cat.capabilities.map(cap => (
                  <li class="flex items-start gap-3 text-sm text-slate-600">
                    <span class="text-blue-600 font-bold">✓</span>
                    <span>{cap}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- B2B Lead Form -->
          <div class="lg:col-span-5 bg-slate-900 text-white rounded-3xl p-8 md:p-10 shadow-xl border border-slate-800">
            <h3 class="text-2xl font-bold mb-2">Request Bulk Catalog</h3>
            <p class="text-slate-400 text-xs mb-6">Send us your technical specs, required sizes, and destination port. We will supply direct factory prices and OEM catalogs.</p>

            <form class="space-y-4" action="https://formspree.io/f/mzdqdpwd" method="POST">
              <input type="hidden" name="category" value={cat.name} />
              <div>
                <label class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1">Your Name</label>
                <input type="text" name="name" required class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-2.5 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-blue-500 transition-colors" placeholder="e.g. John Smith" />
              </div>

              <div>
                <label class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1">Business Email</label>
                <input type="email" name="email" required class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-2.5 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-blue-500 transition-colors" placeholder="john@company.com" />
              </div>

              <div>
                <label class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1">Company Name</label>
                <input type="text" name="company" required class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-2.5 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-blue-500 transition-colors" placeholder="e.g. Apex Construction Co." />
              </div>

              <div>
                <label class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1">Requirement Details</label>
                <textarea name="message" rows="3" required class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-2.5 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-blue-500 transition-colors resize-none" placeholder={`Please specify your ${cat.name.toLowerCase()} requirements (width, thickness, tensile strength)...`}></textarea>
              </div>

              <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3.5 rounded-xl transition-all shadow-lg shadow-blue-600/10 text-center block text-sm">
                Get Wholesale Catalog
              </button>
            </form>
          </div>
        </div>
      )}
    </section>
  </main>
</Layout>
