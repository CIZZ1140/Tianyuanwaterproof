---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const products = await getCollection('products');
---

<Layout title="Tianyuan Waterproof - Global Leader in Waterproofing Solutions">
	<main>
		<!-- Hero Section -->
		<section class="relative h-[80vh] flex items-center justify-center overflow-hidden bg-slate-900">
			<div class="absolute inset-0 opacity-40 bg-cover bg-center" style="background-image: url('https://sc04.alicdn.com/kf/Hfe087a70867f43a8bd7c11db0b7f9e20T.png_960x960q80.jpg');"></div>
			<div class="relative z-10 text-center px-4 max-w-4xl">
				<h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 tracking-tight">
					Engineering <span class="text-blue-400">Future-Proof</span> Protection
				</h1>
				<p class="text-xl text-slate-200 mb-10 leading-relaxed">
					20+ years of excellence in manufacturing premium SBS, PVC, and TPO waterproofing systems for global construction projects.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href="#products-grid" class="bg-blue-600 text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-blue-700 transition-all text-center">Explore Products</a>
					<a href="#why-us" class="bg-white/10 backdrop-blur-md text-white border border-white/30 px-8 py-4 rounded-lg font-bold text-lg hover:bg-white/20 transition-all text-center">Why Choose Us</a>
				</div>
			</div>
		</section>

		<!-- Featured Products -->
		<section id="products-grid" class="py-24 max-w-7xl mx-auto px-4 scroll-mt-6">
			<div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
				<div>
					<h2 class="text-blue-600 font-bold tracking-widest uppercase text-sm mb-3">Featured Solutions</h2>
					<p class="text-4xl font-bold text-slate-900">Core Waterproofing Membranes</p>
				</div>
				<span class="text-slate-500 font-semibold text-sm">{products.length} Professional Products Available</span>
			</div>

			<div class="grid md:grid-cols-3 gap-10">
				{products.map(p => (
					<a href={`/products/${p.slug}`} class="group block cursor-pointer">
						<div class="relative overflow-hidden rounded-2xl mb-6 aspect-[4/3] bg-slate-100 flex items-center justify-center">
							{p.data.image ? (
								<img src={p.data.image} alt={p.data.title} class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500" />
							) : (
								<div class="w-full h-full flex flex-col items-center justify-center text-slate-400 p-6 text-center select-none">
									<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 mb-3 text-slate-300">
										<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
									</svg>
									<span class="text-xs font-bold uppercase tracking-wider text-slate-400">Image Coming Soon</span>
								</div>
							)}
							<div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
						</div>
						<h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors line-clamp-2" title={p.data.title}>{p.data.title}</h3>
						<p class="text-slate-600 mb-6 leading-relaxed line-clamp-3 text-sm">{p.data.description}</p>
						<span class="inline-flex items-center gap-2 font-bold text-blue-600 text-sm">Learn More <span class="text-xl leading-none">›</span></span>
					</a>
				))}
			</div>
		</section>

		<!-- Why Us -->
		<section id="why-us" class="bg-slate-100 py-24 scroll-mt-6">
			<div class="max-w-7xl mx-auto px-4 grid md:grid-cols-3 gap-12 text-center">
				<div>
					<div class="w-16 h-16 bg-blue-600 text-white rounded-2xl flex items-center justify-center mx-auto mb-6 text-2xl">✓</div>
					<h4 class="text-xl font-bold mb-3">Certified Quality</h4>
					<p class="text-slate-600">Full compliance with ISO 9001, ISO 14001, and international CE standards.</p>
				</div>
				<div>
					<div class="w-16 h-16 bg-blue-600 text-white rounded-2xl flex items-center justify-center mx-auto mb-6 text-2xl">🌍</div>
					<h4 class="text-xl font-bold mb-3">Global Export</h4>
					<p class="text-slate-600">Trusted by major contractors across Southeast Asia, the Middle East, and Africa.</p>
				</div>
				<div>
					<div class="w-16 h-16 bg-blue-600 text-white rounded-2xl flex items-center justify-center mx-auto mb-6 text-2xl">⚙</div>
					<h4 class="text-xl font-bold mb-3">Technical Support</h4>
					<p class="text-slate-600">From design phase to installation, our engineers provide complete project solutions.</p>
				</div>
			</div>
		</section>
	</main>
</Layout>
