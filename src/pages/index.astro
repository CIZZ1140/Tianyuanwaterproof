---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTA from '../components/CTA.astro';
import { getCollection } from 'astro:content';
import { applications, productCategories, site, stats } from '../data/site';

const products = (await getCollection('products')).sort((a,b)=>a.data.order-b.data.order);
const featured = products.filter((p)=>p.data.featured).slice(0,6);
---
<Layout title="Waterproofing Membranes, Tapes & Coatings Manufacturer">
  <section class="relative overflow-hidden bg-deep text-white">
    <img src={site.heroImage} alt="Torch applied waterproofing membrane roof construction" class="absolute inset-0 h-full w-full object-cover opacity-55" />
    <div class="absolute inset-0 bg-gradient-to-r from-deep via-deep/75 to-deep/15"></div>
    <div class="container relative grid min-h-[560px] items-center py-20">
      <div class="max-w-2xl">
        <h1 class="text-5xl font-black uppercase leading-tight md:text-7xl">Reliable Waterproofing Materials from China</h1>
        <p class="mt-6 max-w-xl text-lg leading-8 text-white/85">Factory supply of waterproofing membranes, tapes and coatings with OEM packaging, technical data support and fast quotation service.</p>
        <div class="mt-8 flex flex-wrap gap-4"><a href="/contact/" class="btn-primary">Request a Quote →</a><a href="/products/" class="btn-secondary">View Products ↓</a></div>
      </div>
    </div>
  </section>

  <section class="bg-navy py-6 text-white">
    <div class="container grid grid-cols-2 gap-4 md:grid-cols-5">
      {stats.map((s)=><div class="border-white/10 md:border-r last:border-0"><p class="text-2xl font-black text-blue-300">{s.value}</p><p class="text-xs font-semibold text-white/70">{s.label}</p></div>)}
    </div>
  </section>

  <section class="py-12">
    <div class="container">
      <SectionHeader title="Product Categories" href="/products/" linkLabel="View All Products" />
      <div class="grid gap-6 lg:grid-cols-3">
        {productCategories.slice(0,3).map((cat)=>(
          <article class="card overflow-hidden p-6">
            <a href={cat.href} class="block aspect-[16/9] rounded-xl bg-slate-50 p-4"><img src={cat.image} alt={cat.title} class="h-full w-full object-contain" /></a>
            <h3 class="mt-5 text-xl font-extrabold uppercase text-navy"><a href={cat.href}>{cat.title}</a></h3>
            <ul class="mt-3 space-y-2 text-sm text-slate-600">{cat.items.map((i)=><li>• <a href={i.href} class="hover:text-brand">{i.title}</a></li>)}</ul>
            <a href={cat.href} class="mt-6 inline-flex text-sm font-bold text-brand">View All →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-12">
    <div class="container">
      <SectionHeader title="Applications" href="/applications/" linkLabel="View All Applications" />
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-6">
        {applications.map((app)=>(
          <a href={`/applications/${app.slug}/`} class="group relative min-h-44 overflow-hidden rounded-xl shadow-card">
            <img src={app.image} alt={app.title} loading="lazy" class="absolute inset-0 h-full w-full object-cover transition-transform group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-deep via-deep/45 to-transparent"></div>
            <h3 class="absolute bottom-4 left-4 right-4 text-lg font-extrabold text-white">{app.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-14">
    <div class="container grid gap-8 lg:grid-cols-2 lg:items-center">
        <div>
          <p class="section-kicker text-xs opacity-80">Why Choose Us</p>
          <h2 class="section-title normal-case text-4xl leading-tight">A Global Leader in Waterproofing Innovation</h2>
        <div class="mt-5 space-y-4 text-sm leading-7 text-slate-700">
          <p>Weifang Tianyuan Waterproof Material Co., Ltd., located in the “Waterproofing Capital of China” — Shouguang, is a premier manufacturer specializing in advanced waterproofing systems. With over 20 years of industry expertise, we integrate R&D, manufacturing, and international sales to deliver high-performance solutions for residential, commercial, and industrial projects worldwide.</p>
          <p>Our state-of-the-art facility is equipped with multiple automated production lines for bitumen membranes, polymer sheets, and eco-friendly coatings. At Tianyuan Waterproof, we don’t just sell products; we provide peace of mind through engineering excellence.</p>
        </div>
      </div>
      <img src="https://img.tyuanwaterproof.com/home/factory.png" alt="Tianyuan Waterproof factory" class="rounded-2xl shadow-card" />
      <div class="lg:col-span-2 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
        {[
          ['Factory Direct Supply','Competitive pricing from source manufacturer with stable production capacity.'],
          ['Global Certifications','Products strictly adhere to ASTM, CE, and ISO international standards.'],
          ['Premium QC System','Rigorous quality control process to ensure zero-defect delivery.'],
          ['Global Export Presence','Trusted partner in 50+ countries across SE Asia, Middle East, Africa, and Americas.'],
          ['Full-Cycle Service','Fast quotation, and end-to-end logistics management.']
        ].map(([t,d])=><div class="card p-5"><p class="font-extrabold text-navy">{t}</p><p class="mt-2 text-sm leading-6 text-slate-600">{d}</p></div>)}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-12">
    <div class="container">
      <SectionHeader title="Featured Products" href="/products/" linkLabel="View All Products" />
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-6">
        {featured.map((p)=><ProductCard title={p.data.shortTitle || p.data.title} href={`/products/${p.slug}/`} image={p.data.image} />)}
      </div>
    </div>
  </section>

  <section class="py-20 overflow-hidden">
    <div class="container">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
        <div class="max-w-2xl">
          <p class="text-brand font-bold tracking-[0.2em] uppercase text-sm mb-4">Success Stories</p>
          <h2 class="text-4xl md:text-5xl font-black text-navy uppercase">Global Projects & Case Studies</h2>
        </div>
        <a href="/projects/" class="text-brand font-bold uppercase tracking-widest text-sm border-b-2 border-brand pb-1">View All Case Studies →</a>
      </div>
      
      <div class="grid gap-8 md:grid-cols-2">
        <div class="group relative overflow-hidden rounded-3xl bg-navy aspect-[16/10]">
          <img src="https://img.tyuanwaterproof.com/home/tunnel.png" alt="Bangkok Subway Project" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-navy via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <span class="bg-brand text-white text-[10px] font-bold uppercase px-3 py-1 rounded-full mb-3 inline-block">Infrastructure</span>
            <h3 class="text-2xl font-bold text-white mb-2 uppercase">Bangkok Subway Extension</h3>
            <p class="text-white/70 text-sm line-clamp-2">Thailand - Supplying 50,000+ SQM of HDPE pre-applied membranes for station waterproofing and tunnel segments.</p>
          </div>
        </div>
        
        <div class="group relative overflow-hidden rounded-3xl bg-navy aspect-[16/10]">
          <img src="https://img.tyuanwaterproof.com/home/factory.png" alt="Industrial Plant Vietnam" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-navy via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <span class="bg-brand text-white text-[10px] font-bold uppercase px-3 py-1 rounded-full mb-3 inline-block">Industrial</span>
            <h3 class="text-2xl font-bold text-white mb-2 uppercase">Samsung Factory Complex</h3>
            <p class="text-white/70 text-sm line-clamp-2">Vietnam - TPO roofing systems and specialized bitumen membranes for major industrial production facilities in Bac Ninh.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</Layout>
