---
import Layout from '@/layouts/Layout.astro';
import ProductCard from '@/components/ProductCard.astro';
import CTA from '@/components/CTA.astro';
import { categories, featuredProducts } from '@/data/products';
import { applications } from '@/data/applications';
const base = import.meta.env.BASE_URL;
---
<Layout title="Waterproofing Membrane, Tape & Coating Manufacturer" description="B2B waterproofing materials supplier for bitumen membranes, waterproof tapes, TPO/PVC membranes and liquid waterproofing coatings.">
  <section class="relative overflow-hidden bg-navy text-white">
    <div class="absolute inset-0 opacity-20" style={`background-image:url('${base}assets/hero.svg');background-size:cover;background-position:center;`}></div>
    <div class="container-wrap relative grid gap-12 py-20 lg:grid-cols-[1.1fr_.9fr] lg:items-center lg:py-28">
      <div>
        <p class="eyebrow">B2B waterproofing materials supplier</p>
        <h1 class="mt-5 max-w-4xl text-4xl font-black leading-tight text-white md:text-6xl">Waterproofing Membrane, Tape & Coating Manufacturer</h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-white/75">Factory supply of bitumen membranes, waterproof tapes, TPO/PVC membranes and liquid waterproof coatings for roofing, basement and construction waterproofing projects.</p>
        <div class="mt-9 flex flex-wrap gap-4">
          <a class="btn-primary" href={`${base}products/`}>View Products</a>
          <a class="btn-secondary" href={`${base}contact/`}>Get a Quote</a>
          <a class="btn-secondary" href={`${base}technical/download-center/`}>Download Catalog</a>
        </div>
      </div>
      <div class="dark-card p-5">
        <img src={`${base}assets/hero.svg`} alt="Waterproofing materials" class="rounded-2xl" />
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container-wrap">
      <p class="eyebrow">Product categories</p>
      <h2 class="section-title mt-3">Core waterproofing product lines</h2>
      <p class="section-copy">A clear product structure for distributors, contractors and bulk construction material buyers.</p>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {categories.map((cat) => (
          <a class="card" href={`${base}products/${cat.slug}/`}>
            <h3 class="text-2xl font-bold">{cat.name}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">{cat.intro}</p>
            <ul class="mt-5 space-y-2 text-sm text-slate-700">{cat.items.map((item) => <li>✓ {item}</li>)}</ul>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-16 md:py-24">
    <div class="container-wrap">
      <div class="grid gap-10 lg:grid-cols-[.8fr_1.2fr] lg:items-end">
        <div>
          <p class="eyebrow">Featured products</p>
          <h2 class="section-title mt-3">Products prepared for B2B inquiry</h2>
          <p class="section-copy">Each product page contains overview, features, applications, specifications and quote entry.</p>
        </div>
        <div class="flex lg:justify-end"><a class="btn-outline" href={`${base}products/`}>All Products</a></div>
      </div>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {featuredProducts.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container-wrap">
      <p class="eyebrow">Applications</p>
      <h2 class="section-title mt-3">Waterproofing solutions by project area</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {applications.map((app) => (
          <a class="card" href={`${base}applications/${app.slug}/`}>
            <h3 class="text-xl font-bold">{app.title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">{app.intro}</p>
            <span class="mt-5 inline-flex text-sm font-bold text-industrial">Recommended products →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-900 py-16 text-white md:py-24">
    <div class="container-wrap grid gap-10 lg:grid-cols-4">
      {['Factory Direct Supply','OEM / ODM Available','Technical Data Support','Export Packaging'].map((item) => (
        <div class="dark-card">
          <div class="mb-5 grid h-12 w-12 place-items-center rounded-2xl bg-accent font-black text-slate-950">✓</div>
          <h3 class="text-xl font-bold text-white">{item}</h3>
          <p class="mt-3 text-sm leading-6 text-white/65">Built for distributors, contractors and B2B procurement teams that need stable specifications and fast communication.</p>
        </div>
      ))}
    </div>
  </section>
  <CTA />
</Layout>
