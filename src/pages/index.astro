---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTA from '../components/CTA.astro';
import { getCollection } from 'astro:content';
import { applications, productCategories, site, stats } from '../data/site';

function normalizeAsset(value: any) {
  if (!value) return "";
  if (typeof value === "string") return value;
  return value?.src || value?.url || "";
}

const products = (await getCollection('products')).sort((a,b)=>a.data.order-b.data.order);
const featured = products.filter((p)=>p.data.featured).slice(0,6);
---
<Layout 
	title="Tianyuan Waterproof | Leading China Waterproofing Materials Manufacturer"
	description="Weifang Tianyuan Waterproof (TY-SHIELD™) is a professional manufacturer of high-quality bitumen membranes, polymer membranes, and waterproof coatings with 30+ years of export experience."
	isHomePage={true}
>
  <Hero />
  <h2 class="sr-only">Main Content</h2>

  <section class="py-12" id="categories" aria-labelledby="cat-title">
    <div class="container mx-auto">
      <SectionHeader title="Product Categories" href="/products/" linkLabel="View All Products" id="cat-title" />
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {productCategories.map((cat)=>(
          <article class="card overflow-hidden p-5 flex flex-col h-full">
            <a href={cat.href} class="block aspect-[16/9] w-full rounded-xl bg-slate-50 overflow-hidden">
              <img 
                src={cat.image} 
                alt={cat.title} 
                class="h-full w-full object-cover transition-transform duration-500 hover:scale-105" 
                loading="lazy"
              />
            </a>
            <div class="mt-5 flex flex-col flex-grow">
              <h3 class="text-xl font-extrabold uppercase text-navy">
                <a href={cat.href} class="hover:text-brand transition-colors">{cat.title}</a>
              </h3>
              <ul class="mt-3 space-y-1.5 text-sm text-slate-600 flex-grow">
                {cat.items.map((i)=><li>• <a href={i.href} class="hover:text-brand">{i.title}</a></li>)}
              </ul>
              <div class="mt-6 pt-4 border-t border-slate-100">
                <a href={cat.href} class="inline-flex items-center text-sm font-bold text-brand hover:translate-x-1 transition-transform">
                  View All <span class="ml-1">→</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-12" aria-labelledby="app-title">
    <div class="container mx-auto">
      <SectionHeader title="Applications" href="/applications/" linkLabel="View All Applications" id="app-title" />
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-6">
        {applications.map((app)=>{
          return (
            <a href={`/applications/${app.slug}/`} class="group relative min-h-44 overflow-hidden rounded-xl shadow-card">
              <img 
                src={app.image} 
                alt={app.title} 
                loading="lazy" 
                decoding="async"
                class="absolute inset-0 h-full w-full object-cover transition-transform group-hover:scale-105" 
                width="400" 
                height="300" 
              />
              <div class="absolute inset-0 bg-gradient-to-t from-deep via-deep/45 to-transparent"></div>
              <h3 class="absolute bottom-4 left-4 right-4 text-lg font-extrabold text-white">{app.title}</h3>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24" id="why-us" aria-labelledby="why-title">
    <div class="container mx-auto">
      <div class="grid gap-8 lg:grid-cols-2 lg:items-stretch mb-12">
        <!-- Left: Why Choose Us Content Card -->
        <article class="relative rounded-3xl border border-line bg-white p-6 shadow-sm sm:p-8 lg:p-10 flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-3">
              <span class="h-0.5 w-8 rounded-full bg-brand"></span>
              <p class="text-sm font-semibold text-brand uppercase tracking-wider">MANUFACTURER & SUPPLIER</p>
            </div>

            <h2 class="mt-5 max-w-3xl text-3xl font-bold leading-[1.35] tracking-normal text-navy sm:text-4xl lg:text-5xl" id="why-title">
              Reliable Waterproofing Manufacturer for Global Buyers
            </h2>

            <div class="mt-5 h-1 w-20 rounded-full bg-brand"></div>

            <div class="mt-8 max-w-3xl space-y-5 text-base leading-relaxed text-slate-700">
              <p>
                Tianyuan Waterproof manufactures <strong>waterproofing membranes, coatings, tapes and geosynthetic materials</strong> for roofing, basement, tunnel, bridge and infrastructure projects.
              </p>
              <p>
                With 30+ years of production experience and 5 production lines, we support contractors, distributors and project buyers with <strong>stable quality, OEM packaging, technical documents and fast quotation service</strong>.
              </p>
            </div>
          </div>

          <div>
            <div class="mt-8 grid gap-3 grid-cols-1 sm:grid-cols-3">
              <div class="rounded-2xl border border-line bg-slate-50 p-4">
                <div class="flex items-center gap-3">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand/10 text-brand">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3L19 6V11C19 15.5 16.1 19.4 12 21C7.9 19.4 5 15.5 5 11V6L12 3Z" stroke-linejoin="round"/><path d="M9 12L11.2 14.2L15.5 9.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                  <div class="flex flex-col justify-center">
                    <p class="text-xl font-black text-brand leading-none">30+</p>
                    <p class="mt-1.5 text-[10px] font-extrabold uppercase tracking-wider text-slate-500 text-nowrap">Years Experience</p>
                  </div>
                </div>
              </div>
              <div class="rounded-2xl border border-line bg-slate-50 p-4">
                <div class="flex items-center gap-3">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand/10 text-brand">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19H20" stroke-linecap="round"/><path d="M6 19V10L10 12V10L14 12V8L18 10V19" stroke-linejoin="round"/><path d="M8 15H9.5M12 15H13.5M16 15H17" stroke-linecap="round"/></svg>
                  </div>
                  <div class="flex flex-col justify-center">
                    <p class="text-xl font-black text-brand leading-none">5</p>
                    <p class="mt-1.5 text-[10px] font-extrabold uppercase tracking-wider text-slate-500 text-nowrap">Production Lines</p>
                  </div>
                </div>
              </div>
              <div class="rounded-2xl border border-line bg-slate-50 p-4">
                <div class="flex items-center gap-3">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand/10 text-brand">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21C16.9706 21 21 16.9706 21 12C21 7.02944 16.9706 3 12 3C7.02944 3 3 7.02944 3 12C3 16.9706 7.02944 21 12 21Z"/><path d="M3.6 9H20.4M3.6 15H20.4" stroke-linecap="round"/><path d="M12 3C14 5.2 15 8.2 15 12C15 15.8 14 18.8 12 21C10 18.8 9 15.8 9 12C9 8.2 10 5.2 12 3Z" stroke-linejoin="round"/></svg>
                  </div>
                  <div class="flex flex-col justify-center">
                    <p class="text-xl font-black text-brand leading-none">50+</p>
                    <p class="mt-1.5 text-[10px] font-extrabold uppercase tracking-wider text-slate-500 text-nowrap">Export Countries</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-8 flex flex-wrap gap-4">
              <a href="/contact/" class="inline-flex items-center justify-center rounded-xl bg-brand px-10 py-3.5 text-sm font-bold text-white shadow-lg shadow-brand/20 transition hover:bg-accent min-w-[180px]">
                Request a Quote <span class="ml-2">→</span>
              </a>
              <a href="/about/" class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-10 py-3.5 text-sm font-semibold text-navy transition hover:border-brand hover:text-brand min-w-[180px]">
                About Our Factory <span class="ml-2">→</span>
              </a>
            </div>
          </div>
        </article>

        <!-- Right: Factory High-res Image -->
        <div class="relative group overflow-hidden rounded-3xl shadow-card bg-gradient-to-br from-[#0E2A47] via-[#1F4E8C] to-[#0E2A47]">
          <img 
            src="https://img.tyuanwaterproof.com/factory-main.webp?v=2" 
            alt="Tianyuan Waterproof high-tech production facility" 
            class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105" 
            loading="lazy"
            decoding="async"
            width="800"
            height="1000"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
          />
          <div class="absolute inset-0 hidden flex-col items-center justify-center text-center p-8" style="display:none">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center mb-6">
              <svg class="w-10 h-10 text-white/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19h16M6 19V10l4 2V10l4 2V8l4 2V19"/></svg>
            </div>
            <p class="text-xl font-black text-white mb-2">Production Facility</p>
            <p class="text-sm text-white/60 font-medium">30+ years manufacturing experience<br/>5 production lines in Shandong, China</p>
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-navy/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      </div>

      <!-- Bottom: Key Advantages Grid -->
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
        {[
          ['Factory Direct Supply','Stable production capacity for bulk waterproofing material orders.'],
          ['OEM Packaging','Private label packaging, roll size customization and pallet packing support.'],
          ['Quality Control','Thickness, weight, tensile strength and packaging are checked before delivery.'],
          ['Technical Documents','TDS, MSDS and product specifications available for project evaluation.'],
          ['Export Support','Container loading, shipping documents and fast quotation for global buyers.']
        ].map(([t,d])=>(
          <div class="card p-6 bg-white border border-line rounded-2xl hover:shadow-xl transition-all duration-300">
            <p class="font-extrabold text-navy text-sm uppercase tracking-wide">{t}</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white border-y border-slate-100 py-12" aria-labelledby="cert-title">
    <div class="container mx-auto">
      <div class="flex items-end justify-between mb-8">
        <div>
          <span class="inline-block rounded-full border border-brand/20 bg-brand/5 px-3 py-0.5 text-[10px] font-bold text-brand uppercase tracking-[0.12em] mb-2">Certified</span>
          <h3 class="text-xl font-black text-navy uppercase tracking-tight" id="cert-title">International Certifications</h3>
        </div>
        <a href="/about/#certifications" class="shrink-0 text-sm font-bold text-brand hover:underline whitespace-nowrap">View All →</a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        <div class="group rounded-xl bg-white border border-slate-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <div class="bg-[#F8F9FA] p-3">
            <img src="https://sc02.alicdn.com/kf/Hd52f7d79611f4932b1eb4758f9f46dbem.jpg" alt="CE RoHS Membrane" width="1200" height="848" loading="lazy" class="w-full object-contain aspect-[3/4] group-hover:scale-105 transition-transform duration-300" />
          </div>
          <div class="px-3 py-2.5 text-center border-t border-slate-50">
            <p class="text-xs font-extrabold text-navy">CE RoHS</p>
            <p class="text-[10px] text-slate-400">Membrane</p>
          </div>
        </div>
        <div class="group rounded-xl bg-white border border-slate-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <div class="bg-[#F8F9FA] p-3">
            <img src="https://img.tyuanwaterproof.com/certs/ce-rohs-coating.jpg?v=2" alt="CE RoHS Coating" width="1200" height="848" loading="lazy" class="w-full object-contain aspect-[3/4] group-hover:scale-105 transition-transform duration-300" />
          </div>
          <div class="px-3 py-2.5 text-center border-t border-slate-50">
            <p class="text-xs font-extrabold text-navy">CE RoHS</p>
            <p class="text-[10px] text-slate-400">Coating</p>
          </div>
        </div>
        <div class="group rounded-xl bg-white border border-slate-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <div class="bg-[#F8F9FA] p-3">
            <img src="https://img.tyuanwaterproof.com/certs/iso-9001-2015-en.jpg?v=2" alt="ISO 9001:2015" width="748" height="956" loading="lazy" class="w-full object-contain aspect-[3/4] group-hover:scale-105 transition-transform duration-300" />
          </div>
          <div class="px-3 py-2.5 text-center border-t border-slate-50">
            <p class="text-xs font-extrabold text-navy">ISO 9001:2015</p>
            <p class="text-[10px] text-slate-400">Quality Management</p>
          </div>
        </div>
        <div class="group rounded-xl bg-white border border-slate-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <div class="bg-[#F8F9FA] p-3">
            <img src="https://img.tyuanwaterproof.com/certs/iso-14001-2015.jpg?v=2" alt="ISO 14001:2015" width="748" height="956" loading="lazy" class="w-full object-contain aspect-[3/4] group-hover:scale-105 transition-transform duration-300" />
          </div>
          <div class="px-3 py-2.5 text-center border-t border-slate-50">
            <p class="text-xs font-extrabold text-navy">ISO 14001:2015</p>
            <p class="text-[10px] text-slate-400">Environmental</p>
          </div>
        </div>
        <div class="group rounded-xl bg-white border border-slate-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow">
          <div class="bg-[#F8F9FA] p-3">
            <img src="https://img.tyuanwaterproof.com/certs/iso-45001-2018.jpg?v=2" alt="ISO 45001:2018" width="748" height="956" loading="lazy" class="w-full object-contain aspect-[3/4] group-hover:scale-105 transition-transform duration-300" />
          </div>
          <div class="px-3 py-2.5 text-center border-t border-slate-50">
            <p class="text-xs font-extrabold text-navy">ISO 45001:2018</p>
            <p class="text-[10px] text-slate-400">Health &amp; Safety</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-12" aria-labelledby="feat-title">
    <div class="container mx-auto">
      <SectionHeader title="Featured Products" href="/products/" linkLabel="View All Products" id="feat-title" />
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-6">
        {featured.map((p)=><ProductCard title={p.slug === 'epdm-waterproofing-membrane-wholesale' ? 'SBS Bitumen Waterproof Membrane' : (p.data.displayName || p.data.shortTitle || p.data.title)} href={p.slug === 'epdm-waterproofing-membrane-wholesale' ? '/products/sbs-bitumen-waterproofing-membrane-manufacturer/' : `/products/${p.slug}/`} image={p.slug === 'epdm-waterproofing-membrane-wholesale' ? 'https://img.tyuanwaterproof.com/products/sbs-torch-membrane-main.webp' : p.data.image} />)}
      </div>
    </div>
  </section>

  <section class="py-20 overflow-hidden" aria-labelledby="proj-title">
    <div class="container mx-auto">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
        <div class="max-w-2xl">
          <p class="text-brand font-bold tracking-[0.2em] uppercase text-sm mb-4">Success Stories</p>
          <h2 class="text-4xl md:text-5xl font-black text-navy uppercase" id="proj-title">Global Projects & Case Studies</h2>
        </div>
        <a href="/projects/" class="text-brand font-bold uppercase tracking-widest text-sm border-b-2 border-brand pb-1">View All Case Studies →</a>
      </div>
      
      <div class="grid gap-8 md:grid-cols-2">
        <div class="group relative overflow-hidden rounded-3xl bg-navy aspect-[16/10]">
          <img 
            src="https://img.tyuanwaterproof.com/projects/tunnel-interior.webp" 
            alt="Metro tunnel waterproofing project" 
            class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-500" 
            width="800" 
            height="500" 
            onerror="this.src='https://img.tyuanwaterproof.com/placeholder.webp'; this.onerror=null;"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-navy via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <span class="bg-brand text-white text-[10px] font-bold uppercase px-3 py-1 rounded-full mb-3 inline-block">Infrastructure</span>
            <h3 class="text-2xl font-bold text-white mb-2 uppercase">Metro Tunnel Waterproofing</h3>
            <p class="text-white/70 text-sm line-clamp-2">Supplied SBS and HDPE waterproofing membrane systems for underground metro station and tunnel segment waterproofing projects.</p>
          </div>
        </div>
        
        <div class="group relative overflow-hidden rounded-3xl bg-navy aspect-[16/10]">
          <img 
            src="https://img.tyuanwaterproof.com/projects/industrial-factory-aerial.webp" 
            alt="Industrial factory waterproofing project" 
            class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-500" 
            width="800" 
            height="500" 
            onerror="this.src='https://img.tyuanwaterproof.com/placeholder.webp'; this.onerror=null;"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-navy via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <span class="bg-brand text-white text-[10px] font-bold uppercase px-3 py-1 rounded-full mb-3 inline-block">Industrial</span>
            <h3 class="text-2xl font-bold text-white mb-2 uppercase">Industrial Factory Waterproofing</h3>
            <p class="text-white/70 text-sm line-clamp-2">Supplied TPO roofing membranes and bitumen waterproofing systems for large-scale industrial production facilities and warehouse roofing projects.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</Layout>

