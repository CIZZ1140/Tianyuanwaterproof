---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { site, productCategories, applications, nav } from "../data/site";

const pageTitle = `Site Map | ${site.brand}`;
const pageDescription = `Full directory of ${site.brand} waterproofing products, technical resources, and professional construction solutions.`;

// 1. Fetch Data
const rawProducts = await getCollection("products");
const products = rawProducts.filter(p => !p.data.draft);

// 2. Category Mapping (Strict Labeling)
const categoryMapping = {
  "bitumen-membranes": "Bitumen Membranes",
  "asphalt-membranes": "Bitumen Membranes",
  "polymer-membranes": "Polymer Membranes",
  "asphalt-shingles": "Asphalt Shingles",
  "waterproof-tapes": "Waterproof Tapes",
  "waterproof-coatings": "Waterproof Coatings",
  "geosynthetics": "Geosynthetics",
  "other": "Other Waterproof Products",
};

const categoryOrder = [
  "Bitumen Membranes",
  "Polymer Membranes",
  "Asphalt Shingles",
  "Waterproof Tapes",
  "Waterproof Coatings",
  "Geosynthetics",
];

// 3. Group Products by Category
const groupedProducts = categoryOrder.map(label => {
  const items = products
    .filter(p => {
      const categoryId = p.data.category || "bitumen-membranes";
      return (categoryMapping[categoryId] || "Other Waterproof Products") === label;
    })
    .map(p => ({
      title: p.data.title,
      href: `/products/${p.slug}/`,
      hasTDS: true // Most products have TDS in your V2.0 layout
    }));
  return { label, items };
});

const resources = [
  { title: "Technical Data Sheets (TDS)", href: "/technical/" },
  { title: "Installation Guide", href: "/technical/installation-guide/" },
  { title: "Download Center", href: "/technical/download-center/" },
  { title: "Case Studies", href: "/projects/" },
  { title: "FAQ", href: "/technical/faq/" }
];

const corporate = [
  { title: "About Tianyuan", href: "/about/" },
  { title: "Production Facility", href: "/about/#factory" },
  { title: "Quality Certificates", href: "/about/#certificates" },
  { title: "Contact Us", href: "/contact/" }
];
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="bg-white min-h-screen">
    {/* Header */}
    <section class="bg-gradient-to-r from-[#0B1E3B] to-[#162D55] text-white py-24 px-6">
      <div class="max-w-7xl mx-auto">
        <h1 class="text-4xl md:text-6xl font-black mb-6 text-white tracking-tight">Site Map</h1>
        <p class="text-white/80 max-w-2xl text-lg leading-relaxed font-medium">
          Explore our full directory of high-performance waterproofing materials, technical resources, and professional construction solutions.
        </p>
      </div>
    </section>

    {/* Sitemap Grid */}
    <section class="max-w-7xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-12">
        
        {/* Products Section */}
        {groupedProducts.map(group => group.items.length > 0 && (
          <div class="space-y-6">
            <h2 class="flex items-center text-lg font-bold text-[#0B1E3B] border-b-2 border-slate-100 pb-3">
              <svg class="w-5 h-5 mr-2 text-[#3B82F6]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
              {group.label}
            </h2>
            <ul class="space-y-3">
              {group.items.map(item => (
                <li>
                  <a href={item.href} class="text-[14.5px] text-[#5B6B7C] hover:text-[#3B82F6] hover:underline flex justify-between items-center group">
                    <span>{item.title}</span>
                    {item.hasTDS && (
                      <span class="text-[9px] bg-slate-100 text-slate-500 px-1.5 py-0.5 rounded font-bold uppercase group-hover:bg-[#3B82F6] group-hover:text-white transition-colors">TDS</span>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}

        {/* Applications Section */}
        <div class="space-y-6">
          <h2 class="flex items-center text-lg font-bold text-[#0B1E3B] border-b-2 border-slate-100 pb-3">
            <svg class="w-5 h-5 mr-2 text-[#3B82F6]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
            Solutions
          </h2>
          <ul class="space-y-3">
            {applications.map(app => (
              <li>
                <a href={`/applications/${app.slug}/`} class="text-[14.5px] text-[#5B6B7C] hover:text-[#3B82F6] hover:underline">
                  {app.title}
                </a>
              </li>
            ))}
          </ul>
        </div>

        {/* Resources Section */}
        <div class="space-y-6">
          <h2 class="flex items-center text-lg font-bold text-[#0B1E3B] border-b-2 border-slate-100 pb-3">
            <svg class="w-5 h-5 mr-2 text-[#3B82F6]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"></path></svg>
            Resources
          </h2>
          <ul class="space-y-3">
            {resources.map(res => (
              <li>
                <a href={res.href} class="text-[14.5px] text-[#5B6B7C] hover:text-[#3B82F6] hover:underline">
                  {res.title}
                </a>
              </li>
            ))}
          </ul>
        </div>

        {/* Corporate Section */}
        <div class="space-y-6">
          <h2 class="flex items-center text-lg font-bold text-[#0B1E3B] border-b-2 border-slate-100 pb-3">
            <svg class="w-5 h-5 mr-2 text-[#3B82F6]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1"></path></svg>
            Corporate
          </h2>
          <ul class="space-y-3">
            {corporate.map(corp => (
              <li>
                <a href={corp.href} class="text-[14.5px] text-[#5B6B7C] hover:text-[#3B82F6] hover:underline">
                  {corp.title}
                </a>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </section>
  </main>
</Layout>
