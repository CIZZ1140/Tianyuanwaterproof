---
import Layout from '@/layouts/Layout.astro';
import CTA from '@/components/CTA.astro';
import { applications } from '@/data/applications';
const base = import.meta.env.BASE_URL;
---
<Layout 
  title="Waterproofing Solutions for Roofing, Basement & Infrastructure"
  description="Discover professional waterproofing application solutions for commercial and industrial projects, including roofs, basements, tunnels, and pools."
>
  <section class="bg-[#0E2A47] py-16 text-white"><div class="container mx-auto px-4"><p class="text-[#F58A1F] text-xs font-black uppercase tracking-widest">Solutions</p>      <h1 class="mt-3 text-4xl font-black text-white md:text-5xl leading-[1.2] pb-2">Waterproofing solutions by application</h1><p class="mt-5 max-w-3xl text-white/70">Help buyers select suitable membranes, tapes and coatings according to project area.</p></div></section>
  <section class="py-16"><div class="container mx-auto px-4 grid gap-6 md:grid-cols-2 lg:grid-cols-3">{applications.map((app) => <a class="group block p-8 bg-white border border-slate-200 rounded-3xl transition-all hover:shadow-xl hover:-translate-y-1" href={`${base}applications/${app.slug}/`}><h2 class="text-2xl font-extrabold text-[#0E2A47]">{app.title}</h2><p class="mt-3 text-sm leading-7 text-slate-600">{app.summary}</p><span class="mt-5 inline-flex items-center gap-2 text-sm font-bold text-[#F58A1F]">View solution <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></a>)}</div></section>
  <CTA />
</Layout>
