---
import Layout from '@/layouts/Layout.astro';
import CTA from '@/components/CTA.astro';
import { applications } from '@/data/applications';
export function getStaticPaths() { return applications.map((app) => ({ params: { slug: app.slug }, props: { app } })); }
const { app } = Astro.props;
---
<Layout title={`${app.title} | Waterproofing Application`} description={app.intro}>
  <section class="bg-[#0E2A47] py-20 text-white border-b border-white/5">
    <div class="container-wrap">
      <p class="inline-flex items-center px-3 py-1 rounded-full bg-white/10 text-white/70 text-[10px] font-bold uppercase tracking-widest mb-6">Application Solution</p>
      <h1 class="text-4xl font-black text-white md:text-5xl lg:text-6xl tracking-tight">{app.title}</h1>
      <p class="mt-6 max-w-3xl text-lg text-white/70 leading-relaxed font-medium">{app.intro}</p>
    </div>
  </section>
  <section class="py-16"><div class="container-wrap grid gap-10 lg:grid-cols-[.9fr_1.1fr]">
    <div class="card"><h2 class="text-2xl font-bold">Recommended products</h2><ul class="mt-5 space-y-3 text-sm">{app.recommended.map((item) => <li class="rounded-xl bg-slate-100 px-4 py-3 font-semibold">{item}</li>)}</ul></div>
    <div><h2 class="text-3xl font-bold">Solution notes</h2><div class="mt-6 grid gap-4">{app.points.map((point) => <div class="card"><p class="font-semibold">✓ {point}</p></div>)}</div></div>
  </div></section>
  <CTA />
</Layout>
