---
import Layout from '@/layouts/Layout.astro';
import CTA from '@/components/CTA.astro';
const files = ['Product Catalog','Technical Data Sheet','MSDS','Installation Guide','Test Report','Certificate','OEM Packaging Guide','Construction Method'];
---
<Layout title="Download Center | Technical Data">
  <section class="bg-navy py-16 text-white"><div class="container-wrap"><p class="eyebrow">Technical support</p><h1 class="mt-3 text-4xl font-black text-white md:text-5xl">Download center</h1><p class="mt-5 max-w-3xl text-white/70">Prepare technical documents for B2B buyers before purchase approval.</p></div></section>
  <section class="py-16"><div class="container-wrap grid gap-6 md:grid-cols-2 lg:grid-cols-4">{files.map((file) => <div class="card"><h2 class="text-xl font-bold">{file}</h2><p class="mt-3 text-sm leading-6 text-slate-600">Upload real PDF documents into public/downloads and link them here.</p><a class="mt-5 inline-flex text-sm font-bold text-industrial" href="/contact/">Request file →</a></div>)}</div></section>
  <CTA />
</Layout>
