---
import Layout from '@/layouts/Layout.astro';

const faqs = [
  {
    category: "Products & Customization",
    questions: [
      {
        q: "What international standards do your waterproofing membranes meet?",
        a: "Our products, including SBS, PVC, and TPO membranes, comply with international standards such as ASTM (American Society for Testing and Materials) and ISO 9001. We provide Technical Data Sheets (TDS) and MSDS for every batch to ensure compliance with global engineering requirements."
      },
      {
        q: "Do you support OEM and private label packaging?",
        a: "Yes. As a direct factory, we offer full OEM services. We can customize the roll length, thickness, and width, and print your company logo or private label on the product surface and packaging film according to your brand identity."
      },
      {
        q: "Can I request a free sample for quality testing?",
        a: "Absolutely. We provide free A4-sized or small roll samples for our global customers. You only need to cover the international courier cost, which will be deducted from your first official bulk order."
      }
    ]
  },
  {
    category: "Ordering & Logistics",
    questions: [
      {
        q: "What is your Minimum Order Quantity (MOQ)?",
        a: "For standard products, our MOQ is typically one 20ft container (approx. 2000-4000 sqm depending on thickness). However, for trial orders or specific stock items, we can negotiate a smaller quantity to support your market testing."
      },
      {
        q: "What is the typical lead time for an export order?",
        a: "Standard orders are usually ready for shipment within 7-15 days after receiving the deposit. For large OEM orders with custom packaging, the lead time is approximately 20 days."
      },
      {
        q: "Which ports do you usually ship from?",
        a: "Our factory is located in Weifang, Shandong. We primarily ship from Qingdao Port, which is one of the largest and most efficient ports in China, ensuring fast transit times to the Middle East, Southeast Asia, and Africa."
      }
    ]
  },
  {
    category: "Technical & Installation",
    questions: [
      {
        q: "Do you provide technical support for site installation?",
        a: "Yes, we provide detailed installation guides, video tutorials, and remote technical consultations. For large-scale infrastructure projects, we can provide professional engineering advice on material selection and joint sealing details."
      },
      {
        q: "What is the service life of your waterproofing membranes?",
        a: "Our premium SBS and TPO membranes are designed for a service life of 20-30 years in exposed roofing applications and even longer for buried underground projects, provided they are installed according to professional standards."
      }
    ]
  }
];

// Generate JSON-LD for SEO
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.flatMap(cat => cat.questions).map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};
---
<Layout 
  title="FAQ | Waterproofing Materials Factory Direct Support"
  description="Find expert answers to common questions about Bitumen Membranes, PVC, TPO, OEM services, MOQ, and international waterproofing standards (ASTM/ISO)."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Hero Section -->
  <section class="bg-[#0B1E3B] py-20 text-white border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6">
      <nav class="flex text-sm font-bold text-blue-200/90 gap-3 items-center mb-6 uppercase tracking-wider">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="text-blue-400/50">/</span>
        <span class="text-white">FAQ</span>
      </nav>
      <h1 class="text-4xl md:text-6xl font-black text-white uppercase leading-tight">
        Frequently Asked <span class="text-blue-500">Questions</span>
      </h1>
      <p class="mt-6 text-slate-300 max-w-2xl text-lg leading-relaxed">
        Expert answers for construction contractors, importers, and project buyers about waterproofing material sourcing and application.
      </p>
    </div>
  </section>

  <section class="py-20 bg-[#F5F7FA]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-[340px_1fr] gap-16">
        <!-- REDESIGNED Sidebar Navigation -->
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <div class="bg-[#0B1E3B] rounded-[2rem] p-8 shadow-2xl border border-white/10 overflow-hidden relative">
              <!-- Decorative element -->
              <div class="absolute -top-12 -right-12 w-32 h-32 bg-blue-600/20 rounded-full blur-3xl"></div>
              
              <h2 class="text-[13px] font-black uppercase tracking-[0.2em] text-blue-400 mb-10">Topic Categories</h2>
              
              <nav class="flex flex-col gap-3">
                {faqs.map((cat) => (
                  <a 
                    href={`#${cat.category.toLowerCase().replace(/\s+/g, '-')}`} 
                    class="group flex items-center justify-between px-6 py-5 rounded-2xl bg-white/5 border border-white/5 text-white hover:bg-blue-600 hover:border-blue-400 transition-all duration-300 transform hover:-translate-y-1"
                  >
                    <span class="text-lg font-bold tracking-tight">{cat.category}</span>
                    <svg class="w-5 h-5 text-white/30 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
                  </a>
                ))}
              </nav>

              <div class="mt-12 pt-10 border-t border-white/10">
                <h3 class="text-white font-black text-xl mb-3">Still Need Help?</h3>
                <p class="text-slate-400 text-sm leading-relaxed mb-8">Can't find the specific technical answer? Our engineers are ready to assist you.</p>
                <a href="/contact/" class="flex items-center justify-center gap-3 bg-blue-600 hover:bg-blue-500 text-white font-black text-sm uppercase tracking-widest py-4 px-6 rounded-2xl transition-all shadow-xl shadow-blue-900/20 group">
                  Contact Expert
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7-7 7"></path></svg>
                </a>
              </div>
            </div>
          </div>
        </aside>

        <!-- FAQ Content -->
        <div class="space-y-24">
          {faqs.map((cat) => (
            <div id={cat.category.toLowerCase().replace(/\s+/g, '-')} class="scroll-mt-24">
              <div class="inline-flex items-center gap-3 bg-blue-600/10 px-4 py-1.5 rounded-full mb-6">
                <span class="w-2 h-2 bg-blue-600 rounded-full animate-pulse"></span>
                <span class="text-xs font-black text-blue-700 uppercase tracking-widest">{cat.category}</span>
              </div>
              
              <h2 class="text-3xl md:text-4xl font-black text-[#0B1E3B] uppercase mb-10 tracking-tight leading-none">
                {cat.category}
              </h2>

              <div class="grid gap-8">
                {cat.questions.map((faq) => (
                  <div class="group bg-white rounded-[2rem] p-10 border border-slate-200 shadow-sm hover:shadow-xl transition-all duration-500 hover:border-blue-200 relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-2 h-0 bg-blue-600 group-hover:h-full transition-all duration-500"></div>
                    <h3 class="text-xl md:text-2xl font-black text-[#0B1E3B] mb-6 leading-tight group-hover:text-blue-600 transition-colors">
                      {faq.q}
                    </h3>
                    <div class="h-0.5 w-12 bg-slate-100 mb-6 group-hover:w-24 group-hover:bg-blue-200 transition-all duration-500"></div>
                    <p class="text-slate-600 leading-relaxed text-base md:text-lg">
                      {faq.a}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-32 bg-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('https://img.tyuanwaterproof.com/grid.svg')] opacity-[0.03]"></div>
    <div class="max-w-7xl mx-auto px-6 text-center relative z-10">
      <h2 class="text-4xl md:text-5xl font-black text-[#0B1E3B] uppercase mb-8 leading-tight">Discuss Your Project with Our <span class="text-blue-600 underline underline-offset-8 decoration-8 decoration-blue-100">Technical Team</span></h2>
      <p class="text-slate-500 mb-12 max-w-2xl mx-auto text-lg leading-relaxed font-medium">Get custom quotations, technical datasheets, and professional advice for your specific waterproofing project.</p>
      <div class="flex flex-wrap justify-center gap-6">
        <a href="/contact/" class="bg-[#0B1E3B] text-white font-black text-sm uppercase tracking-[0.2em] px-12 py-5 rounded-2xl hover:bg-blue-600 transition-all shadow-2xl shadow-navy/20">Send Inquiry</a>
        <a href="https://wa.me/8615263640998" class="bg-[#25D366] text-white font-black text-sm uppercase tracking-[0.2em] px-12 py-5 rounded-2xl hover:scale-105 transition-all shadow-2xl shadow-green-500/20">WhatsApp Us</a>
      </div>
    </div>
  </section>
</Layout>
