---
import Layout from '@/layouts/Layout.astro';
import CTA from '@/components/CTA.astro';
---
<Layout title="Installation Guide | Waterproofing Materials">
  <section class="bg-navy py-16 text-white"><div class="container-wrap"><p class="eyebrow">Technical support</p><h1 class="mt-3 text-4xl font-black text-white md:text-5xl">Installation guide</h1><p class="mt-5 max-w-3xl text-white/70">General installation information for membranes, tapes and coatings. Replace with product-specific instructions.</p></div></section>
  <section class="py-16"><div class="container-wrap grid gap-6 md:grid-cols-3">{['Surface preparation','Application method','Inspection & storage'].map((title) => <div class="card"><h2 class="text-2xl font-bold">{title}</h2><p class="mt-3 text-sm leading-6">Clean substrate, confirm dryness and temperature requirements, follow product TDS and project specification.</p></div>)}</div></section>
  <CTA />
</Layout>
